+
+static bool safe_name(const char *name)
+{
+	const char *p;
+
+	if (!name || !name[0] || !strcmp(name, ".") || !strcmp(name, ".."))
+		return false;
+
+	for (p = name; *p; p++) {
+		if ((*p >= 'A' && *p <= 'Z') ||
+		    (*p >= 'a' && *p <= 'z') ||
+		    (*p >= '0' && *p <= '9') ||
+		    *p == '.' || *p == '_' || *p == '-')
+			continue;
