+static int unix_sockaddr_path(const char *path, struct sockaddr_un *addr,
+			      socklen_t *addrlen)
+{
+	size_t len = strlen(path);
+
+	if (len >= sizeof(addr->sun_path))
+		return -ENAMETOOLONG;
+
+	memset(addr, 0, sizeof(*addr));
