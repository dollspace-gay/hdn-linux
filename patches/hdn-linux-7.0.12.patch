+static int event_decoder_read_output(int fd, char *buf, size_t size)
+{
+	size_t offset = 0;
+
+	if (!size)
+		return -EINVAL;
+
+	for (;;) {
+		ssize_t len;
+
+		if (offset == size - 1)
+			return -ENOSPC;
+		len = read(fd, buf + offset, size - 1 - offset);
+		if (len < 0) {
+			if (errno == EINTR)
+				continue;
+			return -errno;
+		}
+		if (!len)
+			break;
+		offset += len;
+	}
+
+	buf[offset] = '\0';
+	return 0;
+}
+
+static int event_decoder_run_capture(const char *input, char *buf, size_t size)
+{
+	int pipefd[2];
+	int status;
+	pid_t child;
+	int ret;
+
+	if (pipe(pipefd))
+		return -errno;
+
+	child = fork();
+	if (child < 0) {
+		ret = -errno;
+		close(pipefd[0]);
+		close(pipefd[1]);
+		return ret;
+	}
+
+	if (!child) {
+		close(pipefd[0]);
+		if (dup2(pipefd[1], STDOUT_FILENO) < 0)
+			_exit(2);
+		close(pipefd[1]);
+		execl(HDN_EVENT_DECODE_EXEC, "hdn-event-decode",
+		      "--input", input, NULL);
+		fprintf(stderr, "event decoder exec failed: %s\n",
+			strerror(errno));
+		_exit(2);
+	}
+
+	close(pipefd[1]);
+	ret = event_decoder_read_output(pipefd[0], buf, size);
+	close(pipefd[0]);
+
+	if (waitpid(child, &status, 0) < 0)
+		return -errno;
+	if (ret)
+		return ret;
+	if (!WIFEXITED(status))
+		return 2;
+	return WEXITSTATUS(status);
+}
