+static int directory_entry_count(const char *path, unsigned int *count)
+{
+	struct dirent *de;
+	DIR *dir;
+
+	dir = opendir(path);
+	if (!dir)
+		return -errno;
+
+	*count = 0;
+	while ((de = readdir(dir))) {
+		if (!strcmp(de->d_name, ".") || !strcmp(de->d_name, ".."))
+			continue;
+		(*count)++;
+	}
+
+	closedir(dir);
+	return 0;
+}
