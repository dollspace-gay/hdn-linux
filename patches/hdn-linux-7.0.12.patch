+static int process_fd_target_child(int sync_fd)
+{
+	int fd;
+
+	fd = open("/dev/null", O_RDONLY | O_CLOEXEC);
+	if (fd < 0)
+		return 2;
+
+	if (write(sync_fd, &fd, sizeof(fd)) != sizeof(fd))
+		return 2;
+	close(sync_fd);
+
+	for (;;)
+		pause();
+}
+
+static pid_t spawn_process_fd_target(bool nobody, int *remote_fd)
+{
+	int sync_pipe[2];
+	pid_t child;
+
+	if (pipe(sync_pipe))
+		return -1;
+
+	child = fork();
+	if (child < 0) {
+		close(sync_pipe[0]);
+		close(sync_pipe[1]);
+		return -1;
+	}
+
+	if (!child) {
+		close(sync_pipe[0]);
+		if (nobody &&
+		    (setgid(HDN_TEST_NOBODY) || setuid(HDN_TEST_NOBODY)))
+			_exit(2);
+		_exit(process_fd_target_child(sync_pipe[1]));
+	}
+
+	close(sync_pipe[1]);
+	if (read(sync_pipe[0], remote_fd, sizeof(*remote_fd)) !=
+	    sizeof(*remote_fd)) {
+		close(sync_pipe[0]);
+		kill(child, SIGKILL);
+		waitpid(child, NULL, 0);
+		return -1;
+	}
+	close(sync_pipe[0]);
+
+	return child;
+}
