+static int forked_child_result(int (*fn)(void))
+{
+	int status;
+	pid_t child;
+
+	child = fork();
+	if (child < 0)
+		return 2;
+
+	if (!child)
+		_exit(fn());
+
+	if (waitpid(child, &status, 0) < 0)
+		return 2;
+	if (!WIFEXITED(status))
+		return 2;
+
+	return WEXITSTATUS(status);
+}
