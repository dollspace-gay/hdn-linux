+static int read_whole_file(const char *path, unsigned char **buf,
+			   size_t *size)
+{
+	struct stat st;
+	unsigned char *data;
+	size_t offset = 0;
+	int fd;
+	int ret = 0;
+
+	fd = open(path, O_RDONLY | O_CLOEXEC);
+	if (fd < 0)
+		return -errno;
+	if (fstat(fd, &st)) {
+		ret = -errno;
+		goto out_close;
+	}
+	if (st.st_size <= 0 || st.st_size > 2 * 1024 * 1024) {
+		ret = -EINVAL;
+		goto out_close;
+	}
+
+	data = malloc(st.st_size);
+	if (!data) {
+		ret = -ENOMEM;
+		goto out_close;
+	}
+
+	while (offset < (size_t)st.st_size) {
+		ssize_t len;
+
+		len = read(fd, data + offset, (size_t)st.st_size - offset);
+		if (len < 0) {
+			ret = -errno;
+			goto out_free;
+		}
+		if (!len) {
+			ret = -EIO;
+			goto out_free;
+		}
+		offset += len;
+	}
+
+	*buf = data;
+	*size = offset;
+	goto out_close;
+
+out_free:
+	free(data);
+out_close:
+	close(fd);
+	return ret;
+}
+
+static int write_blob_file(const char *path, const unsigned char *buf,
+			   size_t size)
+{
+	int fd;
+	ssize_t len;
+	int ret = 0;
+
+	fd = open(path, O_WRONLY | O_CLOEXEC);
+	if (fd < 0)
+		return -errno;
+
+	len = write(fd, buf, size);
+	if (len < 0)
+		ret = -errno;
+	else if ((size_t)len != size)
+		ret = -EIO;
+
+	close(fd);
+	return ret;
+}
