+		       event_count_increased("reason=50", before) ? 0 : 1;
+	}
+
+	if (addr != MAP_FAILED)
+		return 1;
+	if (!errno_is_denial(saved_errno))
+		return 2;
+	return !require_event || event_count_increased("reason=50", before) ?
+	       0 : 1;
