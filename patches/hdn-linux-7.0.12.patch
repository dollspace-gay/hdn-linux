+static u64 hdn_profile_flags(u64 profile_id)
+{
+	const struct hdn_profile_record *profile;
+	u64 flags;
+
+	rcu_read_lock();
+	profile = hdn_profile_by_id(profile_id);
+	flags = profile->flags;
