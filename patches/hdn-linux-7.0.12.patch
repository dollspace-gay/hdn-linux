+static int write_all_fd(int fd, const void *buf, size_t size)
+{
+	const unsigned char *pos = buf;
+
+	while (size) {
+		ssize_t len = write(fd, pos, size);
+
+		if (len < 0)
+			return -errno;
+		if (!len)
+			return -EIO;
+
+		pos += len;
+		size -= len;
+	}
+
+	return 0;
+}
