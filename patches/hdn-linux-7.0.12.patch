+static int pidfd_info_received_result(bool expect_allowed)
+{
+	int saved_errno = 0;
+	int sv[2];
+	int status;
+	int pidfd;
+	pid_t reader;
+	pid_t target;
+
+	target = spawn_nobody_ptrace_target();
+	if (target < 0)
+		return 2;
+
+	pidfd = syscall(__NR_pidfd_open, target, 0);
+	if (pidfd < 0) {
+		saved_errno = errno;
+		kill(target, SIGKILL);
+		waitpid(target, NULL, 0);
+		return saved_errno == ENOSYS ? KSFT_SKIP : 2;
+	}
+
+	if (socketpair(AF_UNIX, SOCK_STREAM | SOCK_CLOEXEC, 0, sv)) {
+		close(pidfd);
+		kill(target, SIGKILL);
+		waitpid(target, NULL, 0);
+		return 2;
+	}
+
+	reader = fork();
+	if (reader < 0) {
+		close(sv[0]);
+		close(sv[1]);
+		close(pidfd);
+		kill(target, SIGKILL);
+		waitpid(target, NULL, 0);
+		return 2;
+	}
+
+	if (!reader) {
+		struct hdn_pidfd_info info = {
+			.mask = PIDFD_INFO_SUPPORTED_MASK,
+		};
+		int fd;
+		int ret;
+
+		close(sv[0]);
+		close(pidfd);
+		fd = recv_fd_over_socket(sv[1]);
+		close(sv[1]);
+		if (fd < 0)
+			_exit(2);
+
+		errno = 0;
+		ret = ioctl(fd, PIDFD_GET_INFO, &info);
+		if (ret)
+			saved_errno = errno;
+		close(fd);
+
+		if (expect_allowed)
+			_exit(!ret ? 0 :
+			      saved_errno == ENOTTY ? KSFT_SKIP : 1);
+		_exit(!ret ? 1 :
+		      saved_errno == ENOTTY ? KSFT_SKIP :
+		      errno_is_denial(saved_errno) ? 0 : 2);
+	}
+
+	close(sv[1]);
+	if (send_fd_over_socket(sv[0], pidfd)) {
+		close(sv[0]);
+		close(pidfd);
+		kill(reader, SIGKILL);
+		waitpid(reader, NULL, 0);
+		kill(target, SIGKILL);
+		waitpid(target, NULL, 0);
+		return 2;
+	}
+	close(sv[0]);
+	close(pidfd);
+
+	if (waitpid(reader, &status, 0) < 0) {
+		kill(target, SIGKILL);
+		waitpid(target, NULL, 0);
+		return 2;
+	}
+
+	kill(target, SIGKILL);
+	waitpid(target, NULL, 0);
+
+	if (!WIFEXITED(status))
+		return 2;
+	return WEXITSTATUS(status);
+}
