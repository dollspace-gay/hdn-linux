+static int hdn_authorize_object_dentry_flag(const struct dentry *dentry,
+					    u64 deny_flag,
+					    enum hdn_authority authority,
+					    enum hdn_transition transition,
+					    bool require_dir)
+{
+	struct inode *inode;
+
+	if (!dentry)
+		return 0;
+
+	inode = d_inode(dentry);
+	if (!inode)
+		return 0;
+
+	if (require_dir && !S_ISDIR(inode->i_mode))
+		return 0;
+
+	if (!hdn_object_dentry_access_denied((struct dentry *)dentry,
+					     hdn_current_profile_id(),
+					     deny_flag))
+		return 0;
+
+	return hdn_deny_object(authority, transition, HDN_REASON_OBJECT_POLICY,
+			       -EACCES,
+			       hdn_inode_object_id(inode));
+}
