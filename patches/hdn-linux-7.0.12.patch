+	snprintf(proc_path, sizeof(proc_path), "proc/%ld", (long)child);
+	errno = 0;
+	ret = fstatat(rootfd, proc_path, &st, AT_SYMLINK_NOFOLLOW);
+	saved_errno = errno;
+	close(rootfd);
+	if (release_chroot_outside_target(child, release_fd))
+		return 2;
+	if (!ret)
