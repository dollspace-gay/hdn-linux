+			"hdn-desktop-action: action is not product-approved: %s\n",
+			action);
+		free_config(&config);
+		return 1;
+	}
+
+	ret = run_prompt_portal(config.portal_helper, rule->portal_action);
+	free_config(&config);
+	return ret ? 1 : 0;
+}
