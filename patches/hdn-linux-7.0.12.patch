+static int sysfs_owner_only_readdir_hidden(void)
+{
+	char path[PATH_MAX];
+	char dir[PATH_MAX];
+	char name[NAME_MAX + 1];
+	const char *slash;
+	struct dirent *entry;
+	size_t dir_len;
