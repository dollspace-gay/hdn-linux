+static bool hdn_fcntl_cmd_controls_file(unsigned int cmd)
+{
+	switch (cmd) {
+	case F_DUPFD:
+	case F_DUPFD_CLOEXEC:
+	case F_SETFD:
+	case F_SETFL:
+	case F_SETLK:
+	case F_SETLKW:
+#ifdef F_SETLK64
+#if F_SETLK64 != F_SETLK
+	case F_SETLK64:
+#endif
+#endif
+#ifdef F_SETLKW64
+#if F_SETLKW64 != F_SETLKW
+	case F_SETLKW64:
+#endif
+#endif
+	case F_SETOWN:
+	case F_SETOWN_EX:
+	case F_SETSIG:
+	case F_SETLEASE:
+	case F_NOTIFY:
+	case F_SETPIPE_SZ:
+	case F_ADD_SEALS:
+	case F_SET_RW_HINT:
+	case F_SETDELEG:
+	case F_OFD_SETLK:
+	case F_OFD_SETLKW:
+		return true;
+	default:
+		return false;
+	}
+}
