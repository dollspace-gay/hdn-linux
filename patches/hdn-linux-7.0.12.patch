+	if (hdn_profile_allows(HDN_AUTH_PROC_DISCLOSE, HDN_TRANS_PROCFS_READ))
+		return true;
+	if (hdn_profile_allows(HDN_AUTH_PROC_TASK_VIEW, HDN_TRANS_PROCFS_READ))
