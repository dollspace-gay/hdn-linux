+	errno = 0;
+	fd = open(path, O_RDONLY | O_CLOEXEC);
+	if (fd >= 0) {
+		close(fd);
+		kill(child, SIGKILL);
+		waitpid(child, NULL, 0);
+		return 1;
+	}
+	saved_errno = errno;
+	if (saved_errno != ENOENT && !errno_is_denial(saved_errno)) {
+		kill(child, SIGKILL);
+		waitpid(child, NULL, 0);
+		return 2;
+	}
+
+	errno = 0;
+	dir = opendir("/proc");
+	if (!dir) {
+		kill(child, SIGKILL);
+		waitpid(child, NULL, 0);
+		return 2;
+	}
+	while ((de = readdir(dir))) {
+		if (!strcmp(de->d_name, pid_name)) {
+			found = true;
+			break;
+		}
+	}
+	saved_errno = errno;
+	closedir(dir);
+
+	kill(child, SIGKILL);
+	waitpid(child, NULL, 0);
+	if (saved_errno)
+		return 2;
+
+	return found ? 1 : 0;
+}
