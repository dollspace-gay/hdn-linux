+static int tty_tiocsti_denied(void)
+{
+	pid_t child;
+	int ret;
+
+	child = fork();
+	if (child < 0)
+		return 2;
+
+	if (!child) {
+		char ch = 'x';
+		int fd;
+
+		fd = tty_controlling_fd();
+		if (fd < 0)
+			_exit(errno == ENOTTY || errno == ENOENT ?
+			      KSFT_SKIP : 2);
+		if (setgid(HDN_TEST_NOBODY) || setuid(HDN_TEST_NOBODY))
+			_exit(2);
+		errno = 0;
+		ret = ioctl(fd, TIOCSTI, &ch);
+		close(fd);
+		if (!ret)
