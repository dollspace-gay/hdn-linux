+static int attach_execute_only_target(pid_t child)
+{
+	int status;
+
+	if (ptrace(PTRACE_ATTACH, child, NULL, NULL))
+		return -errno;
+	if (waitpid(child, &status, WUNTRACED) < 0)
+		return -errno;
+	if (!WIFSTOPPED(status))
+		return -ESRCH;
+
+	return 0;
+}
