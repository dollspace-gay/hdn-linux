+	{ SOCK_DGRAM, "SOCK_DGRAM" },
+	{ SOCK_RAW, "SOCK_RAW" },
+	{ SOCK_RDM, "SOCK_RDM" },
+	{ SOCK_SEQPACKET, "SOCK_SEQPACKET" },
+};
+
+static const char *lookup_name(const struct hdn_name *names, size_t count,
+			       unsigned int value)
+{
+	size_t i;
+
+	for (i = 0; i < count; i++) {
+		if (names[i].value == value)
+			return names[i].name;
+	}
+
+	return "UNKNOWN";
+}
+
+static int lookup_value(const struct hdn_name *names, size_t count,
+			const char *name, unsigned int *value)
+{
+	size_t i;
+
+	for (i = 0; i < count; i++) {
+		if (!strcasecmp(names[i].name, name)) {
+			*value = names[i].value;
+			return 0;
+		}
+	}
+
+	return -ENOENT;
+}
+
+static int parse_u64(const char *text, unsigned long long *value)
+{
+	char *end;
+
+	errno = 0;
+	*value = strtoull(text, &end, 0);
+	if (errno || end == text || *end)
+		return -EINVAL;
+	return 0;
+}
+
+static int parse_s32(const char *text, int *value)
+{
+	char *end;
+	long parsed;
+
+	errno = 0;
+	parsed = strtol(text, &end, 0);
+	if (errno || end == text || *end)
+		return -EINVAL;
+	*value = (int)parsed;
+	return 0;
+}
+
+static int parse_event_line(char *line, struct hdn_decoded_event *event)
+{
+	char *save = NULL;
+	char *word;
+
+	memset(event, 0, sizeof(*event));
+
+	for (word = strtok_r(line, " \t\r\n", &save); word;
+	     word = strtok_r(NULL, " \t\r\n", &save)) {
+		char *value = strchr(word, '=');
+		unsigned long long parsed;
+		int parsed_s32;
+
+		if (!value)
+			continue;
+		*value++ = '\0';
+
+		if (!strcmp(word, "sequence")) {
+			if (parse_u64(value, &event->sequence))
+				return -EINVAL;
+		} else if (!strcmp(word, "timestamp_ns")) {
+			if (parse_u64(value, &event->timestamp_ns))
+				return -EINVAL;
+		} else if (!strcmp(word, "event_id")) {
+			if (parse_u64(value, &parsed))
+				return -EINVAL;
+			event->event_id = (unsigned int)parsed;
+		} else if (!strcmp(word, "pid")) {
+			if (parse_u64(value, &parsed))
+				return -EINVAL;
+			event->pid = (unsigned int)parsed;
+		} else if (!strcmp(word, "uid")) {
+			if (parse_u64(value, &parsed))
+				return -EINVAL;
+			event->uid = (unsigned int)parsed;
+		} else if (!strcmp(word, "profile")) {
+			if (parse_u64(value, &event->profile))
+				return -EINVAL;
+		} else if (!strcmp(word, "authority")) {
+			if (parse_u64(value, &parsed))
+				return -EINVAL;
+			event->authority = (unsigned int)parsed;
+		} else if (!strcmp(word, "transition")) {
+			if (parse_u64(value, &parsed))
+				return -EINVAL;
+			event->transition = (unsigned int)parsed;
+		} else if (!strcmp(word, "action")) {
+			if (parse_u64(value, &parsed))
+				return -EINVAL;
+			event->action = (unsigned int)parsed;
+		} else if (!strcmp(word, "reason")) {
+			if (parse_u64(value, &parsed))
+				return -EINVAL;
+			event->reason = (unsigned int)parsed;
+		} else if (!strcmp(word, "error")) {
+			if (parse_s32(value, &parsed_s32))
+				return -EINVAL;
+			event->error = parsed_s32;
+		} else if (!strcmp(word, "subject")) {
+			if (parse_u64(value, &event->subject))
+				return -EINVAL;
+		} else if (!strcmp(word, "object")) {
+			if (parse_u64(value, &event->object))
+				return -EINVAL;
+		} else if (!strcmp(word, "flags")) {
+			if (parse_u64(value, &event->flags))
+				return -EINVAL;
+		}
+	}
+
+	return 0;
+}
+
+static unsigned int event_field(const struct hdn_decoded_event *event,
+				enum hdn_decode_field field)
+{
+	switch (field) {
+	case HDN_FIELD_EVENT:
+		return event->event_id;
+	case HDN_FIELD_ACTION:
+		return event->action;
+	case HDN_FIELD_AUTHORITY:
+		return event->authority;
+	case HDN_FIELD_TRANSITION:
+		return event->transition;
+	case HDN_FIELD_REASON:
+		return event->reason;
+	}
+
+	return 0;
+}
+
+static int parse_field(const char *name, enum hdn_decode_field *field)
+{
+	if (!strcasecmp(name, "event") || !strcasecmp(name, "event_id")) {
+		*field = HDN_FIELD_EVENT;
+		return 0;
+	}
+	if (!strcasecmp(name, "action")) {
+		*field = HDN_FIELD_ACTION;
+		return 0;
+	}
+	if (!strcasecmp(name, "authority")) {
+		*field = HDN_FIELD_AUTHORITY;
+		return 0;
+	}
+	if (!strcasecmp(name, "transition")) {
+		*field = HDN_FIELD_TRANSITION;
+		return 0;
+	}
+	if (!strcasecmp(name, "reason")) {
+		*field = HDN_FIELD_REASON;
+		return 0;
+	}
+
+	return -EINVAL;
+}
+
+static const struct hdn_name *map_for_field(enum hdn_decode_field field,
+					    size_t *count)
+{
+	switch (field) {
+	case HDN_FIELD_EVENT:
+	case HDN_FIELD_TRANSITION:
+		*count = sizeof(transition_names) / sizeof(transition_names[0]);
+		return transition_names;
+	case HDN_FIELD_ACTION:
+		*count = sizeof(action_names) / sizeof(action_names[0]);
+		return action_names;
+	case HDN_FIELD_AUTHORITY:
+		*count = sizeof(authority_names) / sizeof(authority_names[0]);
+		return authority_names;
+	case HDN_FIELD_REASON:
+		*count = sizeof(reason_names) / sizeof(reason_names[0]);
+		return reason_names;
+	}
+
+	*count = 0;
+	return NULL;
+}
+
+static int parse_expectation(const char *text, struct hdn_expectation *expect)
+{
+	char *copy;
+	char *value;
+	size_t count;
+	const struct hdn_name *names;
+	unsigned long long parsed;
+	int ret;
+
+	copy = strdup(text);
+	if (!copy)
+		return -ENOMEM;
+
+	value = strchr(copy, '=');
+	if (!value) {
+		free(copy);
+		return -EINVAL;
+	}
+	*value++ = '\0';
+
+	ret = parse_field(copy, &expect->field);
+	if (ret) {
+		free(copy);
+		return ret;
+	}
+
+	if (!parse_u64(value, &parsed)) {
+		expect->value = (unsigned int)parsed;
+		free(copy);
+		return 0;
+	}
+
+	names = map_for_field(expect->field, &count);
+	ret = lookup_value(names, count, value, &expect->value);
+	free(copy);
+	return ret;
+}
+
+static bool event_matches(const struct hdn_decoded_event *event,
+			  const struct hdn_expectation *expectations,
+			  unsigned int expectation_count)
+{
+	unsigned int i;
+
+	for (i = 0; i < expectation_count; i++) {
+		if (event_field(event, expectations[i].field) !=
+		    expectations[i].value)
+			return false;
+	}
+
+	return true;
+}
+
+static void print_flag_names(unsigned long long flags)
+{
+	bool first = true;
+
+	if (flags & HDN_EVENT_RESPONSE_KILL_TASK) {
+		printf("%sRESPONSE_KILL_TASK", first ? "" : ",");
+		first = false;
+	}
+	if (flags & HDN_EVENT_CHROOTED) {
+		printf("%sCHROOTED", first ? "" : ",");
+		first = false;
+	}
+	if (first)
+		printf("none");
+}
+
+static void print_resource_detail(unsigned long long object)
+{
+	unsigned int resource = object >> 56;
+	unsigned long long wanted =
+		object & ((1ULL << 56) - 1);
+	bool packed_pressure = resource != 0;
+
+	if (!packed_pressure)
+		resource = (unsigned int)object;
+
+	printf(" object_detail=resource resource_id=%u resource=%s",
+	       resource,
+	       lookup_name(resource_names,
+			   sizeof(resource_names) / sizeof(resource_names[0]),
+			   resource));
+	if (packed_pressure)
+		printf(" resource_wanted=%llu", wanted);
+}
+
+static void print_signal_detail(unsigned long long object)
+{
+	unsigned int sig = object >> 56;
+	unsigned long long addr = object & ((1ULL << 56) - 1);
+
+	printf(" object_detail=signal signal_id=%u signal=%s fault_addr_low=0x%llx",
+	       sig,
+	       lookup_name(signal_names,
+			   sizeof(signal_names) / sizeof(signal_names[0]),
+			   sig),
+	       addr);
+}
+
+static void print_signal_number_detail(unsigned int sig)
+{
+	printf(" object_detail=signal signal_id=%u signal=%s",
+	       sig,
+	       lookup_name(signal_names,
+			   sizeof(signal_names) / sizeof(signal_names[0]),
+			   sig));
+}
+
+static void print_socket_create_detail(unsigned long long object)
+{
+	unsigned int family = object >> 32;
+	unsigned int type = (object >> 16) & 0xffff;
+	unsigned int protocol = object & 0xffff;
+
+	printf(" object_detail=socket socket_family_id=%u socket_family=%s socket_type_id=%u socket_type=%s socket_protocol=%u",
+	       family,
+	       lookup_name(socket_family_names,
+			   sizeof(socket_family_names) /
+			   sizeof(socket_family_names[0]), family),
+	       type,
+	       lookup_name(socket_type_names,
+			   sizeof(socket_type_names) /
+			   sizeof(socket_type_names[0]), type),
+	       protocol);
+}
+
+static void print_ipv4_endpoint(unsigned long long object)
+{
+	unsigned int type = (object >> 48) & 0xff;
+	unsigned int port = (object >> 32) & 0xffff;
+	unsigned int addr = object & 0xffffffff;
+	unsigned char octets[4];
+
+	octets[0] = (addr >> 24) & 0xff;
+	octets[1] = (addr >> 16) & 0xff;
+	octets[2] = (addr >> 8) & 0xff;
+	octets[3] = addr & 0xff;
+
+	printf(" object_detail=socket socket_family_id=%u socket_family=AF_INET socket_type_id=%u socket_type=%s socket_port=%u socket_address=%u.%u.%u.%u",
+	       AF_INET, type,
+	       lookup_name(socket_type_names,
+			   sizeof(socket_type_names) /
+			   sizeof(socket_type_names[0]), type),
+	       port, octets[0], octets[1], octets[2], octets[3]);
+}
+
+static void print_ipv6_endpoint(unsigned long long object)
+{
+	unsigned int type = (object >> 48) & 0xff;
+	unsigned int port = (object >> 32) & 0xffff;
+	unsigned int hash = object & 0xffffffff;
+
+	printf(" object_detail=socket socket_family_id=%u socket_family=AF_INET6 socket_type_id=%u socket_type=%s socket_port=%u socket_addr_hash=0x%x",
+	       AF_INET6, type,
+	       lookup_name(socket_type_names,
+			   sizeof(socket_type_names) /
+			   sizeof(socket_type_names[0]), type),
+	       port, hash);
+}
+
+static void print_socket_endpoint_detail(unsigned long long object)
+{
+	unsigned int family = object >> 56;
+
+	if (family == AF_INET) {
+		print_ipv4_endpoint(object);
+		return;
+	}
+	if (family == AF_INET6) {
+		print_ipv6_endpoint(object);
+		return;
+	}
+
+	print_socket_create_detail(object);
+}
+
+static void print_object_detail(const struct hdn_decoded_event *event)
+{
+	switch (event->transition) {
+	case HDN_TRANS_EXEC_ARGS:
+		printf(" object_detail=exec_args argc=%u envc=%u",
+		       (unsigned int)(event->object >> 32),
+		       (unsigned int)(event->object & 0xffffffff));
+		break;
+	case HDN_TRANS_FORK:
+		if (event->object)
+			printf(" object_detail=process related_pid=%llu",
+			       event->object);
+		break;
+	case HDN_TRANS_PROCESS_ACCOUNT:
+		printf(" object_detail=process exit_code=%u",
+		       (unsigned int)event->object);
+		break;
+	case HDN_TRANS_SIGNAL:
+		print_signal_detail(event->object);
+		break;
+	case HDN_TRANS_COREDUMP:
+		print_signal_number_detail((unsigned int)event->object);
+		break;
+	case HDN_TRANS_TIME_CHANGE:
+		printf(" object_detail=time time_operation_id=%u time_operation=%s",
+		       (unsigned int)event->object,
+		       lookup_name(time_operation_names,
+				   sizeof(time_operation_names) /
+				   sizeof(time_operation_names[0]),
+				   (unsigned int)event->object));
+		break;
+	case HDN_TRANS_RESOURCE_LIMIT:
+		print_resource_detail(event->object);
+		break;
+	case HDN_TRANS_USB_ATTACH:
+		printf(" object_detail=usb usb_bus=%u usb_port=%u",
+		       (unsigned int)(event->object >> 32),
+		       (unsigned int)(event->object & 0xffffffff));
+		break;
+	case HDN_TRANS_USB_MONITOR:
+		printf(" object_detail=usb usb_bus=%llu", event->object);
+		break;
+	case HDN_TRANS_SOCKET_CREATE:
+		print_socket_create_detail(event->object);
+		break;
+	case HDN_TRANS_SOCKET_CONNECT:
+	case HDN_TRANS_SOCKET_SERVER:
+		print_socket_endpoint_detail(event->object);
+		break;
+	default:
+		break;
+	}
+}
+
+static void print_event(const struct hdn_decoded_event *event)
+{
+	printf("sequence=%llu timestamp_ns=%llu pid=%u uid=%u profile=%llu ",
+	       event->sequence, event->timestamp_ns, event->pid, event->uid,
+	       event->profile);
+	printf("event_id=%u event=%s authority_id=%u authority=%s ",
+	       event->event_id,
+	       lookup_name(transition_names,
+			   sizeof(transition_names) / sizeof(transition_names[0]),
+			   event->event_id),
+	       event->authority,
+	       lookup_name(authority_names,
+			   sizeof(authority_names) / sizeof(authority_names[0]),
+			   event->authority));
+	printf("transition_id=%u transition=%s action_id=%u action=%s ",
+	       event->transition,
+	       lookup_name(transition_names,
+			   sizeof(transition_names) / sizeof(transition_names[0]),
+			   event->transition),
+	       event->action,
+	       lookup_name(action_names,
+			   sizeof(action_names) / sizeof(action_names[0]),
+			   event->action));
+	printf("reason_id=%u reason=%s error=%d subject=%llu object=%llu flags=0x%llx flag_names=",
+	       event->reason,
+	       lookup_name(reason_names,
+			   sizeof(reason_names) / sizeof(reason_names[0]),
+			   event->reason),
+	       event->error, event->subject, event->object, event->flags);
+	print_flag_names(event->flags);
+	print_object_detail(event);
+	printf("\n");
+}
+
+static void usage(const char *prog)
+{
+	fprintf(stderr,
+		"Usage: %s [--input PATH] [--quiet] [--expect FIELD=VALUE]...\n"
+		"\n"
+		"Decodes securityfs hardening event records to stable UAPI names.\n"
+		"Fields for --expect: event, action, authority, transition, reason.\n",
+		prog);
+}
+
+int main(int argc, char **argv)
+{
+	const char *input = HDN_EVENTS_PATH;
+	struct hdn_expectation expectations[HDN_MAX_EXPECTATIONS];
+	unsigned int expectation_count = 0;
+	bool quiet = false;
+	bool found = false;
+	char *line = NULL;
+	size_t size = 0;
+	ssize_t len;
+	FILE *file;
+	int i;
+
+	for (i = 1; i < argc; i++) {
+		if (!strcmp(argv[i], "--help")) {
+			usage(argv[0]);
+			return 0;
+		}
+		if (!strcmp(argv[i], "--input")) {
+			if (++i >= argc)
+				goto bad_args;
+			input = argv[i];
+			continue;
+		}
+		if (!strcmp(argv[i], "--quiet")) {
+			quiet = true;
+			continue;
+		}
+		if (!strcmp(argv[i], "--expect")) {
+			if (++i >= argc ||
+			    expectation_count >= HDN_MAX_EXPECTATIONS)
+				goto bad_args;
+			if (parse_expectation(argv[i],
+					      &expectations[expectation_count]))
+				goto bad_args;
+			expectation_count++;
+			continue;
+		}
+		goto bad_args;
+	}
+
+	file = fopen(input, "r");
+	if (!file) {
+		fprintf(stderr, "hdn-event-decode: cannot open %s: %s\n",
+			input, strerror(errno));
+		return 2;
+	}
+
+	while ((len = getline(&line, &size, file)) >= 0) {
+		struct hdn_decoded_event event;
+
+		(void)len;
+		if (parse_event_line(line, &event)) {
+			free(line);
+			fclose(file);
+			fprintf(stderr,
+				"hdn-event-decode: malformed event line\n");
+			return 2;
+		}
+		if (expectation_count &&
+		    event_matches(&event, expectations, expectation_count))
+			found = true;
+		if (!quiet)
+			print_event(&event);
+	}
+
+	free(line);
+	if (ferror(file)) {
+		fclose(file);
+		return 2;
+	}
+	fclose(file);
+
+	if (expectation_count)
+		return found ? 0 : 1;
+	return 0;
+
+bad_args:
+	usage(argv[0]);
+	return 2;
+}
diff -urN linux-7.0.12/tools/hardening/hdn-image-seal.c linux-7.0.12-hdn/tools/hardening/hdn-image-seal.c
--- linux-7.0.12/tools/hardening/hdn-image-seal.c	1969-12-31 18:00:00.000000000 -0600
+++ linux-7.0.12-hdn/tools/hardening/hdn-image-seal.c	2026-06-25 15:18:48.557280910 -0500
@@ -0,0 +1,417 @@
+// SPDX-License-Identifier: GPL-2.0-only
+
+#define _GNU_SOURCE
+
+#include <errno.h>
+#include <fcntl.h>
+#include <stdbool.h>
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+#include <sys/stat.h>
+#include <sys/wait.h>
+#include <unistd.h>
+
+#ifndef HDN_IMAGE_SEAL_CONFIG
+#define HDN_IMAGE_SEAL_CONFIG "/etc/hdn/image-seals.conf"
+#endif
+
+#ifndef HDN_ADMIN_BROKER_PATH
+#define HDN_ADMIN_BROKER_PATH "/usr/libexec/hdn-admin-broker"
+#endif
+
+#define HDN_IMAGE_SEAL_MAX_STEPS 64
+
+enum hdn_image_seal_op {
+	HDN_IMAGE_SEAL_POLICY_COMMIT,
+	HDN_IMAGE_SEAL_ROFS_APPLY,
+};
+
+struct hdn_image_seal_step {
+	char *name;
+	enum hdn_image_seal_op op;
+	char *argument;
+};
+
+struct hdn_image_seal_config {
+	struct hdn_image_seal_step steps[HDN_IMAGE_SEAL_MAX_STEPS];
+	unsigned int count;
+};
+
+static void usage(const char *prog)
+{
+	fprintf(stderr,
+		"Usage: %s [--config FILE] [--broker PATH] SEAL_NAME\n"
+		"\n"
+		"Runs a product-approved image sealing sequence through hdn-admin-broker.\n"
+		"Config lines:\n"
+		"  seal NAME policy-commit SIGNED_POLICY\n"
+		"  seal NAME rofs-apply READONLY_LIST\n",
+		prog);
+}
+
+static char *trim(char *line)
+{
+	char *end;
+
+	while (*line == ' ' || *line == '\t' || *line == '\r' ||
+	       *line == '\n')
+		line++;
+
+	end = line + strlen(line);
+	while (end > line &&
+	       (end[-1] == ' ' || end[-1] == '\t' || end[-1] == '\r' ||
+		end[-1] == '\n'))
+		*--end = '\0';
+
+	return line;
+}
+
+static bool safe_name(const char *name)
+{
+	const char *p;
+
+	if (!name || !name[0] || !strcmp(name, ".") || !strcmp(name, ".."))
+		return false;
+
+	for (p = name; *p; p++) {
+		if ((*p >= 'A' && *p <= 'Z') ||
+		    (*p >= 'a' && *p <= 'z') ||
+		    (*p >= '0' && *p <= '9') ||
+		    *p == '.' || *p == '_' || *p == '-')
+			continue;
+		return false;
+	}
+
+	return true;
+}
+
+static bool path_has_dot_component(const char *path)
+{
+	const char *part = path;
+
+	while (*part) {
+		const char *slash;
+		size_t len;
+
+		while (*part == '/')
+			part++;
+		if (!*part)
+			break;
+
+		slash = strchr(part, '/');
+		len = slash ? (size_t)(slash - part) : strlen(part);
+		if ((len == 1 && part[0] == '.') ||
+		    (len == 2 && part[0] == '.' && part[1] == '.'))
+			return true;
+		part += len;
+	}
+
+	return false;
+}
+
+static int require_safe_absolute(const char *what, const char *path)
+{
+	if (!path || path[0] != '/') {
+		fprintf(stderr, "hdn-image-seal: %s must be absolute: %s\n",
+			what, path ? path : "(null)");
+		return -EINVAL;
+	}
+	if (path_has_dot_component(path)) {
+		fprintf(stderr,
+			"hdn-image-seal: %s must not contain . or .. path components: %s\n",
+			what, path);
+		return -EINVAL;
+	}
+
+	return 0;
+}
+
+static int add_step(struct hdn_image_seal_config *config, char **tokens,
+		    unsigned int count, unsigned int lineno)
+{
+	struct hdn_image_seal_step *step;
+	enum hdn_image_seal_op op;
+
+	if (count != 4) {
+		fprintf(stderr,
+			"hdn-image-seal: seal line %u needs NAME OP ARGUMENT\n",
+			lineno);
+		return -EINVAL;
+	}
+	if (config->count >= HDN_IMAGE_SEAL_MAX_STEPS) {
+		fprintf(stderr, "hdn-image-seal: too many seal steps\n");
+		return -E2BIG;
+	}
+	if (!safe_name(tokens[1])) {
+		fprintf(stderr,
+			"hdn-image-seal: unsafe seal name at line %u: %s\n",
+			lineno, tokens[1]);
+		return -EINVAL;
+	}
+	if (!strcmp(tokens[2], "policy-commit"))
+		op = HDN_IMAGE_SEAL_POLICY_COMMIT;
+	else if (!strcmp(tokens[2], "rofs-apply"))
+		op = HDN_IMAGE_SEAL_ROFS_APPLY;
+	else {
+		fprintf(stderr,
+			"hdn-image-seal: unknown seal operation at line %u: %s\n",
+			lineno, tokens[2]);
+		return -EINVAL;
+	}
+	if (require_safe_absolute(tokens[2], tokens[3]))
+		return -EINVAL;
+
+	step = &config->steps[config->count];
+	step->name = strdup(tokens[1]);
+	step->argument = strdup(tokens[3]);
+	if (!step->name || !step->argument)
+		return -ENOMEM;
+	step->op = op;
+	config->count++;
+	return 0;
+}
+
+static int parse_config_line(struct hdn_image_seal_config *config, char *line,
+			     unsigned int lineno)
+{
+	char *tokens[4];
+	unsigned int count = 0;
+	char *save = NULL;
+	char *word;
+
+	line = trim(line);
+	if (!line[0] || line[0] == '#')
+		return 0;
+
+	for (word = strtok_r(line, " \t", &save); word;
+	     word = strtok_r(NULL, " \t", &save)) {
+		if (count >= sizeof(tokens) / sizeof(tokens[0])) {
+			fprintf(stderr,
+				"hdn-image-seal: too many fields at line %u\n",
+				lineno);
+			return -E2BIG;
+		}
+		tokens[count++] = word;
+	}
+
+	if (!count)
+		return 0;
+	if (strcmp(tokens[0], "seal")) {
+		fprintf(stderr,
+			"hdn-image-seal: unknown config key at line %u: %s\n",
+			lineno, tokens[0]);
+		return -EINVAL;
+	}
+
+	return add_step(config, tokens, count, lineno);
+}
+
+static int open_config(const char *path)
+{
+	struct stat st;
+	int flags = O_RDONLY | O_CLOEXEC;
+	int fd;
+
+#ifdef O_NOFOLLOW
+	flags |= O_NOFOLLOW;
+#endif
+
+	fd = open(path, flags);
+	if (fd < 0) {
+		fprintf(stderr, "hdn-image-seal: cannot open %s: %s\n",
+			path, strerror(errno));
+		return -errno;
+	}
+
+	if (fstat(fd, &st)) {
+		int ret = -errno;
+
+		fprintf(stderr, "hdn-image-seal: cannot stat %s: %s\n",
+			path, strerror(errno));
+		close(fd);
+		return ret;
+	}
+
+	if (!S_ISREG(st.st_mode) || st.st_uid != 0 || (st.st_mode & 022)) {
+		fprintf(stderr,
+			"hdn-image-seal: refusing unsafe config %s\n",
+			path);
+		close(fd);
+		return -EACCES;
+	}
+
+	return fd;
+}
+
+static int load_config(const char *path, struct hdn_image_seal_config *config)
+{
+	char *line = NULL;
+	size_t size = 0;
+	unsigned int lineno = 0;
+	ssize_t len;
+	FILE *file;
+	int ret = 0;
+	int fd;
+
+	memset(config, 0, sizeof(*config));
+
+	fd = open_config(path);
+	if (fd < 0)
+		return fd;
+
+	file = fdopen(fd, "r");
+	if (!file) {
+		ret = -errno;
+		close(fd);
+		return ret;
+	}
+
+	while ((len = getline(&line, &size, file)) >= 0) {
+		(void)len;
+		lineno++;
+		ret = parse_config_line(config, line, lineno);
+		if (ret)
+			break;
+	}
+	if (ferror(file) && !ret)
+		ret = -EIO;
+
+	free(line);
+	fclose(file);
+	return ret;
+}
+
+static void free_config(struct hdn_image_seal_config *config)
+{
+	unsigned int i;
+
+	for (i = 0; i < config->count; i++) {
+		free(config->steps[i].name);
+		free(config->steps[i].argument);
+	}
+}
+
+static int run_broker_step(const char *broker,
+			   const struct hdn_image_seal_step *step)
+{
+	char *const policy_argv[] = {
+		(char *)broker,
+		"policy-commit",
+		step->argument,
+		NULL,
+	};
+	char *const rofs_argv[] = {
+		(char *)broker,
+		"rofs-apply",
+		"-f",
+		step->argument,
+		NULL,
+	};
+	char *const *argv = step->op == HDN_IMAGE_SEAL_POLICY_COMMIT ?
+			    policy_argv : rofs_argv;
+	int status;
+	pid_t child;
+
+	child = fork();
+	if (child < 0) {
+		fprintf(stderr, "hdn-image-seal: fork failed: %s\n",
+			strerror(errno));
+		return 1;
+	}
+
+	if (!child) {
+		execv(broker, argv);
+		fprintf(stderr, "hdn-image-seal: exec %s failed: %s\n",
+			broker, strerror(errno));
+		_exit(errno == ENOENT ? 127 : 126);
+	}
+
+	if (waitpid(child, &status, 0) < 0) {
+		fprintf(stderr, "hdn-image-seal: wait failed: %s\n",
+			strerror(errno));
+		return 1;
+	}
+	if (!WIFEXITED(status))
+		return 1;
+	return WEXITSTATUS(status);
+}
+
+static int run_seal(const char *broker,
+		    const struct hdn_image_seal_config *config,
+		    const char *name)
+{
+	bool found = false;
+	unsigned int i;
+	int ret;
+
+	for (i = 0; i < config->count; i++) {
+		if (strcmp(config->steps[i].name, name))
+			continue;
+		found = true;
+		ret = run_broker_step(broker, &config->steps[i]);
+		if (ret)
+			return ret;
+	}
+
+	if (!found) {
+		fprintf(stderr,
+			"hdn-image-seal: seal is not product-approved: %s\n",
+			name);
+		return 1;
+	}
+
+	return 0;
+}
+
+int main(int argc, char **argv)
+{
+	const char *config_path = HDN_IMAGE_SEAL_CONFIG;
+	const char *broker_path = HDN_ADMIN_BROKER_PATH;
+	struct hdn_image_seal_config config;
+	const char *seal = NULL;
+	int ret;
+	int i;
+
+	for (i = 1; i < argc; i++) {
+		if (!strcmp(argv[i], "--help")) {
+			usage(argv[0]);
+			return 0;
+		}
+		if (!strcmp(argv[i], "--config")) {
+			if (++i >= argc)
+				goto bad_args;
+			config_path = argv[i];
+			continue;
+		}
+		if (!strcmp(argv[i], "--broker")) {
+			if (++i >= argc)
+				goto bad_args;
+			broker_path = argv[i];
+			continue;
+		}
+		if (argv[i][0] == '-')
+			goto bad_args;
+		if (seal)
+			goto bad_args;
+		seal = argv[i];
+	}
+
+	if (!seal || !safe_name(seal))
+		goto bad_args;
+	if (require_safe_absolute("config", config_path) ||
+	    require_safe_absolute("broker", broker_path))
+		return 1;
+
+	ret = load_config(config_path, &config);
+	if (ret)
+		return 1;
+
+	ret = run_seal(broker_path, &config, seal);
+	free_config(&config);
+	return ret;
+
+bad_args:
+	usage(argv[0]);
+	return 2;
+}
diff -urN linux-7.0.12/tools/hardening/hdn-package-hook.c linux-7.0.12-hdn/tools/hardening/hdn-package-hook.c
--- linux-7.0.12/tools/hardening/hdn-package-hook.c	1969-12-31 18:00:00.000000000 -0600
+++ linux-7.0.12-hdn/tools/hardening/hdn-package-hook.c	2026-06-25 15:50:47.741586264 -0500
@@ -0,0 +1,420 @@
+// SPDX-License-Identifier: GPL-2.0-only
+
+#define _GNU_SOURCE
+
+#include <errno.h>
+#include <fcntl.h>
+#include <stdbool.h>
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+#include <sys/stat.h>
+#include <sys/wait.h>
+#include <unistd.h>
+
+#ifndef HDN_PACKAGE_HOOK_CONFIG
+#define HDN_PACKAGE_HOOK_CONFIG "/etc/hdn/package-hooks.conf"
+#endif
+
+#ifndef HDN_SYSTEM_TRANSACTION_PATH
+#define HDN_SYSTEM_TRANSACTION_PATH "/usr/libexec/hdn-system-transaction"
+#endif
+
+#ifndef HDN_IMAGE_SEAL_PATH
+#define HDN_IMAGE_SEAL_PATH "/usr/libexec/hdn-image-seal"
+#endif
+
+#define HDN_PACKAGE_HOOK_MAX_RULES 64
+
+enum hdn_package_hook_backend {
+	HDN_PACKAGE_HOOK_SYSTEM_TRANSACTION,
+	HDN_PACKAGE_HOOK_IMAGE_SEAL,
+};
+
+struct hdn_package_hook_rule {
+	char *name;
+	enum hdn_package_hook_backend backend;
+	char *argument;
+};
+
+struct hdn_package_hook_config {
+	struct hdn_package_hook_rule rules[HDN_PACKAGE_HOOK_MAX_RULES];
+	unsigned int count;
+};
+
+static void usage(const char *prog)
+{
+	fprintf(stderr,
+		"Usage: %s [--config FILE] [--system-transaction PATH] [--image-seal PATH] HOOK\n"
+		"\n"
+		"Runs a product-approved package-manager hook.\n"
+		"Config lines:\n"
+		"  hook NAME system-transaction TRANSACTION\n"
+		"  hook NAME image-seal SEAL\n",
+		prog);
+}
+
+static char *trim(char *line)
+{
+	char *end;
+
+	while (*line == ' ' || *line == '\t' || *line == '\r' ||
+	       *line == '\n')
+		line++;
+
+	end = line + strlen(line);
+	while (end > line &&
+	       (end[-1] == ' ' || end[-1] == '\t' || end[-1] == '\r' ||
+		end[-1] == '\n'))
+		*--end = '\0';
+
+	return line;
+}
+
+static bool safe_name(const char *name)
+{
+	const char *p;
+
+	if (!name || !name[0] || !strcmp(name, ".") || !strcmp(name, ".."))
+		return false;
+
+	for (p = name; *p; p++) {
+		if ((*p >= 'A' && *p <= 'Z') ||
+		    (*p >= 'a' && *p <= 'z') ||
+		    (*p >= '0' && *p <= '9') ||
+		    *p == '.' || *p == '_' || *p == '-')
+			continue;
+		return false;
+	}
+
+	return true;
+}
+
+static bool path_has_dot_component(const char *path)
+{
+	const char *part = path;
+
+	while (*part) {
+		const char *slash;
+		size_t len;
+
+		while (*part == '/')
+			part++;
+		if (!*part)
+			break;
+
+		slash = strchr(part, '/');
+		len = slash ? (size_t)(slash - part) : strlen(part);
+		if ((len == 1 && part[0] == '.') ||
+		    (len == 2 && part[0] == '.' && part[1] == '.'))
+			return true;
+		part += len;
+	}
+
+	return false;
+}
+
+static int require_safe_absolute(const char *what, const char *path)
+{
+	if (!path || path[0] != '/') {
+		fprintf(stderr, "hdn-package-hook: %s must be absolute: %s\n",
+			what, path ? path : "(null)");
+		return -EINVAL;
+	}
+	if (path_has_dot_component(path)) {
+		fprintf(stderr,
+			"hdn-package-hook: %s must not contain . or .. path components: %s\n",
+			what, path);
+		return -EINVAL;
+	}
+
+	return 0;
+}
+
+static int add_rule(struct hdn_package_hook_config *config, char **tokens,
+		    unsigned int count, unsigned int lineno)
+{
+	struct hdn_package_hook_rule *rule;
+	enum hdn_package_hook_backend backend;
+
+	if (count != 4) {
+		fprintf(stderr,
+			"hdn-package-hook: hook line %u needs NAME BACKEND ARGUMENT\n",
+			lineno);
+		return -EINVAL;
+	}
+	if (config->count >= HDN_PACKAGE_HOOK_MAX_RULES) {
+		fprintf(stderr, "hdn-package-hook: too many hook rules\n");
+		return -E2BIG;
+	}
+	if (!safe_name(tokens[1])) {
+		fprintf(stderr,
+			"hdn-package-hook: unsafe hook name at line %u: %s\n",
+			lineno, tokens[1]);
+		return -EINVAL;
+	}
+	if (!safe_name(tokens[3])) {
+		fprintf(stderr,
+			"hdn-package-hook: unsafe backend argument at line %u: %s\n",
+			lineno, tokens[3]);
+		return -EINVAL;
+	}
+
+	if (!strcmp(tokens[2], "system-transaction"))
+		backend = HDN_PACKAGE_HOOK_SYSTEM_TRANSACTION;
+	else if (!strcmp(tokens[2], "image-seal"))
+		backend = HDN_PACKAGE_HOOK_IMAGE_SEAL;
+	else {
+		fprintf(stderr,
+			"hdn-package-hook: unknown hook backend at line %u: %s\n",
+			lineno, tokens[2]);
+		return -EINVAL;
+	}
+
+	rule = &config->rules[config->count];
+	rule->name = strdup(tokens[1]);
+	rule->argument = strdup(tokens[3]);
+	if (!rule->name || !rule->argument)
+		return -ENOMEM;
+	rule->backend = backend;
+	config->count++;
+	return 0;
+}
+
+static int parse_config_line(struct hdn_package_hook_config *config,
+			     char *line, unsigned int lineno)
+{
+	char *tokens[4];
+	unsigned int count = 0;
+	char *save = NULL;
+	char *word;
+
+	line = trim(line);
+	if (!line[0] || line[0] == '#')
+		return 0;
+
+	for (word = strtok_r(line, " \t", &save); word;
+	     word = strtok_r(NULL, " \t", &save)) {
+		if (count >= sizeof(tokens) / sizeof(tokens[0])) {
+			fprintf(stderr,
+				"hdn-package-hook: too many fields at line %u\n",
+				lineno);
+			return -E2BIG;
+		}
+		tokens[count++] = word;
+	}
+
+	if (!count)
+		return 0;
+	if (strcmp(tokens[0], "hook")) {
+		fprintf(stderr,
+			"hdn-package-hook: unknown config key at line %u: %s\n",
+			lineno, tokens[0]);
+		return -EINVAL;
+	}
+
+	return add_rule(config, tokens, count, lineno);
+}
+
+static int open_config(const char *path)
+{
+	struct stat st;
+	int flags = O_RDONLY | O_CLOEXEC;
+	int fd;
+
+#ifdef O_NOFOLLOW
+	flags |= O_NOFOLLOW;
+#endif
+
+	fd = open(path, flags);
+	if (fd < 0) {
+		fprintf(stderr, "hdn-package-hook: cannot open %s: %s\n",
+			path, strerror(errno));
+		return -errno;
+	}
+
+	if (fstat(fd, &st)) {
+		int ret = -errno;
+
+		fprintf(stderr, "hdn-package-hook: cannot stat %s: %s\n",
+			path, strerror(errno));
+		close(fd);
+		return ret;
+	}
+
+	if (!S_ISREG(st.st_mode) || st.st_uid != 0 || (st.st_mode & 022)) {
+		fprintf(stderr,
+			"hdn-package-hook: refusing unsafe config %s\n",
+			path);
+		close(fd);
+		return -EACCES;
+	}
+
+	return fd;
+}
+
+static int load_config(const char *path, struct hdn_package_hook_config *config)
+{
+	char *line = NULL;
+	size_t size = 0;
+	unsigned int lineno = 0;
+	ssize_t len;
+	FILE *file;
+	int ret = 0;
+	int fd;
+
+	memset(config, 0, sizeof(*config));
+
+	fd = open_config(path);
+	if (fd < 0)
+		return fd;
+
+	file = fdopen(fd, "r");
+	if (!file) {
+		ret = -errno;
+		close(fd);
+		return ret;
+	}
+
+	while ((len = getline(&line, &size, file)) >= 0) {
+		(void)len;
+		lineno++;
+		ret = parse_config_line(config, line, lineno);
+		if (ret)
+			break;
+	}
+	if (ferror(file) && !ret)
+		ret = -EIO;
+
+	free(line);
+	fclose(file);
+	return ret;
+}
+
+static void free_config(struct hdn_package_hook_config *config)
+{
+	unsigned int i;
+
+	for (i = 0; i < config->count; i++) {
+		free(config->rules[i].name);
+		free(config->rules[i].argument);
+	}
+}
+
+static const struct hdn_package_hook_rule *
+find_rule(const struct hdn_package_hook_config *config, const char *hook)
+{
+	unsigned int i;
+
+	for (i = 0; i < config->count; i++) {
+		if (!strcmp(config->rules[i].name, hook))
+			return &config->rules[i];
+	}
+
+	return NULL;
+}
+
+static int run_hook(const struct hdn_package_hook_rule *rule,
+		    const char *system_transaction, const char *image_seal)
+{
+	const char *path;
+	const char *argv0;
+	pid_t child;
+	int status;
+
+	if (rule->backend == HDN_PACKAGE_HOOK_SYSTEM_TRANSACTION) {
+		path = system_transaction;
+		argv0 = "hdn-system-transaction";
+	} else {
+		path = image_seal;
+		argv0 = "hdn-image-seal";
+	}
+
+	child = fork();
+	if (child < 0) {
+		fprintf(stderr, "hdn-package-hook: fork failed: %s\n",
+			strerror(errno));
+		return 1;
+	}
+
+	if (!child) {
+		execl(path, argv0, rule->argument, NULL);
+		fprintf(stderr, "hdn-package-hook: exec %s failed: %s\n",
+			path, strerror(errno));
+		_exit(errno == ENOENT ? 127 : 126);
+	}
+
+	if (waitpid(child, &status, 0) < 0)
+		return 1;
+	if (!WIFEXITED(status))
+		return 1;
+	return WEXITSTATUS(status);
+}
+
+int main(int argc, char **argv)
+{
+	struct hdn_package_hook_config config;
+	const struct hdn_package_hook_rule *rule;
+	const char *config_path = HDN_PACKAGE_HOOK_CONFIG;
+	const char *system_transaction = HDN_SYSTEM_TRANSACTION_PATH;
+	const char *image_seal = HDN_IMAGE_SEAL_PATH;
+	const char *hook = NULL;
+	int ret;
+	int i;
+
+	for (i = 1; i < argc; i++) {
+		if (!strcmp(argv[i], "--config")) {
+			if (++i >= argc) {
+				usage(argv[0]);
+				return 2;
+			}
+			config_path = argv[i];
+		} else if (!strcmp(argv[i], "--system-transaction")) {
+			if (++i >= argc ||
+			    require_safe_absolute("system transaction helper",
+						  argv[i])) {
+				usage(argv[0]);
+				return 2;
+			}
+			system_transaction = argv[i];
+		} else if (!strcmp(argv[i], "--image-seal")) {
+			if (++i >= argc ||
+			    require_safe_absolute("image seal helper", argv[i])) {
+				usage(argv[0]);
+				return 2;
+			}
+			image_seal = argv[i];
+		} else if (!strcmp(argv[i], "-h") ||
+			   !strcmp(argv[i], "--help")) {
+			usage(argv[0]);
+			return 0;
+		} else if (!hook) {
+			hook = argv[i];
+		} else {
+			usage(argv[0]);
+			return 2;
+		}
+	}
+
+	if (!hook || !safe_name(hook)) {
+		usage(argv[0]);
+		return 2;
+	}
+
+	ret = load_config(config_path, &config);
+	if (ret)
+		return 1;
+
+	rule = find_rule(&config, hook);
+	if (!rule) {
+		fprintf(stderr,
+			"hdn-package-hook: hook is not product-approved: %s\n",
+			hook);
+		free_config(&config);
+		return 1;
+	}
+
+	ret = run_hook(rule, system_transaction, image_seal);
+	free_config(&config);
+	return ret ? 1 : 0;
+}
diff -urN linux-7.0.12/tools/hardening/hdn-policy-learn.c linux-7.0.12-hdn/tools/hardening/hdn-policy-learn.c
--- linux-7.0.12/tools/hardening/hdn-policy-learn.c	1969-12-31 18:00:00.000000000 -0600
+++ linux-7.0.12-hdn/tools/hardening/hdn-policy-learn.c	2026-06-26 14:00:35.182043147 -0500
@@ -0,0 +1,846 @@
+// SPDX-License-Identifier: GPL-2.0-only
+
+#define _GNU_SOURCE
+
+#include <errno.h>
+#include <linux/hardening.h>
+#include <stdbool.h>
+#include <stdint.h>
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+#include <strings.h>
+
+#ifndef HDN_EVENTS_PATH
+#define HDN_EVENTS_PATH "/sys/kernel/security/hardening/events"
+#endif
+
+#define ARRAY_SIZE(array) (sizeof(array) / sizeof((array)[0]))
+#define HDN_MAX_LEARN_PROFILES 256
+#define HDN_MAX_REVIEW_ITEMS 512
+
+struct hdn_name {
+	unsigned int value;
+	const char *name;
+};
+
+struct hdn_learn_event {
+	unsigned long long sequence;
+	unsigned long long profile;
+	unsigned long long subject;
+	unsigned long long object;
+	unsigned int event_id;
+	unsigned int authority;
+	unsigned int transition;
+	unsigned int action;
+	unsigned int reason;
+	int error;
+};
+
