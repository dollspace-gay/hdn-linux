+static int file_lock_pressure_child(const char *path, int inherited_fd,
+				    bool posix_lock)
+{
+	int saved_errno = 0;
+	int fd;
+	int ret;
+
+	close(inherited_fd);
+	fd = open(path, O_RDWR | O_CLOEXEC);
+	if (fd < 0)
+		return 2;
+
+	if (posix_lock) {
+		struct flock lock = {
+			.l_type = F_WRLCK,
+			.l_whence = SEEK_SET,
+			.l_start = 0,
+			.l_len = 1,
+		};
+
+		ret = fcntl(fd, F_SETLK, &lock);
+	} else {
+		ret = flock(fd, LOCK_EX | LOCK_NB);
+	}
+	if (ret < 0)
+		saved_errno = errno;
+	close(fd);
+
+	return ret < 0 && (saved_errno == EACCES ||
+			   saved_errno == EAGAIN ||
+			   saved_errno == EWOULDBLOCK) ? 0 : 1;
+}
+
+static int run_conflicting_file_lock(const char *path, bool posix_lock)
+{
+	int result = 2;
+	pid_t child;
+	int fd;
+
+	unlink(path);
+	fd = open(path, O_CREAT | O_TRUNC | O_RDWR | O_CLOEXEC, 0600);
+	if (fd < 0)
+		return 2;
+
+	if (posix_lock) {
+		struct flock lock = {
+			.l_type = F_WRLCK,
+			.l_whence = SEEK_SET,
+			.l_start = 0,
+			.l_len = 1,
+		};
+
+		if (fcntl(fd, F_SETLK, &lock))
+			goto out;
+	} else if (flock(fd, LOCK_EX)) {
+		goto out;
+	}
+
+	child = fork();
+	if (child < 0)
+		goto out;
+	if (!child)
+		_exit(file_lock_pressure_child(path, fd, posix_lock));
+
+	result = child_exit_result(child);
+
+out:
+	if (posix_lock) {
+		struct flock unlock = {
+			.l_type = F_UNLCK,
+			.l_whence = SEEK_SET,
+			.l_start = 0,
+			.l_len = 1,
+		};
+
+		fcntl(fd, F_SETLK, &unlock);
+	} else {
+		flock(fd, LOCK_UN);
+	}
+	close(fd);
+	unlink(path);
+	return result;
+}
