+static int resource_memlock_pressure_child(void)
+{
+	long page_size = sysconf(_SC_PAGESIZE);
+	struct rlimit limit;
+	size_t len;
+	void *addr;
+	int saved_errno = 0;
+	int ret;
+
+	if (page_size <= 0)
+		return 2;
+	len = (size_t)page_size * 2;
+
+	if (setgid(HDN_TEST_NOBODY) || setuid(HDN_TEST_NOBODY))
+		return 2;
+
+	if (getrlimit(RLIMIT_MEMLOCK, &limit))
+		return 2;
+	if (limit.rlim_max != RLIM_INFINITY &&
+	    limit.rlim_max < (rlim_t)page_size)
+		return KSFT_SKIP;
+
+	limit.rlim_cur = page_size;
+	if (setrlimit(RLIMIT_MEMLOCK, &limit))
+		return 2;
+
+	addr = mmap(NULL, len, PROT_READ | PROT_WRITE,
+		    MAP_PRIVATE | MAP_ANONYMOUS, -1, 0);
+	if (addr == MAP_FAILED)
+		return 2;
+
+	ret = mlock(addr, len);
+	if (ret < 0)
+		saved_errno = errno;
+	munmap(addr, len);
+
+	return ret < 0 && saved_errno == ENOMEM ? 0 : 1;
+}
