+static pid_t spawn_chroot_outside_target(int *release_fd)
+{
+	int pipefd[2];
+	pid_t child;
+
+	if (pipe(pipefd))
+		return -1;
+
+	child = fork();
+	if (child < 0) {
+		close(pipefd[0]);
+		close(pipefd[1]);
+		return -1;
+	}
+
+	if (!child) {
+		char byte;
+
+		close(pipefd[1]);
+		while (read(pipefd[0], &byte, 1) > 0)
+			;
+		close(pipefd[0]);
+		_exit(0);
+	}
+
+	close(pipefd[0]);
+	*release_fd = pipefd[1];
+	return child;
+}
+
+static int release_chroot_outside_target(pid_t child, int release_fd)
+{
+	int status;
+	pid_t waited;
+
+	if (release_fd >= 0)
+		close(release_fd);
+
+	do {
+		waited = waitpid(child, &status, 0);
+	} while (waited < 0 && errno == EINTR);
+
+	if (waited != child)
+		return 2;
+	if (!WIFEXITED(status) || WEXITSTATUS(status))
+		return 2;
+
+	return 0;
+}
