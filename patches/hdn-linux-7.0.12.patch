+static int find_owner_only_sysfs_file(char *path, size_t size)
+{
+	struct dirent *cache;
+	DIR *slabs;
+	int ret = -ENOENT;
+
+	slabs = opendir(HDN_SYSFS_SLAB_DIR);
+	if (!slabs)
+		return -errno;
+
+	while ((cache = readdir(slabs))) {
+		struct dirent *attr;
+		char dir_path[PATH_MAX];
+		DIR *dir;
+
+		if (!strcmp(cache->d_name, ".") ||
+		    !strcmp(cache->d_name, ".."))
+			continue;
+
+		if (build_child_path(dir_path, sizeof(dir_path),
+				     HDN_SYSFS_SLAB_DIR, cache->d_name))
+			continue;
+
+		dir = opendir(dir_path);
+		if (!dir)
+			continue;
+
+		while ((attr = readdir(dir))) {
+			struct stat st;
+
+				if (!strcmp(attr->d_name, ".") ||
+				    !strcmp(attr->d_name, ".."))
+					continue;
+
+				if (build_child_path(path, size, dir_path,
+						     attr->d_name))
+					continue;
+				if (stat(path, &st))
+					continue;
+			if (!S_ISREG(st.st_mode))
+				continue;
+			if ((st.st_mode & 0400) &&
+			    !(st.st_mode & 0044)) {
+				ret = 0;
+				break;
+			}
+		}
+
+		closedir(dir);
+		if (!ret)
+			break;
+	}
+
+	closedir(slabs);
+	return ret;
+}
