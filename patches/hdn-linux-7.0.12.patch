+static int object_lock_path(const char *path, bool posix_lock,
+			    bool expect_denied)
+{
+	int saved_errno;
+	int ret;
+	int fd;
+
+	fd = open(path, O_RDWR | O_CLOEXEC);
+	if (fd < 0)
+		return 2;
+
+	errno = 0;
+	if (posix_lock) {
+		struct flock lock = {
+			.l_type = F_WRLCK,
+			.l_whence = SEEK_SET,
+			.l_start = 0,
+			.l_len = 1,
+		};
+
+		ret = fcntl(fd, F_SETLK, &lock);
+	} else {
+		ret = flock(fd, LOCK_EX | LOCK_NB);
+	}
+	saved_errno = errno;
+
+	if (expect_denied) {
+		close(fd);
+		if (!ret)
+			return 1;
+		return errno_is_denial(saved_errno) ? 0 : 2;
+	}
+
+	if (ret) {
+		close(fd);
+		return 2;
+	}
+
+	if (posix_lock) {
+		struct flock unlock = {
+			.l_type = F_UNLCK,
+			.l_whence = SEEK_SET,
+			.l_start = 0,
+			.l_len = 1,
+		};
+
+		ret = fcntl(fd, F_SETLK, &unlock);
+	} else {
+		ret = flock(fd, LOCK_UN);
+	}
+	close(fd);
+	return ret ? 2 : 0;
+}
