+static u64 hdn_path_object_id(const struct path *path)
+{
+	const struct inode *inode;
+
+	if (!path || !path->dentry)
+		return 0;
+
+	inode = d_inode(path->dentry);
+	return inode ? inode->i_ino : 0;
+}
