+	union sigval value = {};
+	struct rlimit lower;
+	struct rlimit orig;
+	unsigned int before;
+	int saved_errno = 0;
+	sigset_t oldset;
+	sigset_t set;
+	int ret;
+
+	if (getrlimit(RLIMIT_SIGPENDING, &orig)) {
+		ksft_test_result_fail("sigpending getrlimit failed: %s\n",
+				      strerror(errno));
+		return;
+	}
+
+	sigemptyset(&set);
+	sigaddset(&set, SIGRTMIN);
