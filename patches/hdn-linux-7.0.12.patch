+static int object_receive_fd_result(const char *path, bool expect_allowed)
+{
+	int saved_errno = 0;
+	int msg_flags = 0;
+	int status;
+	int sv[2];
+	int fd;
+	int ret;
+	pid_t child;
+
+	if (socketpair(AF_UNIX, SOCK_STREAM, 0, sv))
+		return 2;
+
+	child = fork();
+	if (child < 0) {
+		close(sv[0]);
+		close(sv[1]);
+		return 2;
+	}
+
+	if (!child) {
+		int got;
+
+		close(sv[0]);
+		errno = 0;
+		got = recv_fd_with_flags_over_socket(sv[1], &msg_flags);
+		saved_errno = errno;
+		close(sv[1]);
+
+		if (got >= 0) {
+			ret = read_fd_once(got);
+			close(got);
+			if (!expect_allowed)
+				_exit(1);
+			_exit(ret ? 2 : 0);
+		}
+
+		if (expect_allowed)
+			_exit(1);
+		if (errno_is_denial(saved_errno))
+			_exit(0);
+		_exit(!saved_errno && (msg_flags & MSG_CTRUNC) ? 0 : 2);
+	}
+
+	close(sv[1]);
+	fd = open(path, O_RDONLY | O_CLOEXEC);
+	if (fd < 0) {
+		close(sv[0]);
+		waitpid(child, NULL, 0);
+		return 2;
+	}
+
+	ret = send_fd_over_socket(sv[0], fd);
+	close(fd);
+	close(sv[0]);
+	if (ret) {
+		waitpid(child, NULL, 0);
+		return 2;
+	}
+
+	if (waitpid(child, &status, 0) < 0)
+		return 2;
+	if (!WIFEXITED(status))
+		return 2;
+	return WEXITSTATUS(status);
+}
