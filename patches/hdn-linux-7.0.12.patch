+		fprintf(stderr, "%u: %s needs profile ID\n", line, command);
+		return -EINVAL;
+	}
+
+	ret = parse_u64(id_text, value);
+	if (ret)
+		fprintf(stderr, "%u: invalid %s ID '%s'\n", line, command,
+			id_text);
+
+	return ret;
+}
+
+static int parse_subject_command(struct hdn_policy_builder *builder,
+				 char *save, unsigned int line)
+{
+	struct hdn_subject_rule_record *rule;
+	char *kind;
+	char *id_text;
+	char *profile_text;
+	uint64_t id;
+	uint64_t profile_id;
+	int ret;
+
+	if (builder->subject_rule_count >= HDN_MAX_SUBJECT_RULES) {
+		fprintf(stderr, "%u: too many subject rules\n", line);
+		return -E2BIG;
+	}
+
+	kind = strtok_r(NULL, " \t\r\n", &save);
+	id_text = strtok_r(NULL, " \t\r\n", &save);
+	profile_text = strtok_r(NULL, " \t\r\n", &save);
+	if (!kind || !id_text || !profile_text ||
+	    strtok_r(NULL, " \t\r\n", &save)) {
+		fprintf(stderr,
+			"%u: subject needs uid|gid ID PROFILE\n", line);
+		return -EINVAL;
+	}
+
+	ret = parse_u64(id_text, &id);
+	if (ret || id > UINT32_MAX) {
+		fprintf(stderr, "%u: invalid subject ID '%s'\n", line,
+			id_text);
+		return -EINVAL;
+	}
+
+	ret = parse_u64(profile_text, &profile_id);
+	if (ret) {
+		fprintf(stderr, "%u: invalid subject profile '%s'\n", line,
+			profile_text);
+		return -EINVAL;
+	}
+	if (!find_profile(builder->profiles, profile_id)) {
+		fprintf(stderr, "%u: unknown subject profile %llu\n", line,
+			(unsigned long long)profile_id);
+		return -EINVAL;
+	}
+
+	rule = &builder->subject_rules[builder->subject_rule_count];
+	memset(rule, 0, sizeof(*rule));
+	rule->profile_id = profile_id;
+	rule->id = (uint32_t)id;
+	if (!strcmp(kind, "uid"))
+		rule->flags = HDN_SUBJECT_MATCH_UID;
+	else if (!strcmp(kind, "gid"))
+		rule->flags = HDN_SUBJECT_MATCH_GID;
+	else {
+		fprintf(stderr, "%u: unknown subject kind '%s'\n", line,
+			kind);
+		return -EINVAL;
+	}
+
+	builder->subject_rule_count++;
+	return 0;
+}
+
+static int parse_line(struct hdn_policy_builder *builder,
+		      uint64_t *generation, uint64_t *default_profile,
+		      uint64_t *privileged_profile,
+		      uint64_t *expected_generation, char *line,
+		      unsigned int line_number)
+{
+	char *comment;
+	char *command;
+	char *save = NULL;
+
+	comment = strchr(line, '#');
+	if (comment)
+		*comment = '\0';
+
+	command = strtok_r(line, " \t\r\n", &save);
+	if (!command)
+		return 0;
+
+	if (!strcmp(command, "generation"))
+		return parse_id_command(generation, save, line_number,
+					command);
+	if (!strcmp(command, "base"))
+		return parse_id_command(expected_generation, save, line_number,
+					command);
+	if (!strcmp(command, "default"))
+		return parse_id_command(default_profile, save, line_number,
+					command);
+	if (!strcmp(command, "privileged"))
+		return parse_id_command(privileged_profile, save, line_number,
+					command);
+	if (!strcmp(command, "profile"))
+		return parse_profile_command(builder->profiles, save,
+					     line_number);
+	if (!strcmp(command, "role"))
+		return parse_role_command(builder, save, line_number);
+	if (!strcmp(command, "use-role") || !strcmp(command, "profile-role"))
+		return parse_role_use_command(builder, save, line_number);
+	if (!strcmp(command, "allow"))
+		return parse_mask_command(builder->profiles, save, line_number,
+					  false);
+	if (!strcmp(command, "audit"))
+		return parse_mask_command(builder->profiles, save, line_number,
+					  true);
+	if (!strcmp(command, "mem"))
+		return parse_mem_command(builder->profiles, save, line_number);
+	if (!strcmp(command, "response"))
+		return parse_profile_flag_command(builder->profiles, save,
+						  line_number, command);
+	if (!strcmp(command, "feature"))
+		return parse_profile_flag_command(builder->profiles, save,
+						  line_number, command);
+	if (!strcmp(command, "subject"))
+		return parse_subject_command(builder, save, line_number);
+	if (!strcmp(command, "object"))
+		return parse_object_command(builder, save, line_number);
+	if (!strcmp(command, "exec"))
+		return parse_exec_command(builder, save, line_number);
+	if (!strcmp(command, "module"))
+		return parse_module_command(builder, save, line_number);
+	if (!strcmp(command, "firmware"))
+		return parse_firmware_command(builder, save, line_number);
+
+	fprintf(stderr, "%u: unknown command '%s'\n", line_number, command);
+	return -EINVAL;
+}
+
+static int read_policy(const char *path, struct hdn_policy_builder *builder,
+		       uint64_t *generation, uint64_t *default_profile,
+		       uint64_t *privileged_profile,
+		       uint64_t *expected_generation)
+{
+	char line[4096];
+	unsigned int line_number = 0;
+	FILE *file;
+	int ret = 0;
+
+	file = fopen(path, "r");
+	if (!file) {
+		perror(path);
+		return -errno;
+	}
+
+	while (fgets(line, sizeof(line), file)) {
+		line_number++;
+		ret = parse_line(builder, generation, default_profile,
+				 privileged_profile, expected_generation, line,
+				 line_number);
+		if (ret)
+			break;
+	}
+
+	if (ferror(file) && !ret) {
+		perror(path);
+		ret = -EIO;
+	}
+
+	fclose(file);
+	return ret;
+}
+
+static void merge_role(struct hdn_role_builder *role,
+		       const struct hdn_role_builder *parent)
+{
+	role->authority_allow |= parent->authority_allow;
+	role->authority_allow_hi |= parent->authority_allow_hi;
+	role->authority_audit |= parent->authority_audit;
+	role->authority_audit_hi |= parent->authority_audit_hi;
+	role->memory_flags |= parent->memory_flags;
+	role->flags |= parent->flags;
+}
+
+static int expand_role(struct hdn_policy_builder *builder, size_t index)
+{
+	struct hdn_role_builder *role = &builder->roles[index];
+	uint32_t i;
+	int ret;
+	int parent_index;
+
+	if (role->visit_state == 2)
+		return 0;
+	if (role->visit_state == 1) {
+		fprintf(stderr, "role include cycle involving '%s'\n",
+			role->name);
+		return -EINVAL;
+	}
+
+	role->visit_state = 1;
+	for (i = 0; i < builder->role_include_count; i++) {
+		const struct hdn_role_include *include =
+			&builder->role_includes[i];
+
+		if (strcmp(include->role_name, role->name))
+			continue;
+
+		parent_index = find_role_index(builder->roles,
+					       include->parent_name);
+		if (parent_index < 0) {
+			fprintf(stderr, "%u: unknown included role '%s'\n",
+				include->line, include->parent_name);
+			return -ENOENT;
+		}
+
+		ret = expand_role(builder, (size_t)parent_index);
+		if (ret)
+			return ret;
+		merge_role(role, &builder->roles[parent_index]);
+	}
+	role->visit_state = 2;
+
+	return 0;
+}
+
+static int expand_roles(struct hdn_policy_builder *builder)
+{
+	size_t i;
+	int ret;
+
+	for (i = 0; i < HDN_MAX_ROLES; i++)
+		builder->roles[i].visit_state = 0;
+
+	for (i = 0; i < HDN_MAX_ROLES; i++) {
+		if (!builder->roles[i].present)
+			continue;
+		ret = expand_role(builder, i);
+		if (ret)
+			return ret;
+	}
+
+	return 0;
+}
+
+static int apply_role_uses(struct hdn_policy_builder *builder)
+{
+	uint32_t i;
+
+	for (i = 0; i < builder->role_use_count; i++) {
+		const struct hdn_role_use *role_use = &builder->role_uses[i];
+		struct hdn_profile_builder *profile;
+		struct hdn_role_builder *role;
+
+		profile = find_profile(builder->profiles, role_use->profile_id);
+		if (!profile) {
+			fprintf(stderr, "%u: unknown use-role profile %llu\n",
+				role_use->line,
+				(unsigned long long)role_use->profile_id);
+			return -ENOENT;
+		}
+
+		role = find_role(builder->roles, role_use->role_name);
+		if (!role) {
+			fprintf(stderr, "%u: unknown role '%s'\n",
+				role_use->line, role_use->role_name);
+			return -ENOENT;
+		}
+
+		profile->record.authority_allow |= role->authority_allow;
+		profile->record.authority_allow_hi |= role->authority_allow_hi;
+		profile->record.authority_audit |= role->authority_audit;
+		profile->record.authority_audit_hi |= role->authority_audit_hi;
+		profile->record.memory_flags |= role->memory_flags;
+		profile->record.flags |= role->flags;
+	}
+
+	return 0;
+}
+
+static int build_records(const struct hdn_profile_builder *profiles,
+			 struct hdn_profile_record *records, uint32_t *count)
+{
+	size_t i;
+
+	*count = 0;
+	for (i = 0; i < HDN_MAX_PROFILES; i++) {
+		if (!profiles[i].present)
+			continue;
+		records[*count] = profiles[i].record;
+		(*count)++;
+	}
+
+	return *count ? 0 : -EINVAL;
+}
+
+static int write_policy(const char *path,
+			const struct hdn_profile_record *records,
+			uint32_t count,
+			const struct hdn_subject_rule_record *subject_rules,
+			uint32_t subject_rule_count,
+			const struct hdn_object_rule_record *object_rules,
+			uint32_t object_rule_count,
+			const struct hdn_exec_rule_record *exec_rules,
+			uint32_t exec_rule_count,
+			const struct hdn_module_rule_record *module_rules,
+			uint32_t module_rule_count,
+			const struct hdn_firmware_rule_record *firmware_rules,
+			uint32_t firmware_rule_count, uint64_t generation,
+			uint64_t expected_generation,
+			uint64_t default_profile, uint64_t privileged_profile)
+{
+	struct hdn_policy_header header = {
+		.magic = HDN_POLICY_MAGIC,
+		.abi_version = HDN_POLICY_ABI_VERSION,
+		.header_size = sizeof(header),
+		.profile_size = sizeof(records[0]),
+		.profile_count = count,
+		.subject_rule_size = sizeof(subject_rules[0]),
+		.subject_rule_count = subject_rule_count,
+		.object_rule_size = sizeof(object_rules[0]),
+		.object_rule_count = object_rule_count,
+		.exec_rule_size = sizeof(exec_rules[0]),
+		.exec_rule_count = exec_rule_count,
+		.module_rule_size = sizeof(module_rules[0]),
+		.module_rule_count = module_rule_count,
+		.firmware_rule_size = sizeof(firmware_rules[0]),
+		.firmware_rule_count = firmware_rule_count,
+		.generation = generation,
+		.expected_generation = expected_generation,
+		.default_profile_id = default_profile,
+		.privileged_profile_id = privileged_profile,
+	};
+	FILE *file;
+
+	file = fopen(path, "wb");
+	if (!file) {
+		perror(path);
+		return -errno;
+	}
+
+	if (fwrite(&header, sizeof(header), 1, file) != 1 ||
+	    fwrite(records, sizeof(records[0]), count, file) != count ||
+	    fwrite(subject_rules, sizeof(subject_rules[0]),
+		   subject_rule_count, file) != subject_rule_count ||
+	    fwrite(object_rules, sizeof(object_rules[0]),
+		   object_rule_count, file) != object_rule_count ||
+	    fwrite(exec_rules, sizeof(exec_rules[0]), exec_rule_count, file) !=
+	    exec_rule_count ||
+	    fwrite(module_rules, sizeof(module_rules[0]), module_rule_count,
+		   file) != module_rule_count ||
+	    fwrite(firmware_rules, sizeof(firmware_rules[0]),
+		   firmware_rule_count, file) != firmware_rule_count) {
+		perror(path);
+		fclose(file);
+		return -EIO;
+	}
+
+	if (fclose(file)) {
+		perror(path);
+		return -EIO;
+	}
+
+	return 0;
+}
+
+static bool profile_id_present(const struct hdn_profile_record *records,
+			       uint32_t count, uint64_t id)
+{
+	uint32_t i;
+
+	for (i = 0; i < count; i++) {
+		if (records[i].profile_id == id)
+			return true;
+	}
+
+	return false;
+}
+
+static int validate_policy(const struct hdn_profile_record *records,
+			   uint32_t count,
+			   const struct hdn_subject_rule_record *subject_rules,
+			   uint32_t subject_rule_count,
+			   const struct hdn_object_rule_record *object_rules,
+			   uint32_t object_rule_count,
+			   uint64_t default_profile, uint64_t privileged_profile)
+{
+	uint32_t i;
+
+	if (!profile_id_present(records, count, default_profile)) {
+		fprintf(stderr, "default profile %llu is missing\n",
+			(unsigned long long)default_profile);
+		return -EINVAL;
+	}
+
+	if (!profile_id_present(records, count, privileged_profile)) {
+		fprintf(stderr, "privileged profile %llu is missing\n",
+			(unsigned long long)privileged_profile);
+		return -EINVAL;
+	}
+
+	for (i = 0; i < subject_rule_count; i++) {
+		if (!profile_id_present(records, count,
+					subject_rules[i].profile_id)) {
+			fprintf(stderr,
+				"subject rule %u target profile %llu is missing\n",
+				i,
+				(unsigned long long)subject_rules[i].profile_id);
+			return -EINVAL;
+		}
+	}
+
+	for (i = 0; i < object_rule_count; i++) {
+		if (!profile_id_present(records, count,
+					object_rules[i].profile_id)) {
+			fprintf(stderr,
+				"object rule %u profile %llu is missing\n",
+				i,
+				(unsigned long long)object_rules[i].profile_id);
+			return -EINVAL;
+		}
+	}
+
+	return 0;
+}
+
+int main(int argc, char **argv)
+{
+	struct hdn_policy_builder builder = {};
+	struct hdn_profile_record records[HDN_MAX_PROFILES] = {};
+	uint64_t generation = 1;
+	uint64_t expected_generation = HDN_POLICY_EXPECT_ANY;
+	uint64_t default_profile = HDN_PROFILE_DEFAULT;
+	uint64_t privileged_profile = HDN_PROFILE_PRIVILEGED;
+	uint32_t count;
+	int ret;
+
+	if (argc != 3) {
+		usage(argv[0]);
+		return 2;
+	}
+
+	ret = read_policy(argv[1], &builder, &generation, &default_profile,
+			  &privileged_profile, &expected_generation);
+	if (ret)
+		return 1;
+
+	ret = expand_roles(&builder);
+	if (ret)
+		return 1;
+
+	ret = apply_role_uses(&builder);
+	if (ret)
+		return 1;
+
+	ret = build_records(builder.profiles, records, &count);
+	if (ret) {
+		fprintf(stderr, "policy contains no profiles\n");
+		return 1;
+	}
+
+	ret = validate_policy(records, count, builder.subject_rules,
+			      builder.subject_rule_count, builder.object_rules,
+			      builder.object_rule_count, default_profile,
+			      privileged_profile);
+	if (ret)
+		return 1;
+
+	ret = write_policy(argv[2], records, count, builder.subject_rules,
+			   builder.subject_rule_count, builder.object_rules,
+			   builder.object_rule_count, builder.exec_rules,
+			   builder.exec_rule_count, builder.module_rules,
+			   builder.module_rule_count, builder.firmware_rules,
+			   builder.firmware_rule_count, generation,
+			   expected_generation,
+			   default_profile, privileged_profile);
+	if (ret)
+		return 1;
+
+	return 0;
+}
diff -urN linux-7.0.12/tools/hardening/hdn-prompt-describe.c linux-7.0.12-hdn/tools/hardening/hdn-prompt-describe.c
--- linux-7.0.12/tools/hardening/hdn-prompt-describe.c	1969-12-31 18:00:00.000000000 -0600
+++ linux-7.0.12-hdn/tools/hardening/hdn-prompt-describe.c	2026-06-25 15:27:31.461346200 -0500
@@ -0,0 +1,417 @@
+// SPDX-License-Identifier: GPL-2.0-only
+
+#define _GNU_SOURCE
+
+#include <errno.h>
+#include <fcntl.h>
+#include <stdbool.h>
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+#include <sys/stat.h>
+#include <unistd.h>
+
+#ifndef HDN_PROMPT_METADATA_CONFIG
+#define HDN_PROMPT_METADATA_CONFIG "/etc/hdn/prompt-metadata.conf"
+#endif
+
+#define HDN_PROMPT_METADATA_MAX_ACTIONS 64
+#define HDN_PROMPT_METADATA_MAX_VALUE 512
+
+struct hdn_prompt_metadata {
+	char *name;
+	char *title;
+	char *message;
+	char *consequence;
+	char *risk;
+};
+
+struct hdn_prompt_metadata_config {
+	struct hdn_prompt_metadata actions[HDN_PROMPT_METADATA_MAX_ACTIONS];
+	unsigned int count;
+};
+
+static void usage(const char *prog)
+{
+	fprintf(stderr,
+		"Usage: %s [--config FILE] ACTION\n"
+		"\n"
+		"Prints product-approved prompt metadata for a named action.\n"
+		"Config lines: prompt NAME FIELD VALUE\n"
+		"Known fields: title, message, consequence, risk\n",
+		prog);
+}
+
+static char *trim(char *line)
+{
+	char *end;
+
+	while (*line == ' ' || *line == '\t' || *line == '\r' ||
+	       *line == '\n')
+		line++;
+
+	end = line + strlen(line);
+	while (end > line &&
+	       (end[-1] == ' ' || end[-1] == '\t' || end[-1] == '\r' ||
+		end[-1] == '\n'))
+		*--end = '\0';
+
+	return line;
+}
+
+static char *next_word(char **cursor)
+{
+	char *word;
+	char *end;
+
+	*cursor = trim(*cursor);
+	if (!(*cursor)[0])
+		return NULL;
+
+	word = *cursor;
+	end = strpbrk(word, " \t");
+	if (!end) {
+		*cursor = word + strlen(word);
+		return word;
+	}
+
+	*end++ = '\0';
+	*cursor = end;
+	return word;
+}
+
+static bool safe_name(const char *name)
+{
+	const char *p;
+
+	if (!name || !name[0] || !strcmp(name, ".") || !strcmp(name, ".."))
+		return false;
+
+	for (p = name; *p; p++) {
+		if ((*p >= 'A' && *p <= 'Z') ||
+		    (*p >= 'a' && *p <= 'z') ||
+		    (*p >= '0' && *p <= '9') ||
+		    *p == '.' || *p == '_' || *p == '-')
+			continue;
+		return false;
+	}
+
+	return true;
+}
+
+static int require_safe_text(const char *field, const char *value,
+			     unsigned int lineno)
+{
+	const unsigned char *p;
+	size_t len;
+
+	if (!value || !value[0]) {
+		fprintf(stderr,
+			"hdn-prompt-describe: missing %s text at line %u\n",
+			field, lineno);
+		return -EINVAL;
+	}
+
+	len = strlen(value);
+	if (len > HDN_PROMPT_METADATA_MAX_VALUE) {
+		fprintf(stderr,
+			"hdn-prompt-describe: %s text too long at line %u\n",
+			field, lineno);
+		return -E2BIG;
+	}
+
+	for (p = (const unsigned char *)value; *p; p++) {
+		if (*p >= 0x20 && *p <= 0x7e)
+			continue;
+		fprintf(stderr,
+			"hdn-prompt-describe: unsafe %s text at line %u\n",
+			field, lineno);
+		return -EINVAL;
+	}
+
+	return 0;
+}
+
+static struct hdn_prompt_metadata *
+find_metadata(struct hdn_prompt_metadata_config *config, const char *name)
+{
+	unsigned int i;
+
+	for (i = 0; i < config->count; i++) {
+		if (!strcmp(config->actions[i].name, name))
+			return &config->actions[i];
+	}
+
+	return NULL;
+}
+
+static struct hdn_prompt_metadata *
+find_or_add_metadata(struct hdn_prompt_metadata_config *config,
+		     const char *name, unsigned int lineno)
+{
+	struct hdn_prompt_metadata *meta;
+
+	meta = find_metadata(config, name);
+	if (meta)
+		return meta;
+
+	if (config->count >= HDN_PROMPT_METADATA_MAX_ACTIONS) {
+		fprintf(stderr,
+			"hdn-prompt-describe: too many prompt metadata actions\n");
+		errno = E2BIG;
+		return NULL;
+	}
+
+	meta = &config->actions[config->count];
+	meta->name = strdup(name);
+	if (!meta->name) {
+		errno = ENOMEM;
+		return NULL;
+	}
+
+	config->count++;
+	(void)lineno;
+	return meta;
+}
+
+static int set_field(char **slot, const char *field, const char *value,
+		     unsigned int lineno)
+{
+	char *copy;
+	int ret;
+
+	if (*slot) {
+		fprintf(stderr,
+			"hdn-prompt-describe: duplicate %s field at line %u\n",
+			field, lineno);
+		return -EINVAL;
+	}
+
+	ret = require_safe_text(field, value, lineno);
+	if (ret)
+		return ret;
+
+	copy = strdup(value);
+	if (!copy)
+		return -ENOMEM;
+
+	*slot = copy;
+	return 0;
+}
+
+static int parse_config_line(struct hdn_prompt_metadata_config *config,
+			     char *line, unsigned int lineno)
+{
+	struct hdn_prompt_metadata *meta;
+	char *cursor;
+	char *key;
+	char *name;
+	char *field;
+	char *value;
+
+	cursor = trim(line);
+	if (!cursor[0] || cursor[0] == '#')
+		return 0;
+
+	key = next_word(&cursor);
+	name = next_word(&cursor);
+	field = next_word(&cursor);
+	value = trim(cursor);
+
+	if (!key || strcmp(key, "prompt")) {
+		fprintf(stderr,
+			"hdn-prompt-describe: unknown config key at line %u: %s\n",
+			lineno, key ? key : "(null)");
+		return -EINVAL;
+	}
+	if (!name || !field || !value[0]) {
+		fprintf(stderr,
+			"hdn-prompt-describe: prompt line %u needs NAME FIELD VALUE\n",
+			lineno);
+		return -EINVAL;
+	}
+	if (!safe_name(name)) {
+		fprintf(stderr,
+			"hdn-prompt-describe: unsafe action name at line %u: %s\n",
+			lineno, name);
+		return -EINVAL;
+	}
+
+	meta = find_or_add_metadata(config, name, lineno);
+	if (!meta)
+		return -errno;
+
+	if (!strcmp(field, "title"))
+		return set_field(&meta->title, field, value, lineno);
+	if (!strcmp(field, "message"))
+		return set_field(&meta->message, field, value, lineno);
+	if (!strcmp(field, "consequence"))
+		return set_field(&meta->consequence, field, value, lineno);
+	if (!strcmp(field, "risk"))
+		return set_field(&meta->risk, field, value, lineno);
+
+	fprintf(stderr,
+		"hdn-prompt-describe: unknown prompt metadata field at line %u: %s\n",
+		lineno, field);
+	return -EINVAL;
+}
+
+static int open_config(const char *path)
+{
+	struct stat st;
+	int flags = O_RDONLY | O_CLOEXEC;
+	int fd;
+
+#ifdef O_NOFOLLOW
+	flags |= O_NOFOLLOW;
+#endif
+
+	fd = open(path, flags);
+	if (fd < 0) {
+		fprintf(stderr, "hdn-prompt-describe: cannot open %s: %s\n",
+			path, strerror(errno));
+		return -errno;
+	}
+
+	if (fstat(fd, &st)) {
+		int ret = -errno;
+
+		fprintf(stderr, "hdn-prompt-describe: cannot stat %s: %s\n",
+			path, strerror(errno));
+		close(fd);
+		return ret;
+	}
+
+	if (!S_ISREG(st.st_mode) || st.st_uid != 0 || (st.st_mode & 022)) {
+		fprintf(stderr,
+			"hdn-prompt-describe: refusing unsafe config %s\n",
+			path);
+		close(fd);
+		return -EACCES;
+	}
+
+	return fd;
+}
+
+static int load_config(const char *path,
+		       struct hdn_prompt_metadata_config *config)
+{
+	char *line = NULL;
+	size_t size = 0;
+	unsigned int lineno = 0;
+	ssize_t len;
+	FILE *file;
+	int ret = 0;
+	int fd;
+
+	memset(config, 0, sizeof(*config));
+
+	fd = open_config(path);
+	if (fd < 0)
+		return fd;
+
+	file = fdopen(fd, "r");
+	if (!file) {
+		ret = -errno;
+		close(fd);
+		return ret;
+	}
+
+	while ((len = getline(&line, &size, file)) >= 0) {
+		(void)len;
+		lineno++;
+		ret = parse_config_line(config, line, lineno);
+		if (ret)
+			break;
+	}
+	if (ferror(file) && !ret)
+		ret = -EIO;
+
+	free(line);
+	fclose(file);
+	return ret;
+}
+
+static void free_config(struct hdn_prompt_metadata_config *config)
+{
+	unsigned int i;
+
+	for (i = 0; i < config->count; i++) {
+		free(config->actions[i].name);
+		free(config->actions[i].title);
+		free(config->actions[i].message);
+		free(config->actions[i].consequence);
+		free(config->actions[i].risk);
+	}
+}
+
+static int describe_action(struct hdn_prompt_metadata_config *config,
+			   const char *action)
+{
+	struct hdn_prompt_metadata *meta;
+
+	meta = find_metadata(config, action);
+	if (!meta) {
+		fprintf(stderr,
+			"hdn-prompt-describe: prompt action is not product-approved: %s\n",
+			action);
+		return 1;
+	}
+
+	if (!meta->title || !meta->message || !meta->consequence) {
+		fprintf(stderr,
+			"hdn-prompt-describe: prompt action has incomplete metadata: %s\n",
+			action);
+		return 1;
+	}
+
+	printf("HDN_PROMPT_METADATA_V1\n");
+	printf("action=%s\n", meta->name);
+	printf("title=%s\n", meta->title);
+	printf("message=%s\n", meta->message);
+	printf("consequence=%s\n", meta->consequence);
+	if (meta->risk)
+		printf("risk=%s\n", meta->risk);
+	return ferror(stdout) ? 1 : 0;
+}
+
+int main(int argc, char **argv)
+{
+	struct hdn_prompt_metadata_config config;
+	const char *config_path = HDN_PROMPT_METADATA_CONFIG;
+	const char *action = NULL;
+	int ret;
+	int i;
+
+	for (i = 1; i < argc; i++) {
+		if (!strcmp(argv[i], "--config")) {
+			if (++i >= argc) {
+				usage(argv[0]);
+				return 2;
+			}
+			config_path = argv[i];
+		} else if (!strcmp(argv[i], "-h") ||
+			   !strcmp(argv[i], "--help")) {
+			usage(argv[0]);
+			return 0;
+		} else if (!action) {
+			action = argv[i];
+		} else {
+			usage(argv[0]);
+			return 2;
+		}
+	}
+
+	if (!action || !safe_name(action)) {
+		usage(argv[0]);
+		return 2;
+	}
+
+	ret = load_config(config_path, &config);
+	if (ret)
+		return 1;
+
+	ret = describe_action(&config, action);
+	free_config(&config);
+	return ret;
+}
diff -urN linux-7.0.12/tools/hardening/hdn-prompt-dispatch.c linux-7.0.12-hdn/tools/hardening/hdn-prompt-dispatch.c
--- linux-7.0.12/tools/hardening/hdn-prompt-dispatch.c	1969-12-31 18:00:00.000000000 -0600
+++ linux-7.0.12-hdn/tools/hardening/hdn-prompt-dispatch.c	2026-06-25 15:09:00.693226933 -0500
@@ -0,0 +1,673 @@
+// SPDX-License-Identifier: GPL-2.0-only
+
+#define _GNU_SOURCE
+
+#include <errno.h>
+#include <fcntl.h>
+#include <limits.h>
+#include <stdbool.h>
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+#include <sys/stat.h>
+#include <sys/wait.h>
+#include <unistd.h>
+
+#ifndef HDN_PROMPT_DISPATCH_CONFIG
+#define HDN_PROMPT_DISPATCH_CONFIG "/etc/hdn/prompt-actions.conf"
+#endif
+
+#ifndef HDN_ADMIN_BROKER_PATH
+#define HDN_ADMIN_BROKER_PATH "/usr/libexec/hdn-admin-broker"
+#endif
+
+#ifndef HDN_APPROVAL_TOKEN_PATH
+#define HDN_APPROVAL_TOKEN_PATH "/usr/libexec/hdn-approval-token"
+#endif
+
+#ifndef HDN_APPROVAL_TOKEN_DIR
+#define HDN_APPROVAL_TOKEN_DIR "/run/hdn/approvals"
+#endif
+
+#define HDN_PROMPT_MAX_RULES 64
+#define HDN_PROMPT_MAX_ARGS 32
+#define HDN_PROMPT_TOKEN_TTL_DEFAULT_MS 30000ULL
+#define HDN_PROMPT_TOKEN_TTL_MAX_MS 300000ULL
+
+struct hdn_prompt_rule {
+	char *name;
+	char *intent;
+	char *args[HDN_PROMPT_MAX_ARGS + 1];
+	unsigned int argc;
+};
+
+struct hdn_prompt_config {
+	struct hdn_prompt_rule rules[HDN_PROMPT_MAX_RULES];
+	unsigned int count;
+};
+
+static void usage(const char *prog)
+{
+	fprintf(stderr,
+		"Usage: %s [--config FILE] [--broker PATH] [--token-issuer PATH]\n"
+		"       [--token-dir DIR] [--ttl-ms MS] ACTION\n"
+		"\n"
+		"Runs a named post-auth product action through hdn-admin-broker.\n"
+		"Config lines: action NAME INTENT [ARG...]\n"
+		"Known intents: rofs-apply, rofs-transaction, policy-commit, policy-rollback\n",
+		prog);
+}
+
+static char *trim(char *line)
+{
+	char *end;
+
+	while (*line == ' ' || *line == '\t' || *line == '\r' ||
+	       *line == '\n')
+		line++;
+
+	end = line + strlen(line);
+	while (end > line &&
+	       (end[-1] == ' ' || end[-1] == '\t' || end[-1] == '\r' ||
+		end[-1] == '\n'))
+		*--end = '\0';
+
+	return line;
+}
+
+static bool known_intent(const char *intent)
+{
+	return !strcmp(intent, "rofs-apply") ||
+	       !strcmp(intent, "rofs-transaction") ||
+	       !strcmp(intent, "policy-commit") ||
+	       !strcmp(intent, "policy-rollback");
+}
+
+static bool safe_name(const char *name)
+{
+	const char *p;
+
+	if (!name || !name[0] || !strcmp(name, ".") || !strcmp(name, ".."))
+		return false;
+
+	for (p = name; *p; p++) {
+		if ((*p >= 'A' && *p <= 'Z') ||
+		    (*p >= 'a' && *p <= 'z') ||
+		    (*p >= '0' && *p <= '9') ||
+		    *p == '.' || *p == '_' || *p == '-')
+			continue;
+		return false;
+	}
+
+	return true;
+}
+
+static bool path_has_dot_component(const char *path)
+{
+	const char *part = path;
+
+	while (*part) {
+		const char *slash;
+		size_t len;
+
+		while (*part == '/')
+			part++;
+		if (!*part)
+			break;
+
+		slash = strchr(part, '/');
+		len = slash ? (size_t)(slash - part) : strlen(part);
+		if ((len == 1 && part[0] == '.') ||
+		    (len == 2 && part[0] == '.' && part[1] == '.'))
+			return true;
+		part += len;
+	}
+
+	return false;
+}
+
+static int require_safe_absolute(const char *what, const char *path)
+{
+	if (!path || path[0] != '/') {
+		fprintf(stderr,
+			"hdn-prompt-dispatch: %s must be absolute: %s\n",
+			what, path ? path : "(null)");
+		return -EINVAL;
+	}
+	if (path_has_dot_component(path)) {
+		fprintf(stderr,
+			"hdn-prompt-dispatch: %s must not contain . or .. path components: %s\n",
+			what, path);
+		return -EINVAL;
+	}
+
+	return 0;
+}
+
+static int require_safe_dir(const char *path)
+{
+	int ret = require_safe_absolute("token directory", path);
+
+	if (ret)
+		return ret;
+	if (!strcmp(path, "/")) {
+		fprintf(stderr,
+			"hdn-prompt-dispatch: token directory / is too broad\n");
+		return -EINVAL;
+	}
+
+	return 0;
+}
+
+static int parse_u64(const char *text, unsigned long long *value)
+{
+	char *end;
+
+	errno = 0;
+	*value = strtoull(text, &end, 10);
+	if (errno || end == text || *end)
+		return -EINVAL;
+	return 0;
+}
+
+static int validate_rofs_apply_args(char **args, unsigned int argc,
+				    unsigned int lineno)
+{
+	bool saw_target = false;
+	unsigned int i;
+
+	for (i = 0; i < argc; i++) {
+		if (!strcmp(args[i], "-r") || !strcmp(args[i], "--recursive"))
+			continue;
+		if (!strcmp(args[i], "-f") || !strcmp(args[i], "--file")) {
+			if (++i >= argc)
+				goto bad;
+			if (require_safe_absolute("readonly mount list",
+						  args[i]))
+				return -EINVAL;
+			saw_target = true;
+			continue;
+		}
+		if (args[i][0] == '-')
+			goto bad;
+		if (require_safe_absolute("mountpoint", args[i]))
+			return -EINVAL;
+		saw_target = true;
+	}
+
+	if (saw_target)
+		return 0;
+
+bad:
+	fprintf(stderr,
+		"hdn-prompt-dispatch: invalid rofs-apply action at line %u\n",
+		lineno);
+	return -EINVAL;
+}
+
+static int validate_rofs_transaction_args(char **args, unsigned int argc,
+					  unsigned int lineno)
+{
+	if (argc < 3 || strcmp(args[1], "--")) {
+		fprintf(stderr,
+			"hdn-prompt-dispatch: rofs-transaction action at line %u needs MOUNTPOINT -- WORKER [ARG...]\n",
+			lineno);
+		return -EINVAL;
+	}
+	if (require_safe_absolute("mountpoint", args[0]) ||
+	    require_safe_absolute("worker", args[2]))
+		return -EINVAL;
+
+	return 0;
+}
+
+static int validate_policy_commit_args(char **args, unsigned int argc,
+				       unsigned int lineno)
+{
+	if (argc != 1) {
+		fprintf(stderr,
+			"hdn-prompt-dispatch: policy-commit action at line %u needs SIGNED_POLICY\n",
+			lineno);
+		return -EINVAL;
+	}
+
+	return require_safe_absolute("signed policy", args[0]);
+}
+
+static int validate_rule_args(const char *intent, char **args,
+			      unsigned int argc, unsigned int lineno)
+{
+	if (!strcmp(intent, "rofs-apply"))
+		return validate_rofs_apply_args(args, argc, lineno);
+	if (!strcmp(intent, "rofs-transaction"))
+		return validate_rofs_transaction_args(args, argc, lineno);
+	if (!strcmp(intent, "policy-commit"))
+		return validate_policy_commit_args(args, argc, lineno);
+	if (!strcmp(intent, "policy-rollback")) {
+		if (!argc)
+			return 0;
+		fprintf(stderr,
+			"hdn-prompt-dispatch: policy-rollback takes no arguments at line %u\n",
+			lineno);
+		return -EINVAL;
+	}
+
+	return -EINVAL;
+}
+
+static int add_rule(struct hdn_prompt_config *config, char **tokens,
+		    unsigned int count, unsigned int lineno)
+{
+	struct hdn_prompt_rule *rule;
+	unsigned int argc;
+	unsigned int i;
+
+	if (count < 3) {
+		fprintf(stderr,
+			"hdn-prompt-dispatch: action line %u needs NAME INTENT\n",
+			lineno);
+		return -EINVAL;
+	}
+	if (config->count >= HDN_PROMPT_MAX_RULES) {
+		fprintf(stderr,
+			"hdn-prompt-dispatch: too many prompt actions\n");
+		return -E2BIG;
+	}
+	if (!safe_name(tokens[1])) {
+		fprintf(stderr,
+			"hdn-prompt-dispatch: unsafe action name at line %u: %s\n",
+			lineno, tokens[1]);
+		return -EINVAL;
+	}
+	if (!known_intent(tokens[2])) {
+		fprintf(stderr,
+			"hdn-prompt-dispatch: unknown intent at line %u: %s\n",
+			lineno, tokens[2]);
+		return -EINVAL;
+	}
+
+	argc = count - 3;
+	if (argc > HDN_PROMPT_MAX_ARGS) {
+		fprintf(stderr,
+			"hdn-prompt-dispatch: too many action arguments at line %u\n",
+			lineno);
+		return -E2BIG;
+	}
+	if (validate_rule_args(tokens[2], &tokens[3], argc, lineno))
+		return -EINVAL;
+
+	rule = &config->rules[config->count];
+	rule->name = strdup(tokens[1]);
+	rule->intent = strdup(tokens[2]);
+	if (!rule->name || !rule->intent)
+		return -ENOMEM;
+
+	for (i = 0; i < argc; i++) {
+		rule->args[rule->argc] = strdup(tokens[i + 3]);
+		if (!rule->args[rule->argc])
+			return -ENOMEM;
+		rule->argc++;
+	}
+	rule->args[rule->argc] = NULL;
+	config->count++;
+	return 0;
+}
+
+static int parse_config_line(struct hdn_prompt_config *config, char *line,
+			     unsigned int lineno)
+{
+	char *tokens[HDN_PROMPT_MAX_ARGS + 3];
+	unsigned int count = 0;
+	char *save = NULL;
+	char *word;
+
+	line = trim(line);
+	if (!line[0] || line[0] == '#')
+		return 0;
+
+	for (word = strtok_r(line, " \t", &save); word;
+	     word = strtok_r(NULL, " \t", &save)) {
+		if (count >= sizeof(tokens) / sizeof(tokens[0])) {
+			fprintf(stderr,
+				"hdn-prompt-dispatch: too many fields at line %u\n",
+				lineno);
+			return -E2BIG;
+		}
+		tokens[count++] = word;
+	}
+
+	if (!count)
+		return 0;
+	if (strcmp(tokens[0], "action")) {
+		fprintf(stderr,
+			"hdn-prompt-dispatch: unknown config key at line %u: %s\n",
+			lineno, tokens[0]);
+		return -EINVAL;
+	}
+
+	return add_rule(config, tokens, count, lineno);
+}
+
+static int open_config(const char *path)
+{
+	struct stat st;
+	int flags = O_RDONLY | O_CLOEXEC;
+	int fd;
+
+#ifdef O_NOFOLLOW
+	flags |= O_NOFOLLOW;
+#endif
+
+	fd = open(path, flags);
+	if (fd < 0) {
+		fprintf(stderr, "hdn-prompt-dispatch: cannot open %s: %s\n",
+			path, strerror(errno));
+		return -errno;
+	}
+
+	if (fstat(fd, &st)) {
+		int ret = -errno;
+
+		fprintf(stderr, "hdn-prompt-dispatch: cannot stat %s: %s\n",
+			path, strerror(errno));
+		close(fd);
+		return ret;
+	}
+
+	if (!S_ISREG(st.st_mode) || st.st_uid != 0 || (st.st_mode & 022)) {
+		fprintf(stderr,
+			"hdn-prompt-dispatch: refusing unsafe config %s\n",
+			path);
+		close(fd);
+		return -EACCES;
+	}
+
+	return fd;
+}
+
+static int load_config(const char *path, struct hdn_prompt_config *config)
+{
+	char *line = NULL;
+	size_t size = 0;
+	unsigned int lineno = 0;
+	ssize_t len;
+	FILE *file;
+	int ret = 0;
+	int fd;
+
+	memset(config, 0, sizeof(*config));
+
+	fd = open_config(path);
+	if (fd < 0)
+		return fd;
+
+	file = fdopen(fd, "r");
+	if (!file) {
+		ret = -errno;
+		close(fd);
+		return ret;
+	}
+
+	while ((len = getline(&line, &size, file)) >= 0) {
+		(void)len;
+		lineno++;
+		ret = parse_config_line(config, line, lineno);
+		if (ret)
+			break;
+	}
+	if (ferror(file) && !ret)
+		ret = -EIO;
+
+	free(line);
+	fclose(file);
+	return ret;
+}
+
+static void free_config(struct hdn_prompt_config *config)
+{
+	unsigned int i;
+	unsigned int j;
+
+	for (i = 0; i < config->count; i++) {
+		free(config->rules[i].name);
+		free(config->rules[i].intent);
+		for (j = 0; j < config->rules[i].argc; j++)
+			free(config->rules[i].args[j]);
+	}
+}
+
+static const struct hdn_prompt_rule *
+find_rule(const struct hdn_prompt_config *config, const char *action)
+{
+	unsigned int i;
+
+	for (i = 0; i < config->count; i++) {
+		if (!strcmp(config->rules[i].name, action))
+			return &config->rules[i];
+	}
+
+	return NULL;
+}
+
+static int read_token_path(int fd, char *token, size_t size)
+{
+	size_t done = 0;
+
+	while (done + 1 < size) {
+		ssize_t ret = read(fd, token + done, size - done - 1);
+
+		if (ret < 0) {
+			if (errno == EINTR)
+				continue;
+			return -errno;
+		}
+		if (!ret)
+			break;
+		done += (size_t)ret;
+	}
+	token[done] = '\0';
+
+	while (done && (token[done - 1] == '\n' ||
+			token[done - 1] == '\r' ||
+			token[done - 1] == ' ' ||
+			token[done - 1] == '\t'))
+		token[--done] = '\0';
+
+	if (!done || strchr(token, '\n'))
+		return -EINVAL;
+
+	return 0;
+}
+
+static int issue_token(const char *issuer, const char *intent,
+		       const char *token_dir, unsigned long long ttl_ms,
+		       char *token, size_t token_size)
+{
+	char ttl_text[32];
+	int pipefd[2];
+	int status;
+	pid_t child;
+	int ret;
+
+	if (snprintf(ttl_text, sizeof(ttl_text), "%llu", ttl_ms) >=
+	    (int)sizeof(ttl_text))
+		return 1;
+	if (pipe(pipefd)) {
+		fprintf(stderr, "hdn-prompt-dispatch: pipe failed: %s\n",
+			strerror(errno));
+		return 1;
+	}
+
+	child = fork();
+	if (child < 0) {
+		fprintf(stderr, "hdn-prompt-dispatch: fork failed: %s\n",
+			strerror(errno));
+		close(pipefd[0]);
+		close(pipefd[1]);
+		return 1;
+	}
+
+	if (!child) {
+		close(pipefd[0]);
+		if (dup2(pipefd[1], STDOUT_FILENO) < 0)
+			_exit(126);
+		close(pipefd[1]);
+		execl(issuer, "hdn-approval-token", "--dir", token_dir,
+		      "--intent", intent, "--ttl-ms", ttl_text, NULL);
+		fprintf(stderr, "hdn-prompt-dispatch: exec %s failed: %s\n",
+			issuer, strerror(errno));
+		_exit(errno == ENOENT ? 127 : 126);
+	}
+
+	close(pipefd[1]);
+	ret = read_token_path(pipefd[0], token, token_size);
+	close(pipefd[0]);
+
+	if (waitpid(child, &status, 0) < 0) {
+		fprintf(stderr, "hdn-prompt-dispatch: wait failed: %s\n",
+			strerror(errno));
+		return 1;
+	}
+	if (!WIFEXITED(status) || WEXITSTATUS(status)) {
+		if (WIFEXITED(status))
+			return WEXITSTATUS(status) ? WEXITSTATUS(status) : 1;
+		return 1;
+	}
+	if (ret) {
+		fprintf(stderr,
+			"hdn-prompt-dispatch: token issuer returned an invalid token path\n");
+		return 1;
+	}
+	if (require_safe_absolute("approval token", token))
+		return 1;
+
+	return 0;
+}
+
+static int run_rule(const char *broker, const char *token,
+		    const struct hdn_prompt_rule *rule)
+{
+	char **argv;
+	unsigned int argc = 0;
+	unsigned int i;
+
+	argv = calloc((size_t)rule->argc + 5, sizeof(*argv));
+	if (!argv) {
+		fprintf(stderr, "hdn-prompt-dispatch: allocation failed\n");
+		unlink(token);
+		return 1;
+	}
+
+	argv[argc++] = (char *)broker;
+	argv[argc++] = "--approval-token";
+	argv[argc++] = (char *)token;
+	argv[argc++] = rule->intent;
+	for (i = 0; i < rule->argc; i++)
+		argv[argc++] = rule->args[i];
+	argv[argc] = NULL;
+
+	execv(broker, argv);
+	fprintf(stderr, "hdn-prompt-dispatch: exec %s failed: %s\n",
+		broker, strerror(errno));
+	free(argv);
+	unlink(token);
+	return errno == ENOENT ? 127 : 126;
+}
+
+int main(int argc, char **argv)
+{
+	const char *config_path = HDN_PROMPT_DISPATCH_CONFIG;
+	const char *broker_path = HDN_ADMIN_BROKER_PATH;
+	const char *issuer_path = HDN_APPROVAL_TOKEN_PATH;
+	const char *token_dir = HDN_APPROVAL_TOKEN_DIR;
+	unsigned long long ttl_ms = HDN_PROMPT_TOKEN_TTL_DEFAULT_MS;
+	const struct hdn_prompt_rule *rule;
+	struct hdn_prompt_config config;
+	const char *action = NULL;
+	char token[PATH_MAX];
+	int ret = 0;
+	int i;
+
+	for (i = 1; i < argc; i++) {
+		if (!strcmp(argv[i], "--help")) {
+			usage(argv[0]);
+			return 0;
+		}
+		if (!strcmp(argv[i], "--config")) {
+			if (++i >= argc)
+				goto bad_args;
+			config_path = argv[i];
+			continue;
+		}
+		if (!strcmp(argv[i], "--broker")) {
+			if (++i >= argc)
+				goto bad_args;
+			broker_path = argv[i];
+			continue;
+		}
+		if (!strcmp(argv[i], "--token-issuer")) {
+			if (++i >= argc)
+				goto bad_args;
+			issuer_path = argv[i];
+			continue;
+		}
+		if (!strcmp(argv[i], "--token-dir")) {
+			if (++i >= argc)
+				goto bad_args;
+			token_dir = argv[i];
+			continue;
+		}
+		if (!strcmp(argv[i], "--ttl-ms")) {
+			if (++i >= argc || parse_u64(argv[i], &ttl_ms))
+				goto bad_args;
+			continue;
+		}
+		if (argv[i][0] == '-')
+			goto bad_args;
+		if (action)
+			goto bad_args;
+		action = argv[i];
+	}
+
+	if (!action || !safe_name(action))
+		goto bad_args;
+	if (geteuid() != 0) {
+		fprintf(stderr, "hdn-prompt-dispatch: must run as root\n");
+		return 1;
+	}
+	if (!ttl_ms || ttl_ms > HDN_PROMPT_TOKEN_TTL_MAX_MS) {
+		fprintf(stderr,
+			"hdn-prompt-dispatch: ttl-ms must be between 1 and %llu\n",
+			HDN_PROMPT_TOKEN_TTL_MAX_MS);
+		return 1;
+	}
+	if (require_safe_absolute("config", config_path) ||
+	    require_safe_absolute("broker", broker_path) ||
+	    require_safe_absolute("token issuer", issuer_path) ||
+	    require_safe_dir(token_dir))
+		return 1;
+
+	ret = load_config(config_path, &config);
+	if (ret)
+		return 1;
+
+	rule = find_rule(&config, action);
+	if (!rule) {
+		fprintf(stderr,
+			"hdn-prompt-dispatch: action is not product-approved: %s\n",
+			action);
+		free_config(&config);
+		return 1;
+	}
+
+	ret = issue_token(issuer_path, rule->intent, token_dir, ttl_ms, token,
+			  sizeof(token));
+	if (!ret)
+		ret = run_rule(broker_path, token, rule);
+	free_config(&config);
+	return ret;
+
+bad_args:
+	usage(argv[0]);
+	return 2;
+}
diff -urN linux-7.0.12/tools/hardening/hdn-prompt-portal.c linux-7.0.12-hdn/tools/hardening/hdn-prompt-portal.c
--- linux-7.0.12/tools/hardening/hdn-prompt-portal.c	1969-12-31 18:00:00.000000000 -0600
+++ linux-7.0.12-hdn/tools/hardening/hdn-prompt-portal.c	2026-06-25 19:48:04.286309168 -0500
@@ -0,0 +1,407 @@
+// SPDX-License-Identifier: GPL-2.0-only
+
+#define _GNU_SOURCE
+
+#include <errno.h>
+#include <fcntl.h>
+#include <stdbool.h>
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+#include <sys/stat.h>
+#include <sys/wait.h>
+#include <unistd.h>
+
+#ifndef HDN_PROMPT_PORTAL_CONFIG
+#define HDN_PROMPT_PORTAL_CONFIG "/etc/hdn/prompt-portal.conf"
+#endif
+
+#ifndef HDN_PROMPT_SESSION_PATH
+#define HDN_PROMPT_SESSION_PATH "/usr/libexec/hdn-prompt-session"
+#endif
+
+#define HDN_PROMPT_PORTAL_MAX_RULES 64
+
+struct hdn_prompt_portal_rule {
+	char *name;
+	char *session_action;
+};
+
+struct hdn_prompt_portal_config {
+	char *session_helper;
+	struct hdn_prompt_portal_rule rules[HDN_PROMPT_PORTAL_MAX_RULES];
+	unsigned int count;
+};
+
+static void usage(const char *prog)
+{
+	fprintf(stderr,
+		"Usage: %s [--config FILE] ACTION\n"
+		"\n"
+		"Runs a product-approved desktop prompt action.\n"
+		"Config lines:\n"
+		"  session-helper PATH\n"
+		"  action DESKTOP_ACTION PROMPT_SESSION_ACTION\n",
+		prog);
+}
+
+static char *trim(char *line)
+{
+	char *end;
+
+	while (*line == ' ' || *line == '\t' || *line == '\r' ||
+	       *line == '\n')
+		line++;
+
+	end = line + strlen(line);
+	while (end > line &&
+	       (end[-1] == ' ' || end[-1] == '\t' || end[-1] == '\r' ||
+		end[-1] == '\n'))
+		*--end = '\0';
+
+	return line;
+}
+
+static bool safe_name(const char *name)
+{
+	const char *p;
+
+	if (!name || !name[0] || !strcmp(name, ".") || !strcmp(name, ".."))
+		return false;
+
+	for (p = name; *p; p++) {
+		if ((*p >= 'A' && *p <= 'Z') ||
+		    (*p >= 'a' && *p <= 'z') ||
+		    (*p >= '0' && *p <= '9') ||
+		    *p == '.' || *p == '_' || *p == '-')
+			continue;
+		return false;
+	}
+
+	return true;
+}
+
+static bool path_has_dot_component(const char *path)
+{
+	const char *part = path;
+
+	while (*part) {
+		const char *slash;
+		size_t len;
+
+		while (*part == '/')
+			part++;
+		if (!*part)
+			break;
+
+		slash = strchr(part, '/');
+		len = slash ? (size_t)(slash - part) : strlen(part);
+		if ((len == 1 && part[0] == '.') ||
+		    (len == 2 && part[0] == '.' && part[1] == '.'))
+			return true;
+		part += len;
+	}
+
+	return false;
+}
+
+static int require_safe_absolute(const char *what, const char *path)
+{
+	if (!path || path[0] != '/') {
+		fprintf(stderr, "hdn-prompt-portal: %s must be absolute: %s\n",
+			what, path ? path : "(null)");
+		return -EINVAL;
+	}
+	if (!strcmp(path, "/")) {
+		fprintf(stderr,
+			"hdn-prompt-portal: %s / is too broad\n", what);
+		return -EINVAL;
+	}
+	if (path_has_dot_component(path)) {
+		fprintf(stderr,
+			"hdn-prompt-portal: %s must not contain . or .. path components: %s\n",
+			what, path);
+		return -EINVAL;
+	}
+
+	return 0;
+}
+
+static int replace_string(char **slot, const char *value)
+{
+	char *copy = strdup(value);
+
+	if (!copy)
+		return -ENOMEM;
+	free(*slot);
+	*slot = copy;
+	return 0;
+}
+
+static int set_session_helper(struct hdn_prompt_portal_config *config,
+			      char **tokens, unsigned int count,
+			      unsigned int lineno)
+{
+	if (count != 2) {
+		fprintf(stderr,
+			"hdn-prompt-portal: session-helper line %u needs exactly one path\n",
+			lineno);
+		return -EINVAL;
+	}
+	if (require_safe_absolute("session-helper", tokens[1]))
+		return -EINVAL;
+	return replace_string(&config->session_helper, tokens[1]);
+}
+
+static int add_action(struct hdn_prompt_portal_config *config, char **tokens,
+		      unsigned int count, unsigned int lineno)
+{
+	struct hdn_prompt_portal_rule *rule;
+
+	if (count != 3) {
+		fprintf(stderr,
+			"hdn-prompt-portal: action line %u needs DESKTOP_ACTION PROMPT_SESSION_ACTION\n",
+			lineno);
+		return -EINVAL;
+	}
+	if (config->count >= HDN_PROMPT_PORTAL_MAX_RULES) {
+		fprintf(stderr, "hdn-prompt-portal: too many action rules\n");
+		return -E2BIG;
+	}
+	if (!safe_name(tokens[1]) || !safe_name(tokens[2])) {
+		fprintf(stderr,
+			"hdn-prompt-portal: unsafe action name at line %u\n",
+			lineno);
+		return -EINVAL;
+	}
+
+	rule = &config->rules[config->count];
+	rule->name = strdup(tokens[1]);
+	rule->session_action = strdup(tokens[2]);
+	if (!rule->name || !rule->session_action)
+		return -ENOMEM;
+	config->count++;
+	return 0;
+}
+
+static int parse_config_line(struct hdn_prompt_portal_config *config,
+			     char *line, unsigned int lineno)
+{
+	char *tokens[3];
+	unsigned int count = 0;
+	char *save = NULL;
+	char *word;
+
+	line = trim(line);
+	if (!line[0] || line[0] == '#')
+		return 0;
+
+	for (word = strtok_r(line, " \t", &save); word;
+	     word = strtok_r(NULL, " \t", &save)) {
+		if (count >= sizeof(tokens) / sizeof(tokens[0])) {
+			fprintf(stderr,
+				"hdn-prompt-portal: too many fields at line %u\n",
+				lineno);
+			return -E2BIG;
+		}
+		tokens[count++] = word;
+	}
+
+	if (!count)
+		return 0;
+	if (!strcmp(tokens[0], "session-helper"))
+		return set_session_helper(config, tokens, count, lineno);
+	if (!strcmp(tokens[0], "action"))
+		return add_action(config, tokens, count, lineno);
+
+	fprintf(stderr, "hdn-prompt-portal: unknown config key at line %u: %s\n",
+		lineno, tokens[0]);
+	return -EINVAL;
+}
+
+static int open_config(const char *path)
+{
+	struct stat st;
+	int flags = O_RDONLY | O_CLOEXEC;
+	int fd;
+
+#ifdef O_NOFOLLOW
+	flags |= O_NOFOLLOW;
+#endif
+
+	fd = open(path, flags);
+	if (fd < 0) {
+		fprintf(stderr, "hdn-prompt-portal: cannot open %s: %s\n",
+			path, strerror(errno));
+		return -errno;
+	}
+
+	if (fstat(fd, &st)) {
+		int ret = -errno;
+
+		fprintf(stderr, "hdn-prompt-portal: cannot stat %s: %s\n",
+			path, strerror(errno));
+		close(fd);
+		return ret;
+	}
+
+	if (!S_ISREG(st.st_mode) || st.st_uid != 0 || (st.st_mode & 022)) {
+		fprintf(stderr,
+			"hdn-prompt-portal: refusing unsafe config %s\n",
+			path);
+		close(fd);
+		return -EACCES;
+	}
+
+	return fd;
+}
+
+static int load_config(const char *path,
+		       struct hdn_prompt_portal_config *config)
+{
+	char *line = NULL;
+	size_t size = 0;
+	unsigned int lineno = 0;
+	ssize_t len;
+	FILE *file;
+	int ret;
+	int fd;
+
+	memset(config, 0, sizeof(*config));
+
+	ret = replace_string(&config->session_helper, HDN_PROMPT_SESSION_PATH);
+	if (ret)
+		return ret;
+
+	fd = open_config(path);
+	if (fd < 0)
+		return fd;
+
+	file = fdopen(fd, "r");
+	if (!file) {
+		ret = -errno;
+		close(fd);
+		return ret;
+	}
+
+	while ((len = getline(&line, &size, file)) >= 0) {
+		(void)len;
+		lineno++;
+		ret = parse_config_line(config, line, lineno);
+		if (ret)
+			break;
+	}
+	if (ferror(file) && !ret)
+		ret = -EIO;
+
+	free(line);
+	fclose(file);
+	return ret;
+}
+
+static void free_config(struct hdn_prompt_portal_config *config)
+{
+	unsigned int i;
+
+	free(config->session_helper);
+	for (i = 0; i < config->count; i++) {
+		free(config->rules[i].name);
+		free(config->rules[i].session_action);
+	}
+}
+
+static const struct hdn_prompt_portal_rule *
+find_action(const struct hdn_prompt_portal_config *config, const char *action)
+{
+	unsigned int i;
+
+	for (i = 0; i < config->count; i++) {
+		if (!strcmp(config->rules[i].name, action))
+			return &config->rules[i];
+	}
+
+	return NULL;
+}
+
+static int child_status_result(pid_t child)
+{
+	int status;
+
+	if (waitpid(child, &status, 0) < 0)
+		return 1;
+	if (!WIFEXITED(status))
+		return 1;
+	return WEXITSTATUS(status);
+}
+
+static int run_prompt_session(const char *helper, const char *action)
+{
+	pid_t child;
+
+	child = fork();
+	if (child < 0) {
+		fprintf(stderr, "hdn-prompt-portal: fork failed: %s\n",
+			strerror(errno));
+		return 1;
+	}
+
+	if (!child) {
+		execl(helper, "hdn-prompt-session", action, NULL);
+		fprintf(stderr, "hdn-prompt-portal: exec %s failed: %s\n",
+			helper, strerror(errno));
+		_exit(errno == ENOENT ? 127 : 126);
+	}
+
+	return child_status_result(child);
+}
+
+int main(int argc, char **argv)
+{
+	struct hdn_prompt_portal_config config;
+	const struct hdn_prompt_portal_rule *rule;
+	const char *config_path = HDN_PROMPT_PORTAL_CONFIG;
+	const char *action = NULL;
+	int ret;
+	int i;
+
+	for (i = 1; i < argc; i++) {
+		if (!strcmp(argv[i], "--config")) {
+			if (++i >= argc) {
+				usage(argv[0]);
+				return 2;
+			}
+			config_path = argv[i];
+		} else if (!strcmp(argv[i], "-h") ||
+			   !strcmp(argv[i], "--help")) {
+			usage(argv[0]);
+			return 0;
+		} else if (!action) {
+			action = argv[i];
+		} else {
+			usage(argv[0]);
+			return 2;
+		}
+	}
+
+	if (!action || !safe_name(action)) {
+		usage(argv[0]);
+		return 2;
+	}
+
+	ret = load_config(config_path, &config);
+	if (ret)
+		return 1;
+
+	rule = find_action(&config, action);
+	if (!rule) {
+		fprintf(stderr,
+			"hdn-prompt-portal: action is not product-approved: %s\n",
+			action);
+		free_config(&config);
+		return 1;
+	}
+
+	ret = run_prompt_session(config.session_helper, rule->session_action);
+	free_config(&config);
+	return ret ? 1 : 0;
+}
diff -urN linux-7.0.12/tools/hardening/hdn-prompt-session.c linux-7.0.12-hdn/tools/hardening/hdn-prompt-session.c
--- linux-7.0.12/tools/hardening/hdn-prompt-session.c	1969-12-31 18:00:00.000000000 -0600
+++ linux-7.0.12-hdn/tools/hardening/hdn-prompt-session.c	2026-06-25 15:37:03.259739192 -0500
@@ -0,0 +1,648 @@
+// SPDX-License-Identifier: GPL-2.0-only
+
+#define _GNU_SOURCE
+
+#include <errno.h>
+#include <fcntl.h>
+#include <stdbool.h>
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+#include <sys/stat.h>
+#include <sys/wait.h>
+#include <unistd.h>
+
+#ifndef HDN_PROMPT_SESSION_CONFIG
+#define HDN_PROMPT_SESSION_CONFIG "/etc/hdn/prompt-session.conf"
+#endif
+
+#ifndef HDN_PROMPT_DESCRIBE_PATH
+#define HDN_PROMPT_DESCRIBE_PATH "/usr/libexec/hdn-prompt-describe"
+#endif
+
+#ifndef HDN_PROMPT_DISPATCH_PATH
+#define HDN_PROMPT_DISPATCH_PATH "/usr/libexec/hdn-prompt-dispatch"
+#endif
+
+#ifndef HDN_PROMPT_AUTH_PATH
+#define HDN_PROMPT_AUTH_PATH "/usr/libexec/hdn-auth-prompt"
+#endif
+
+#define HDN_PROMPT_SESSION_MAX_ARGS 16
+#define HDN_PROMPT_SESSION_MAX_METADATA 8192
+
+struct hdn_prompt_session_config {
+	char *describe_helper;
+	char *dispatch_helper;
+	char *auth_argv[HDN_PROMPT_SESSION_MAX_ARGS + 1];
+	unsigned int auth_argc;
+};
+
+static void usage(const char *prog)
+{
+	fprintf(stderr,
+		"Usage: %s [--config FILE] ACTION\n"
+		"\n"
+		"Runs a named prompt session: describe, authenticate, then dispatch.\n"
+		"Config lines:\n"
+		"  describe-helper PATH\n"
+		"  auth-helper PATH [ARG...]\n"
+		"  dispatch-helper PATH\n",
+		prog);
+}
+
+static char *trim(char *line)
+{
+	char *end;
+
+	while (*line == ' ' || *line == '\t' || *line == '\r' ||
+	       *line == '\n')
+		line++;
+
+	end = line + strlen(line);
+	while (end > line &&
+	       (end[-1] == ' ' || end[-1] == '\t' || end[-1] == '\r' ||
+		end[-1] == '\n'))
+		*--end = '\0';
+
+	return line;
+}
+
+static bool safe_name(const char *name)
+{
+	const char *p;
+
+	if (!name || !name[0] || !strcmp(name, ".") || !strcmp(name, ".."))
+		return false;
+
+	for (p = name; *p; p++) {
+		if ((*p >= 'A' && *p <= 'Z') ||
+		    (*p >= 'a' && *p <= 'z') ||
+		    (*p >= '0' && *p <= '9') ||
+		    *p == '.' || *p == '_' || *p == '-')
+			continue;
+		return false;
+	}
+
+	return true;
+}
+
+static bool path_has_dot_component(const char *path)
+{
+	const char *part = path;
+
+	while (*part) {
+		const char *slash;
+		size_t len;
+
+		while (*part == '/')
+			part++;
+		if (!*part)
+			break;
+
+		slash = strchr(part, '/');
+		len = slash ? (size_t)(slash - part) : strlen(part);
+		if ((len == 1 && part[0] == '.') ||
+		    (len == 2 && part[0] == '.' && part[1] == '.'))
+			return true;
+		part += len;
+	}
+
+	return false;
+}
+
+static int require_safe_absolute(const char *what, const char *path)
+{
+	if (!path || path[0] != '/') {
+		fprintf(stderr, "hdn-prompt-session: %s must be absolute: %s\n",
+			what, path ? path : "(null)");
+		return -EINVAL;
+	}
+	if (!strcmp(path, "/")) {
+		fprintf(stderr,
+			"hdn-prompt-session: %s / is too broad\n", what);
+		return -EINVAL;
+	}
+	if (path_has_dot_component(path)) {
+		fprintf(stderr,
+			"hdn-prompt-session: %s must not contain . or .. path components: %s\n",
+			what, path);
+		return -EINVAL;
+	}
+
+	return 0;
+}
+
+static int require_safe_arg(const char *arg, unsigned int lineno)
+{
+	const unsigned char *p;
+
+	if (!arg || !arg[0]) {
+		fprintf(stderr,
+			"hdn-prompt-session: empty helper argument at line %u\n",
+			lineno);
+		return -EINVAL;
+	}
+
+	for (p = (const unsigned char *)arg; *p; p++) {
+		if (*p >= 0x21 && *p <= 0x7e)
+			continue;
+		fprintf(stderr,
+			"hdn-prompt-session: unsafe helper argument at line %u\n",
+			lineno);
+		return -EINVAL;
+	}
+
+	return 0;
+}
+
+static int replace_string(char **slot, const char *value)
+{
+	char *copy = strdup(value);
+
+	if (!copy)
+		return -ENOMEM;
+	free(*slot);
+	*slot = copy;
+	return 0;
+}
+
+static int set_helper_path(char **slot, const char *kind, char **tokens,
+			   unsigned int count, unsigned int lineno)
+{
+	if (count != 2) {
+		fprintf(stderr,
+			"hdn-prompt-session: %s line %u needs exactly one path\n",
+			kind, lineno);
+		return -EINVAL;
+	}
+	if (require_safe_absolute(kind, tokens[1]))
+		return -EINVAL;
+	return replace_string(slot, tokens[1]);
+}
+
+static int set_auth_helper(struct hdn_prompt_session_config *config,
+			   char **tokens, unsigned int count,
+			   unsigned int lineno)
+{
+	unsigned int i;
+
+	if (count < 2) {
+		fprintf(stderr,
+			"hdn-prompt-session: auth-helper line %u needs PATH [ARG...]\n",
+			lineno);
+		return -EINVAL;
+	}
+	if (count > HDN_PROMPT_SESSION_MAX_ARGS) {
+		fprintf(stderr,
+			"hdn-prompt-session: too many auth-helper arguments at line %u\n",
+			lineno);
+		return -E2BIG;
+	}
+	if (require_safe_absolute("auth-helper", tokens[1]))
+		return -EINVAL;
+
+	for (i = 2; i < count; i++) {
+		if (require_safe_arg(tokens[i], lineno))
+			return -EINVAL;
+	}
+
+	for (i = 0; i < config->auth_argc; i++)
+		free(config->auth_argv[i]);
+	config->auth_argc = 0;
+
+	for (i = 1; i < count; i++) {
+		config->auth_argv[config->auth_argc] = strdup(tokens[i]);
+		if (!config->auth_argv[config->auth_argc])
+			return -ENOMEM;
+		config->auth_argc++;
+	}
+	config->auth_argv[config->auth_argc] = NULL;
+	return 0;
+}
+
+static int parse_config_line(struct hdn_prompt_session_config *config,
+			     char *line, unsigned int lineno)
+{
+	char *tokens[HDN_PROMPT_SESSION_MAX_ARGS + 1];
+	unsigned int count = 0;
+	char *save = NULL;
+	char *word;
+
+	line = trim(line);
+	if (!line[0] || line[0] == '#')
+		return 0;
+
+	for (word = strtok_r(line, " \t", &save); word;
+	     word = strtok_r(NULL, " \t", &save)) {
+		if (count >= sizeof(tokens) / sizeof(tokens[0])) {
+			fprintf(stderr,
+				"hdn-prompt-session: too many fields at line %u\n",
+				lineno);
+			return -E2BIG;
+		}
+		tokens[count++] = word;
+	}
+
+	if (!count)
+		return 0;
+	if (!strcmp(tokens[0], "describe-helper"))
+		return set_helper_path(&config->describe_helper,
+				       "describe-helper", tokens, count,
+				       lineno);
+	if (!strcmp(tokens[0], "dispatch-helper"))
+		return set_helper_path(&config->dispatch_helper,
+				       "dispatch-helper", tokens, count,
+				       lineno);
+	if (!strcmp(tokens[0], "auth-helper"))
+		return set_auth_helper(config, tokens, count, lineno);
+
+	fprintf(stderr, "hdn-prompt-session: unknown config key at line %u: %s\n",
+		lineno, tokens[0]);
+	return -EINVAL;
+}
+
+static int open_config(const char *path)
+{
+	struct stat st;
+	int flags = O_RDONLY | O_CLOEXEC;
+	int fd;
+
+#ifdef O_NOFOLLOW
+	flags |= O_NOFOLLOW;
+#endif
+
+	fd = open(path, flags);
+	if (fd < 0) {
+		fprintf(stderr, "hdn-prompt-session: cannot open %s: %s\n",
+			path, strerror(errno));
+		return -errno;
+	}
+
+	if (fstat(fd, &st)) {
+		int ret = -errno;
+
+		fprintf(stderr, "hdn-prompt-session: cannot stat %s: %s\n",
+			path, strerror(errno));
+		close(fd);
+		return ret;
+	}
+
+	if (!S_ISREG(st.st_mode) || st.st_uid != 0 || (st.st_mode & 022)) {
+		fprintf(stderr,
+			"hdn-prompt-session: refusing unsafe config %s\n",
+			path);
+		close(fd);
+		return -EACCES;
+	}
+
+	return fd;
+}
+
+static int load_config(const char *path,
+		       struct hdn_prompt_session_config *config)
+{
+	char *line = NULL;
+	size_t size = 0;
+	unsigned int lineno = 0;
+	ssize_t len;
+	FILE *file;
+	int ret = 0;
+	int fd;
+
+	memset(config, 0, sizeof(*config));
+
+	ret = replace_string(&config->describe_helper, HDN_PROMPT_DESCRIBE_PATH);
+	if (ret)
+		return ret;
+	ret = replace_string(&config->dispatch_helper, HDN_PROMPT_DISPATCH_PATH);
+	if (ret)
+		return ret;
+	config->auth_argv[0] = strdup(HDN_PROMPT_AUTH_PATH);
+	if (!config->auth_argv[0])
+		return -ENOMEM;
+	config->auth_argc = 1;
+
+	fd = open_config(path);
+	if (fd < 0)
+		return fd;
+
+	file = fdopen(fd, "r");
+	if (!file) {
+		ret = -errno;
+		close(fd);
+		return ret;
+	}
+
+	while ((len = getline(&line, &size, file)) >= 0) {
+		(void)len;
+		lineno++;
+		ret = parse_config_line(config, line, lineno);
+		if (ret)
+			break;
+	}
+	if (ferror(file) && !ret)
+		ret = -EIO;
+
+	free(line);
+	fclose(file);
+	return ret;
+}
+
+static void free_config(struct hdn_prompt_session_config *config)
+{
+	unsigned int i;
+
+	free(config->describe_helper);
+	free(config->dispatch_helper);
+	for (i = 0; i < config->auth_argc; i++)
+		free(config->auth_argv[i]);
+}
+
+static int child_status_result(pid_t child)
+{
+	int status;
+
+	if (waitpid(child, &status, 0) < 0)
+		return 1;
+	if (!WIFEXITED(status))
+		return 1;
+	return WEXITSTATUS(status);
+}
+
+static int read_metadata_from_describe(const char *helper, const char *action,
+				       char **metadata)
+{
+	char buf[HDN_PROMPT_SESSION_MAX_METADATA + 1];
+	size_t done = 0;
+	int pipefd[2];
+	pid_t child;
+	int status;
+
+	if (pipe(pipefd)) {
+		fprintf(stderr, "hdn-prompt-session: pipe failed: %s\n",
+			strerror(errno));
+		return 1;
+	}
+
+	child = fork();
+	if (child < 0) {
+		fprintf(stderr, "hdn-prompt-session: fork failed: %s\n",
+			strerror(errno));
+		close(pipefd[0]);
+		close(pipefd[1]);
+		return 1;
+	}
+
+	if (!child) {
+		close(pipefd[0]);
+		if (dup2(pipefd[1], STDOUT_FILENO) < 0)
+			_exit(126);
+		close(pipefd[1]);
+		execl(helper, "hdn-prompt-describe", action, NULL);
+		fprintf(stderr, "hdn-prompt-session: exec %s failed: %s\n",
+			helper, strerror(errno));
+		_exit(errno == ENOENT ? 127 : 126);
+	}
+
+	close(pipefd[1]);
+	for (;;) {
+		ssize_t len;
+
+		len = read(pipefd[0], buf + done,
+			   HDN_PROMPT_SESSION_MAX_METADATA - done);
+		if (len < 0) {
+			if (errno == EINTR)
+				continue;
+			fprintf(stderr,
+				"hdn-prompt-session: read prompt metadata failed: %s\n",
+				strerror(errno));
+			close(pipefd[0]);
+			(void)child_status_result(child);
+			return 1;
+		}
+		if (!len)
+			break;
+		done += (size_t)len;
+		if (done == HDN_PROMPT_SESSION_MAX_METADATA) {
+			fprintf(stderr,
+				"hdn-prompt-session: prompt metadata too large\n");
+			close(pipefd[0]);
+			(void)child_status_result(child);
+			return 1;
+		}
+	}
+	close(pipefd[0]);
+
+	status = child_status_result(child);
+	if (status)
+		return status;
+	if (!done) {
+		fprintf(stderr, "hdn-prompt-session: empty prompt metadata\n");
+		return 1;
+	}
+
+	buf[done] = '\0';
+	*metadata = strdup(buf);
+	if (!*metadata)
+		return 1;
+	return 0;
+}
+
+static bool metadata_has_line(const char *metadata, const char *line)
+{
+	const char *match = metadata;
+	size_t line_len = strlen(line);
+
+	while ((match = strstr(match, line))) {
+		if ((match == metadata || match[-1] == '\n') &&
+		    match[line_len] == '\n')
+			return true;
+		match += line_len;
+	}
+
+	return false;
+}
+
+static int validate_metadata(const char *metadata, const char *action)
+{
+	char expected[256];
+
+	if (!metadata_has_line(metadata, "HDN_PROMPT_METADATA_V1")) {
+		fprintf(stderr,
+			"hdn-prompt-session: prompt metadata missing magic\n");
+		return 1;
+	}
+	if (snprintf(expected, sizeof(expected), "action=%s", action) >=
+	    (int)sizeof(expected)) {
+		fprintf(stderr, "hdn-prompt-session: action name too long\n");
+		return 1;
+	}
+	if (!metadata_has_line(metadata, expected)) {
+		fprintf(stderr,
+			"hdn-prompt-session: prompt metadata action mismatch\n");
+		return 1;
+	}
+
+	return 0;
+}
+
+static int write_all(int fd, const char *buf, size_t size)
+{
+	size_t done = 0;
+
+	while (done < size) {
+		ssize_t ret = write(fd, buf + done, size - done);
+
+		if (ret < 0) {
+			if (errno == EINTR)
+				continue;
+			return -errno;
+		}
+		if (!ret)
+			return -EIO;
+		done += (size_t)ret;
+	}
+
+	return 0;
+}
+
+static int run_auth_helper(const struct hdn_prompt_session_config *config,
+			   const char *action, const char *metadata)
+{
+	char *argv[HDN_PROMPT_SESSION_MAX_ARGS + 2];
+	int pipefd[2];
+	unsigned int i;
+	pid_t child;
+	int write_ret;
+	int status;
+
+	if (pipe(pipefd)) {
+		fprintf(stderr, "hdn-prompt-session: pipe failed: %s\n",
+			strerror(errno));
+		return 1;
+	}
+
+	child = fork();
+	if (child < 0) {
+		fprintf(stderr, "hdn-prompt-session: fork failed: %s\n",
+			strerror(errno));
+		close(pipefd[0]);
+		close(pipefd[1]);
+		return 1;
+	}
+
+	if (!child) {
+		close(pipefd[1]);
+		if (dup2(pipefd[0], STDIN_FILENO) < 0)
+			_exit(126);
+		close(pipefd[0]);
+		for (i = 0; i < config->auth_argc; i++)
+			argv[i] = config->auth_argv[i];
+		argv[config->auth_argc] = (char *)action;
+		argv[config->auth_argc + 1] = NULL;
+		execv(config->auth_argv[0], argv);
+		fprintf(stderr, "hdn-prompt-session: exec %s failed: %s\n",
+			config->auth_argv[0], strerror(errno));
+		_exit(errno == ENOENT ? 127 : 126);
+	}
+
+	close(pipefd[0]);
+	write_ret = write_all(pipefd[1], metadata, strlen(metadata));
+	close(pipefd[1]);
+	status = child_status_result(child);
+	if (write_ret && !status) {
+		fprintf(stderr,
+			"hdn-prompt-session: auth helper input failed: %s\n",
+			strerror(-write_ret));
+		return 1;
+	}
+	return status ? 1 : 0;
+}
+
+static int run_dispatch_helper(const char *helper, const char *action)
+{
+	pid_t child;
+
+	child = fork();
+	if (child < 0) {
+		fprintf(stderr, "hdn-prompt-session: fork failed: %s\n",
+			strerror(errno));
+		return 1;
+	}
+
+	if (!child) {
+		execl(helper, "hdn-prompt-dispatch", action, NULL);
+		fprintf(stderr, "hdn-prompt-session: exec %s failed: %s\n",
+			helper, strerror(errno));
+		_exit(errno == ENOENT ? 127 : 126);
+	}
+
+	return child_status_result(child);
+}
+
+int main(int argc, char **argv)
+{
+	struct hdn_prompt_session_config config;
+	const char *config_path = HDN_PROMPT_SESSION_CONFIG;
+	const char *action = NULL;
+	char *metadata = NULL;
+	int ret;
+	int i;
+
+	for (i = 1; i < argc; i++) {
+		if (!strcmp(argv[i], "--config")) {
+			if (++i >= argc) {
+				usage(argv[0]);
+				return 2;
+			}
+			config_path = argv[i];
+		} else if (!strcmp(argv[i], "-h") ||
+			   !strcmp(argv[i], "--help")) {
+			usage(argv[0]);
+			return 0;
+		} else if (!action) {
+			action = argv[i];
+		} else {
+			usage(argv[0]);
+			return 2;
+		}
+	}
+
+	if (!action || !safe_name(action)) {
+		usage(argv[0]);
+		return 2;
+	}
+
+	ret = load_config(config_path, &config);
+	if (ret)
+		return 1;
+
+	ret = read_metadata_from_describe(config.describe_helper, action,
+					  &metadata);
+	if (ret)
+		goto out;
+
+	ret = validate_metadata(metadata, action);
+	if (ret)
+		goto out;
+
+	ret = run_auth_helper(&config, action, metadata);
+	if (ret) {
+		fprintf(stderr,
+			"hdn-prompt-session: prompt authentication denied: %s\n",
+			action);
+		goto out;
+	}
+
+	ret = run_dispatch_helper(config.dispatch_helper, action);
+	if (ret)
+		fprintf(stderr,
+			"hdn-prompt-session: prompt dispatch failed for %s\n",
+			action);
+
+out:
+	free(metadata);
+	free_config(&config);
+	return ret ? 1 : 0;
+}
diff -urN linux-7.0.12/tools/hardening/hdn-recovery-action.c linux-7.0.12-hdn/tools/hardening/hdn-recovery-action.c
--- linux-7.0.12/tools/hardening/hdn-recovery-action.c	1969-12-31 18:00:00.000000000 -0600
+++ linux-7.0.12-hdn/tools/hardening/hdn-recovery-action.c	2026-06-25 14:45:56.003761215 -0500
@@ -0,0 +1,425 @@
+// SPDX-License-Identifier: GPL-2.0-only
+
+#define _GNU_SOURCE
+
+#include <errno.h>
+#include <fcntl.h>
+#include <stdbool.h>
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+#include <sys/stat.h>
+#include <unistd.h>
+
+#ifndef HDN_RECOVERY_ACTION_CONFIG
+#define HDN_RECOVERY_ACTION_CONFIG "/etc/hdn/recovery-actions.conf"
+#endif
+
+#ifndef HDN_ADMIN_BROKER_PATH
+#define HDN_ADMIN_BROKER_PATH "/usr/libexec/hdn-admin-broker"
+#endif
+
+#ifndef HDN_SYSTEM_TRANSACTION_PATH
+#define HDN_SYSTEM_TRANSACTION_PATH "/usr/libexec/hdn-system-transaction"
+#endif
+
+#define HDN_RECOVERY_MAX_RULES 64
+
+enum hdn_recovery_backend {
+	HDN_RECOVERY_POLICY_ROLLBACK,
+	HDN_RECOVERY_SYSTEM_TRANSACTION,
+};
+
+struct hdn_recovery_rule {
+	char *name;
+	enum hdn_recovery_backend backend;
+	char *argument;
+};
+
+struct hdn_recovery_config {
+	struct hdn_recovery_rule rules[HDN_RECOVERY_MAX_RULES];
+	unsigned int count;
+};
+
+static void usage(const char *prog)
+{
+	fprintf(stderr,
+		"Usage: %s [--config FILE] [--broker PATH] [--system-transaction PATH] ACTION\n"
+		"\n"
+		"Runs a product-approved recovery action.\n"
+		"Config lines:\n"
+		"  action NAME policy-rollback\n"
+		"  action NAME system-transaction TRANSACTION\n",
+		prog);
+}
+
+static char *trim(char *line)
+{
+	char *end;
+
+	while (*line == ' ' || *line == '\t' || *line == '\r' ||
+	       *line == '\n')
+		line++;
+
+	end = line + strlen(line);
+	while (end > line &&
+	       (end[-1] == ' ' || end[-1] == '\t' || end[-1] == '\r' ||
+		end[-1] == '\n'))
+		*--end = '\0';
+
+	return line;
+}
+
+static bool path_has_dot_component(const char *path)
+{
+	const char *part = path;
+
+	while (*part) {
+		const char *slash;
+		size_t len;
+
+		while (*part == '/')
+			part++;
+		if (!*part)
+			break;
+
+		slash = strchr(part, '/');
+		len = slash ? (size_t)(slash - part) : strlen(part);
+		if ((len == 1 && part[0] == '.') ||
+		    (len == 2 && part[0] == '.' && part[1] == '.'))
+			return true;
+		part += len;
+	}
+
+	return false;
+}
+
+static int require_safe_absolute(const char *what, const char *path)
+{
+	if (!path || path[0] != '/') {
+		fprintf(stderr,
+			"hdn-recovery-action: %s must be absolute: %s\n",
+			what, path ? path : "(null)");
+		return -EINVAL;
+	}
+	if (path_has_dot_component(path)) {
+		fprintf(stderr,
+			"hdn-recovery-action: %s must not contain . or .. path components: %s\n",
+			what, path);
+		return -EINVAL;
+	}
+
+	return 0;
+}
+
+static bool safe_name(const char *name)
+{
+	const char *p;
+
+	if (!name || !name[0] || !strcmp(name, ".") || !strcmp(name, ".."))
+		return false;
+
+	for (p = name; *p; p++) {
+		if ((*p >= 'A' && *p <= 'Z') ||
+		    (*p >= 'a' && *p <= 'z') ||
+		    (*p >= '0' && *p <= '9') ||
+		    *p == '.' || *p == '_' || *p == '-')
+			continue;
+		return false;
+	}
+
+	return true;
+}
+
+static int add_rule(struct hdn_recovery_config *config, char **tokens,
+		    unsigned int count, unsigned int lineno)
+{
+	struct hdn_recovery_rule *rule;
+
+	if (count < 3) {
+		fprintf(stderr,
+			"hdn-recovery-action: action line %u needs NAME BACKEND\n",
+			lineno);
+		return -EINVAL;
+	}
+	if (config->count >= HDN_RECOVERY_MAX_RULES) {
+		fprintf(stderr,
+			"hdn-recovery-action: too many recovery actions\n");
+		return -E2BIG;
+	}
+	if (!safe_name(tokens[1])) {
+		fprintf(stderr,
+			"hdn-recovery-action: unsafe action name at line %u: %s\n",
+			lineno, tokens[1]);
+		return -EINVAL;
+	}
+
+	rule = &config->rules[config->count];
+	rule->name = strdup(tokens[1]);
+	if (!rule->name)
+		return -ENOMEM;
+
+	if (!strcmp(tokens[2], "policy-rollback")) {
+		if (count != 3) {
+			fprintf(stderr,
+				"hdn-recovery-action: policy-rollback takes no argument at line %u\n",
+				lineno);
+			return -EINVAL;
+		}
+		rule->backend = HDN_RECOVERY_POLICY_ROLLBACK;
+	} else if (!strcmp(tokens[2], "system-transaction")) {
+		if (count != 4 || !safe_name(tokens[3])) {
+			fprintf(stderr,
+				"hdn-recovery-action: invalid system transaction at line %u\n",
+				lineno);
+			return -EINVAL;
+		}
+		rule->backend = HDN_RECOVERY_SYSTEM_TRANSACTION;
+		rule->argument = strdup(tokens[3]);
+		if (!rule->argument)
+			return -ENOMEM;
+	} else {
+		fprintf(stderr,
+			"hdn-recovery-action: unknown backend at line %u: %s\n",
+			lineno, tokens[2]);
+		return -EINVAL;
+	}
+
+	config->count++;
+	return 0;
+}
+
+static int parse_config_line(struct hdn_recovery_config *config, char *line,
+			     unsigned int lineno)
+{
+	char *tokens[5];
+	unsigned int count = 0;
+	char *save = NULL;
+	char *word;
+
+	line = trim(line);
+	if (!line[0] || line[0] == '#')
+		return 0;
+
+	for (word = strtok_r(line, " \t", &save); word;
+	     word = strtok_r(NULL, " \t", &save)) {
+		if (count >= sizeof(tokens) / sizeof(tokens[0])) {
+			fprintf(stderr,
+				"hdn-recovery-action: too many fields at line %u\n",
+				lineno);
+			return -E2BIG;
+		}
+		tokens[count++] = word;
+	}
+
+	if (!count)
+		return 0;
+	if (strcmp(tokens[0], "action")) {
+		fprintf(stderr,
+			"hdn-recovery-action: unknown config key at line %u: %s\n",
+			lineno, tokens[0]);
+		return -EINVAL;
+	}
+
+	return add_rule(config, tokens, count, lineno);
+}
+
+static int open_config(const char *path)
+{
+	struct stat st;
+	int flags = O_RDONLY | O_CLOEXEC;
+	int fd;
+
+#ifdef O_NOFOLLOW
+	flags |= O_NOFOLLOW;
+#endif
+
+	fd = open(path, flags);
+	if (fd < 0) {
+		fprintf(stderr, "hdn-recovery-action: cannot open %s: %s\n",
+			path, strerror(errno));
+		return -errno;
+	}
+
+	if (fstat(fd, &st)) {
+		int ret = -errno;
+
+		fprintf(stderr, "hdn-recovery-action: cannot stat %s: %s\n",
+			path, strerror(errno));
+		close(fd);
+		return ret;
+	}
+
+	if (!S_ISREG(st.st_mode) || st.st_uid != 0 || (st.st_mode & 022)) {
+		fprintf(stderr,
+			"hdn-recovery-action: refusing unsafe config %s\n",
+			path);
+		close(fd);
+		return -EACCES;
+	}
+
+	return fd;
+}
+
+static int load_config(const char *path, struct hdn_recovery_config *config)
+{
+	char *line = NULL;
+	size_t size = 0;
+	unsigned int lineno = 0;
+	ssize_t len;
+	FILE *file;
+	int ret = 0;
+	int fd;
+
+	memset(config, 0, sizeof(*config));
+
+	fd = open_config(path);
+	if (fd < 0)
+		return fd;
+
+	file = fdopen(fd, "r");
+	if (!file) {
+		ret = -errno;
+		close(fd);
+		return ret;
+	}
+
+	while ((len = getline(&line, &size, file)) >= 0) {
+		(void)len;
+		lineno++;
+		ret = parse_config_line(config, line, lineno);
+		if (ret)
+			break;
+	}
+	if (ferror(file) && !ret)
+		ret = -EIO;
+
+	free(line);
+	fclose(file);
+	return ret;
+}
+
+static void free_config(struct hdn_recovery_config *config)
+{
+	unsigned int i;
+
+	for (i = 0; i < config->count; i++) {
+		free(config->rules[i].name);
+		free(config->rules[i].argument);
+	}
+}
+
+static const struct hdn_recovery_rule *
+find_rule(const struct hdn_recovery_config *config, const char *action)
+{
+	unsigned int i;
+
+	for (i = 0; i < config->count; i++) {
+		if (!strcmp(config->rules[i].name, action))
+			return &config->rules[i];
+	}
+
+	return NULL;
+}
+
+static int run_rule(const char *broker, const char *system_transaction,
+		    const struct hdn_recovery_rule *rule)
+{
+	if (rule->backend == HDN_RECOVERY_POLICY_ROLLBACK) {
+		char *const argv[] = {
+			(char *)broker,
+			"policy-rollback",
+			NULL,
+		};
+
+		execv(broker, argv);
+		fprintf(stderr, "hdn-recovery-action: exec %s failed: %s\n",
+			broker, strerror(errno));
+		return errno == ENOENT ? 127 : 126;
+	}
+
+	if (rule->backend == HDN_RECOVERY_SYSTEM_TRANSACTION) {
+		char *const argv[] = {
+			(char *)system_transaction,
+			rule->argument,
+			NULL,
+		};
+
+		execv(system_transaction, argv);
+		fprintf(stderr, "hdn-recovery-action: exec %s failed: %s\n",
+			system_transaction, strerror(errno));
+		return errno == ENOENT ? 127 : 126;
+	}
+
+	return 1;
+}
+
+int main(int argc, char **argv)
+{
+	const char *config_path = HDN_RECOVERY_ACTION_CONFIG;
+	const char *broker_path = HDN_ADMIN_BROKER_PATH;
+	const char *system_transaction_path = HDN_SYSTEM_TRANSACTION_PATH;
+	const char *action = NULL;
+	const struct hdn_recovery_rule *rule;
+	struct hdn_recovery_config config;
+	int ret = 0;
+	int i;
+
+	for (i = 1; i < argc; i++) {
+		if (!strcmp(argv[i], "--help")) {
+			usage(argv[0]);
+			return 0;
+		}
+		if (!strcmp(argv[i], "--config")) {
+			if (++i >= argc)
+				goto bad_args;
+			config_path = argv[i];
+			continue;
+		}
+		if (!strcmp(argv[i], "--broker")) {
+			if (++i >= argc)
+				goto bad_args;
+			broker_path = argv[i];
+			continue;
+		}
+		if (!strcmp(argv[i], "--system-transaction")) {
+			if (++i >= argc)
+				goto bad_args;
+			system_transaction_path = argv[i];
+			continue;
+		}
+		if (argv[i][0] == '-')
+			goto bad_args;
+		if (action)
+			goto bad_args;
+		action = argv[i];
+	}
+
+	if (!action || !safe_name(action))
+		goto bad_args;
+	if (require_safe_absolute("config", config_path) ||
+	    require_safe_absolute("broker", broker_path) ||
+	    require_safe_absolute("system transaction", system_transaction_path))
+		return 1;
+
+	ret = load_config(config_path, &config);
+	if (ret)
+		return 1;
+
+	rule = find_rule(&config, action);
+	if (!rule) {
+		fprintf(stderr,
+			"hdn-recovery-action: action is not product-approved: %s\n",
+			action);
+		free_config(&config);
+		return 1;
+	}
+
+	ret = run_rule(broker_path, system_transaction_path, rule);
+	free_config(&config);
+	return ret;
+
+bad_args:
+	usage(argv[0]);
+	return 2;
+}
diff -urN linux-7.0.12/tools/hardening/hdn-recovery-describe.c linux-7.0.12-hdn/tools/hardening/hdn-recovery-describe.c
--- linux-7.0.12/tools/hardening/hdn-recovery-describe.c	1969-12-31 18:00:00.000000000 -0600
+++ linux-7.0.12-hdn/tools/hardening/hdn-recovery-describe.c	2026-06-25 15:43:51.760763152 -0500
@@ -0,0 +1,416 @@
+// SPDX-License-Identifier: GPL-2.0-only
+
+#define _GNU_SOURCE
+
+#include <errno.h>
+#include <fcntl.h>
+#include <stdbool.h>
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+#include <sys/stat.h>
+#include <unistd.h>
+
+#ifndef HDN_RECOVERY_METADATA_CONFIG
+#define HDN_RECOVERY_METADATA_CONFIG "/etc/hdn/recovery-metadata.conf"
+#endif
+
+#define HDN_RECOVERY_METADATA_MAX_ACTIONS 64
+#define HDN_RECOVERY_METADATA_MAX_VALUE 512
+
+struct hdn_recovery_metadata {
+	char *name;
+	char *title;
+	char *message;
+	char *consequence;
+	char *risk;
+};
+
+struct hdn_recovery_metadata_config {
+	struct hdn_recovery_metadata actions[HDN_RECOVERY_METADATA_MAX_ACTIONS];
+	unsigned int count;
+};
+
+static void usage(const char *prog)
+{
+	fprintf(stderr,
+		"Usage: %s [--config FILE] ACTION\n"
+		"\n"
+		"Prints product-approved recovery metadata for a named action.\n"
+		"Config lines: recovery NAME FIELD VALUE\n"
+		"Known fields: title, message, consequence, risk\n",
+		prog);
+}
+
+static char *trim(char *line)
+{
+	char *end;
+
+	while (*line == ' ' || *line == '\t' || *line == '\r' ||
+	       *line == '\n')
+		line++;
+
+	end = line + strlen(line);
+	while (end > line &&
+	       (end[-1] == ' ' || end[-1] == '\t' || end[-1] == '\r' ||
+		end[-1] == '\n'))
+		*--end = '\0';
+
+	return line;
+}
+
+static char *next_word(char **cursor)
+{
+	char *word;
+	char *end;
+
+	*cursor = trim(*cursor);
+	if (!(*cursor)[0])
+		return NULL;
+
+	word = *cursor;
+	end = strpbrk(word, " \t");
+	if (!end) {
+		*cursor = word + strlen(word);
+		return word;
+	}
+
+	*end++ = '\0';
+	*cursor = end;
+	return word;
+}
+
+static bool safe_name(const char *name)
+{
+	const char *p;
+
+	if (!name || !name[0] || !strcmp(name, ".") || !strcmp(name, ".."))
+		return false;
+
+	for (p = name; *p; p++) {
+		if ((*p >= 'A' && *p <= 'Z') ||
+		    (*p >= 'a' && *p <= 'z') ||
+		    (*p >= '0' && *p <= '9') ||
+		    *p == '.' || *p == '_' || *p == '-')
+			continue;
+		return false;
+	}
+
+	return true;
+}
+
+static int require_safe_text(const char *field, const char *value,
+			     unsigned int lineno)
+{
+	const unsigned char *p;
+	size_t len;
+
+	if (!value || !value[0]) {
+		fprintf(stderr,
+			"hdn-recovery-describe: missing %s text at line %u\n",
+			field, lineno);
+		return -EINVAL;
+	}
+
+	len = strlen(value);
+	if (len > HDN_RECOVERY_METADATA_MAX_VALUE) {
+		fprintf(stderr,
+			"hdn-recovery-describe: %s text too long at line %u\n",
+			field, lineno);
+		return -E2BIG;
+	}
+
+	for (p = (const unsigned char *)value; *p; p++) {
+		if (*p >= 0x20 && *p <= 0x7e)
+			continue;
+		fprintf(stderr,
+			"hdn-recovery-describe: unsafe %s text at line %u\n",
+			field, lineno);
+		return -EINVAL;
+	}
+
+	return 0;
+}
+
+static struct hdn_recovery_metadata *
+find_metadata(struct hdn_recovery_metadata_config *config, const char *name)
+{
+	unsigned int i;
+
+	for (i = 0; i < config->count; i++) {
+		if (!strcmp(config->actions[i].name, name))
+			return &config->actions[i];
+	}
+
+	return NULL;
+}
+
+static struct hdn_recovery_metadata *
+find_or_add_metadata(struct hdn_recovery_metadata_config *config,
+		     const char *name)
+{
+	struct hdn_recovery_metadata *meta;
+
+	meta = find_metadata(config, name);
+	if (meta)
+		return meta;
+
+	if (config->count >= HDN_RECOVERY_METADATA_MAX_ACTIONS) {
+		fprintf(stderr,
+			"hdn-recovery-describe: too many recovery metadata actions\n");
+		errno = E2BIG;
+		return NULL;
+	}
+
+	meta = &config->actions[config->count];
+	meta->name = strdup(name);
+	if (!meta->name) {
+		errno = ENOMEM;
+		return NULL;
+	}
+
+	config->count++;
+	return meta;
+}
+
+static int set_field(char **slot, const char *field, const char *value,
+		     unsigned int lineno)
+{
+	char *copy;
+	int ret;
+
+	if (*slot) {
+		fprintf(stderr,
+			"hdn-recovery-describe: duplicate %s field at line %u\n",
+			field, lineno);
+		return -EINVAL;
+	}
+
+	ret = require_safe_text(field, value, lineno);
+	if (ret)
+		return ret;
+
+	copy = strdup(value);
+	if (!copy)
+		return -ENOMEM;
+
+	*slot = copy;
+	return 0;
+}
+
+static int parse_config_line(struct hdn_recovery_metadata_config *config,
+			     char *line, unsigned int lineno)
+{
+	struct hdn_recovery_metadata *meta;
+	char *cursor;
+	char *key;
+	char *name;
+	char *field;
+	char *value;
+
+	cursor = trim(line);
+	if (!cursor[0] || cursor[0] == '#')
+		return 0;
+
+	key = next_word(&cursor);
+	name = next_word(&cursor);
+	field = next_word(&cursor);
+	value = trim(cursor);
+
+	if (!key || strcmp(key, "recovery")) {
+		fprintf(stderr,
+			"hdn-recovery-describe: unknown config key at line %u: %s\n",
+			lineno, key ? key : "(null)");
+		return -EINVAL;
+	}
+	if (!name || !field || !value[0]) {
+		fprintf(stderr,
+			"hdn-recovery-describe: recovery line %u needs NAME FIELD VALUE\n",
+			lineno);
+		return -EINVAL;
+	}
+	if (!safe_name(name)) {
+		fprintf(stderr,
+			"hdn-recovery-describe: unsafe action name at line %u: %s\n",
+			lineno, name);
+		return -EINVAL;
+	}
+
+	meta = find_or_add_metadata(config, name);
+	if (!meta)
+		return -errno;
+
+	if (!strcmp(field, "title"))
+		return set_field(&meta->title, field, value, lineno);
+	if (!strcmp(field, "message"))
+		return set_field(&meta->message, field, value, lineno);
+	if (!strcmp(field, "consequence"))
+		return set_field(&meta->consequence, field, value, lineno);
+	if (!strcmp(field, "risk"))
+		return set_field(&meta->risk, field, value, lineno);
+
+	fprintf(stderr,
+		"hdn-recovery-describe: unknown recovery metadata field at line %u: %s\n",
+		lineno, field);
+	return -EINVAL;
+}
+
+static int open_config(const char *path)
+{
+	struct stat st;
+	int flags = O_RDONLY | O_CLOEXEC;
+	int fd;
+
+#ifdef O_NOFOLLOW
+	flags |= O_NOFOLLOW;
+#endif
+
+	fd = open(path, flags);
+	if (fd < 0) {
+		fprintf(stderr, "hdn-recovery-describe: cannot open %s: %s\n",
+			path, strerror(errno));
+		return -errno;
+	}
+
+	if (fstat(fd, &st)) {
+		int ret = -errno;
+
+		fprintf(stderr, "hdn-recovery-describe: cannot stat %s: %s\n",
+			path, strerror(errno));
+		close(fd);
+		return ret;
+	}
+
+	if (!S_ISREG(st.st_mode) || st.st_uid != 0 || (st.st_mode & 022)) {
+		fprintf(stderr,
+			"hdn-recovery-describe: refusing unsafe config %s\n",
+			path);
+		close(fd);
+		return -EACCES;
+	}
+
+	return fd;
+}
+
+static int load_config(const char *path,
+		       struct hdn_recovery_metadata_config *config)
+{
+	char *line = NULL;
+	size_t size = 0;
+	unsigned int lineno = 0;
+	ssize_t len;
+	FILE *file;
+	int ret = 0;
+	int fd;
+
+	memset(config, 0, sizeof(*config));
+
+	fd = open_config(path);
+	if (fd < 0)
+		return fd;
+
+	file = fdopen(fd, "r");
+	if (!file) {
+		ret = -errno;
+		close(fd);
+		return ret;
+	}
+
+	while ((len = getline(&line, &size, file)) >= 0) {
+		(void)len;
+		lineno++;
+		ret = parse_config_line(config, line, lineno);
+		if (ret)
+			break;
+	}
+	if (ferror(file) && !ret)
+		ret = -EIO;
+
+	free(line);
+	fclose(file);
+	return ret;
+}
+
+static void free_config(struct hdn_recovery_metadata_config *config)
+{
+	unsigned int i;
+
+	for (i = 0; i < config->count; i++) {
+		free(config->actions[i].name);
+		free(config->actions[i].title);
+		free(config->actions[i].message);
+		free(config->actions[i].consequence);
+		free(config->actions[i].risk);
+	}
+}
+
+static int describe_action(struct hdn_recovery_metadata_config *config,
+			   const char *action)
+{
+	struct hdn_recovery_metadata *meta;
+
+	meta = find_metadata(config, action);
+	if (!meta) {
+		fprintf(stderr,
+			"hdn-recovery-describe: recovery action is not product-approved: %s\n",
+			action);
+		return 1;
+	}
+
+	if (!meta->title || !meta->message || !meta->consequence) {
+		fprintf(stderr,
+			"hdn-recovery-describe: recovery action has incomplete metadata: %s\n",
+			action);
+		return 1;
+	}
+
+	printf("HDN_RECOVERY_METADATA_V1\n");
+	printf("action=%s\n", meta->name);
+	printf("title=%s\n", meta->title);
+	printf("message=%s\n", meta->message);
+	printf("consequence=%s\n", meta->consequence);
+	if (meta->risk)
+		printf("risk=%s\n", meta->risk);
+	return ferror(stdout) ? 1 : 0;
+}
+
+int main(int argc, char **argv)
+{
+	struct hdn_recovery_metadata_config config;
+	const char *config_path = HDN_RECOVERY_METADATA_CONFIG;
+	const char *action = NULL;
+	int ret;
+	int i;
+
+	for (i = 1; i < argc; i++) {
+		if (!strcmp(argv[i], "--config")) {
+			if (++i >= argc) {
+				usage(argv[0]);
+				return 2;
+			}
+			config_path = argv[i];
+		} else if (!strcmp(argv[i], "-h") ||
+			   !strcmp(argv[i], "--help")) {
+			usage(argv[0]);
+			return 0;
+		} else if (!action) {
+			action = argv[i];
+		} else {
+			usage(argv[0]);
+			return 2;
+		}
+	}
+
+	if (!action || !safe_name(action)) {
+		usage(argv[0]);
+		return 2;
+	}
+
+	ret = load_config(config_path, &config);
+	if (ret)
+		return 1;
+
+	ret = describe_action(&config, action);
+	free_config(&config);
+	return ret;
+}
diff -urN linux-7.0.12/tools/hardening/hdn-recovery-portal.c linux-7.0.12-hdn/tools/hardening/hdn-recovery-portal.c
--- linux-7.0.12/tools/hardening/hdn-recovery-portal.c	1969-12-31 18:00:00.000000000 -0600
+++ linux-7.0.12-hdn/tools/hardening/hdn-recovery-portal.c	2026-06-25 19:57:10.274597504 -0500
@@ -0,0 +1,410 @@
+// SPDX-License-Identifier: GPL-2.0-only
+
+#define _GNU_SOURCE
+
+#include <errno.h>
+#include <fcntl.h>
+#include <stdbool.h>
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+#include <sys/stat.h>
+#include <sys/wait.h>
+#include <unistd.h>
+
+#ifndef HDN_RECOVERY_PORTAL_CONFIG
+#define HDN_RECOVERY_PORTAL_CONFIG "/etc/hdn/recovery-portal.conf"
+#endif
+
+#ifndef HDN_RECOVERY_SESSION_PATH
+#define HDN_RECOVERY_SESSION_PATH "/usr/libexec/hdn-recovery-session"
+#endif
+
+#define HDN_RECOVERY_PORTAL_MAX_RULES 64
+
+struct hdn_recovery_portal_rule {
+	char *name;
+	char *session_action;
+};
+
+struct hdn_recovery_portal_config {
+	char *session_helper;
+	struct hdn_recovery_portal_rule rules[HDN_RECOVERY_PORTAL_MAX_RULES];
+	unsigned int count;
+};
+
+static void usage(const char *prog)
+{
+	fprintf(stderr,
+		"Usage: %s [--config FILE] ACTION\n"
+		"\n"
+		"Runs a product-approved recovery UI action.\n"
+		"Config lines:\n"
+		"  session-helper PATH\n"
+		"  action RECOVERY_UI_ACTION RECOVERY_SESSION_ACTION\n",
+		prog);
+}
+
+static char *trim(char *line)
+{
+	char *end;
+
+	while (*line == ' ' || *line == '\t' || *line == '\r' ||
+	       *line == '\n')
+		line++;
+
+	end = line + strlen(line);
+	while (end > line &&
+	       (end[-1] == ' ' || end[-1] == '\t' || end[-1] == '\r' ||
+		end[-1] == '\n'))
+		*--end = '\0';
+
+	return line;
+}
+
+static bool safe_name(const char *name)
+{
+	const char *p;
+
+	if (!name || !name[0] || !strcmp(name, ".") || !strcmp(name, ".."))
+		return false;
+
+	for (p = name; *p; p++) {
+		if ((*p >= 'A' && *p <= 'Z') ||
+		    (*p >= 'a' && *p <= 'z') ||
+		    (*p >= '0' && *p <= '9') ||
+		    *p == '.' || *p == '_' || *p == '-')
+			continue;
+		return false;
+	}
+
+	return true;
+}
+
+static bool path_has_dot_component(const char *path)
+{
+	const char *part = path;
+
+	while (*part) {
+		const char *slash;
+		size_t len;
+
+		while (*part == '/')
+			part++;
+		if (!*part)
+			break;
+
+		slash = strchr(part, '/');
+		len = slash ? (size_t)(slash - part) : strlen(part);
+		if ((len == 1 && part[0] == '.') ||
+		    (len == 2 && part[0] == '.' && part[1] == '.'))
+			return true;
+		part += len;
+	}
+
+	return false;
+}
+
+static int require_safe_absolute(const char *what, const char *path)
+{
+	if (!path || path[0] != '/') {
+		fprintf(stderr,
+			"hdn-recovery-portal: %s must be absolute: %s\n",
+			what, path ? path : "(null)");
+		return -EINVAL;
+	}
+	if (!strcmp(path, "/")) {
+		fprintf(stderr,
+			"hdn-recovery-portal: %s / is too broad\n", what);
+		return -EINVAL;
+	}
+	if (path_has_dot_component(path)) {
+		fprintf(stderr,
+			"hdn-recovery-portal: %s must not contain . or .. path components: %s\n",
+			what, path);
+		return -EINVAL;
+	}
+
+	return 0;
+}
+
+static int replace_string(char **slot, const char *value)
+{
+	char *copy = strdup(value);
+
+	if (!copy)
+		return -ENOMEM;
+	free(*slot);
+	*slot = copy;
+	return 0;
+}
+
+static int set_session_helper(struct hdn_recovery_portal_config *config,
+			      char **tokens, unsigned int count,
+			      unsigned int lineno)
+{
+	if (count != 2) {
+		fprintf(stderr,
+			"hdn-recovery-portal: session-helper line %u needs exactly one path\n",
+			lineno);
+		return -EINVAL;
+	}
+	if (require_safe_absolute("session-helper", tokens[1]))
+		return -EINVAL;
+	return replace_string(&config->session_helper, tokens[1]);
+}
+
+static int add_action(struct hdn_recovery_portal_config *config, char **tokens,
+		      unsigned int count, unsigned int lineno)
+{
+	struct hdn_recovery_portal_rule *rule;
+
+	if (count != 3) {
+		fprintf(stderr,
+			"hdn-recovery-portal: action line %u needs RECOVERY_UI_ACTION RECOVERY_SESSION_ACTION\n",
+			lineno);
+		return -EINVAL;
+	}
+	if (config->count >= HDN_RECOVERY_PORTAL_MAX_RULES) {
+		fprintf(stderr, "hdn-recovery-portal: too many action rules\n");
+		return -E2BIG;
+	}
+	if (!safe_name(tokens[1]) || !safe_name(tokens[2])) {
+		fprintf(stderr,
+			"hdn-recovery-portal: unsafe action name at line %u\n",
+			lineno);
+		return -EINVAL;
+	}
+
+	rule = &config->rules[config->count];
+	rule->name = strdup(tokens[1]);
+	rule->session_action = strdup(tokens[2]);
+	if (!rule->name || !rule->session_action)
+		return -ENOMEM;
+	config->count++;
+	return 0;
+}
+
+static int parse_config_line(struct hdn_recovery_portal_config *config,
+			     char *line, unsigned int lineno)
+{
+	char *tokens[3];
+	unsigned int count = 0;
+	char *save = NULL;
+	char *word;
+
+	line = trim(line);
+	if (!line[0] || line[0] == '#')
+		return 0;
+
+	for (word = strtok_r(line, " \t", &save); word;
+	     word = strtok_r(NULL, " \t", &save)) {
+		if (count >= sizeof(tokens) / sizeof(tokens[0])) {
+			fprintf(stderr,
+				"hdn-recovery-portal: too many fields at line %u\n",
+				lineno);
+			return -E2BIG;
+		}
+		tokens[count++] = word;
+	}
+
+	if (!count)
+		return 0;
+	if (!strcmp(tokens[0], "session-helper"))
+		return set_session_helper(config, tokens, count, lineno);
+	if (!strcmp(tokens[0], "action"))
+		return add_action(config, tokens, count, lineno);
+
+	fprintf(stderr,
+		"hdn-recovery-portal: unknown config key at line %u: %s\n",
+		lineno, tokens[0]);
+	return -EINVAL;
+}
+
+static int open_config(const char *path)
+{
+	struct stat st;
+	int flags = O_RDONLY | O_CLOEXEC;
+	int fd;
+
+#ifdef O_NOFOLLOW
+	flags |= O_NOFOLLOW;
+#endif
+
+	fd = open(path, flags);
+	if (fd < 0) {
+		fprintf(stderr, "hdn-recovery-portal: cannot open %s: %s\n",
+			path, strerror(errno));
+		return -errno;
+	}
+
+	if (fstat(fd, &st)) {
+		int ret = -errno;
+
+		fprintf(stderr, "hdn-recovery-portal: cannot stat %s: %s\n",
+			path, strerror(errno));
+		close(fd);
+		return ret;
+	}
+
+	if (!S_ISREG(st.st_mode) || st.st_uid != 0 || (st.st_mode & 022)) {
+		fprintf(stderr,
+			"hdn-recovery-portal: refusing unsafe config %s\n",
+			path);
+		close(fd);
+		return -EACCES;
+	}
+
+	return fd;
+}
+
+static int load_config(const char *path,
+		       struct hdn_recovery_portal_config *config)
+{
+	char *line = NULL;
+	size_t size = 0;
+	unsigned int lineno = 0;
+	ssize_t len;
+	FILE *file;
+	int ret;
+	int fd;
+
+	memset(config, 0, sizeof(*config));
+
+	ret = replace_string(&config->session_helper, HDN_RECOVERY_SESSION_PATH);
+	if (ret)
+		return ret;
+
+	fd = open_config(path);
+	if (fd < 0)
+		return fd;
+
+	file = fdopen(fd, "r");
+	if (!file) {
+		ret = -errno;
+		close(fd);
+		return ret;
+	}
+
+	while ((len = getline(&line, &size, file)) >= 0) {
+		(void)len;
+		lineno++;
+		ret = parse_config_line(config, line, lineno);
+		if (ret)
+			break;
+	}
+	if (ferror(file) && !ret)
+		ret = -EIO;
+
+	free(line);
+	fclose(file);
+	return ret;
+}
+
+static void free_config(struct hdn_recovery_portal_config *config)
+{
+	unsigned int i;
+
+	free(config->session_helper);
+	for (i = 0; i < config->count; i++) {
+		free(config->rules[i].name);
+		free(config->rules[i].session_action);
+	}
+}
+
+static const struct hdn_recovery_portal_rule *
+find_action(const struct hdn_recovery_portal_config *config,
+	    const char *action)
+{
+	unsigned int i;
+
+	for (i = 0; i < config->count; i++) {
+		if (!strcmp(config->rules[i].name, action))
+			return &config->rules[i];
+	}
+
+	return NULL;
+}
+
+static int child_status_result(pid_t child)
+{
+	int status;
+
+	if (waitpid(child, &status, 0) < 0)
+		return 1;
+	if (!WIFEXITED(status))
+		return 1;
+	return WEXITSTATUS(status);
+}
+
+static int run_recovery_session(const char *helper, const char *action)
+{
+	pid_t child;
+
+	child = fork();
+	if (child < 0) {
+		fprintf(stderr, "hdn-recovery-portal: fork failed: %s\n",
+			strerror(errno));
+		return 1;
+	}
+
+	if (!child) {
+		execl(helper, "hdn-recovery-session", action, NULL);
+		fprintf(stderr, "hdn-recovery-portal: exec %s failed: %s\n",
+			helper, strerror(errno));
+		_exit(errno == ENOENT ? 127 : 126);
+	}
+
+	return child_status_result(child);
+}
+
+int main(int argc, char **argv)
+{
+	struct hdn_recovery_portal_config config;
+	const struct hdn_recovery_portal_rule *rule;
+	const char *config_path = HDN_RECOVERY_PORTAL_CONFIG;
+	const char *action = NULL;
+	int ret;
+	int i;
+
+	for (i = 1; i < argc; i++) {
+		if (!strcmp(argv[i], "--config")) {
+			if (++i >= argc) {
+				usage(argv[0]);
+				return 2;
+			}
+			config_path = argv[i];
+		} else if (!strcmp(argv[i], "-h") ||
+			   !strcmp(argv[i], "--help")) {
+			usage(argv[0]);
+			return 0;
+		} else if (!action) {
+			action = argv[i];
+		} else {
+			usage(argv[0]);
+			return 2;
+		}
+	}
+
+	if (!action || !safe_name(action)) {
+		usage(argv[0]);
+		return 2;
+	}
+
+	ret = load_config(config_path, &config);
+	if (ret)
+		return 1;
+
+	rule = find_action(&config, action);
+	if (!rule) {
+		fprintf(stderr,
+			"hdn-recovery-portal: action is not product-approved: %s\n",
+			action);
+		free_config(&config);
+		return 1;
+	}
+
+	ret = run_recovery_session(config.session_helper, rule->session_action);
+	free_config(&config);
+	return ret ? 1 : 0;
+}
diff -urN linux-7.0.12/tools/hardening/hdn-recovery-prompt.c linux-7.0.12-hdn/tools/hardening/hdn-recovery-prompt.c
--- linux-7.0.12/tools/hardening/hdn-recovery-prompt.c	1969-12-31 18:00:00.000000000 -0600
+++ linux-7.0.12-hdn/tools/hardening/hdn-recovery-prompt.c	2026-06-25 19:17:10.275783092 -0500
@@ -0,0 +1,336 @@
+// SPDX-License-Identifier: GPL-2.0-only
+
+#define _GNU_SOURCE
+
+#include <errno.h>
+#include <stdbool.h>
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+#include <sys/wait.h>
+#include <unistd.h>
+
+#define HDN_RECOVERY_PROMPT_MAX_METADATA 8192
+#define HDN_RECOVERY_PROMPT_MAX_TEXT 512
+
+struct hdn_recovery_metadata {
+	char *action;
+	char *title;
+	char *message;
+	char *consequence;
+	char *risk;
+};
+
+static void usage(const char *prog)
+{
+	fprintf(stderr,
+		"Usage: %s [--test-approve|--test-deny] ACTION\n"
+		"\n"
+		"Reads HDN recovery metadata on stdin, shows a recovery confirmation\n"
+		"prompt, and exits 0 only when the user approves.\n",
+		prog);
+}
+
+static bool safe_name(const char *name)
+{
+	const char *p;
+
+	if (!name || !name[0] || !strcmp(name, ".") || !strcmp(name, ".."))
+		return false;
+
+	for (p = name; *p; p++) {
+		if ((*p >= 'A' && *p <= 'Z') ||
+		    (*p >= 'a' && *p <= 'z') ||
+		    (*p >= '0' && *p <= '9') ||
+		    *p == '.' || *p == '_' || *p == '-')
+			continue;
+		return false;
+	}
+
+	return true;
+}
+
+static bool safe_text(const char *text)
+{
+	const unsigned char *p;
+	size_t len;
+
+	if (!text || !text[0])
+		return false;
+
+	len = strlen(text);
+	if (len > HDN_RECOVERY_PROMPT_MAX_TEXT)
+		return false;
+
+	for (p = (const unsigned char *)text; *p; p++) {
+		if (*p >= 0x20 && *p <= 0x7e)
+			continue;
+		return false;
+	}
+
+	return true;
+}
+
+static int read_metadata(char **metadata)
+{
+	char *buf;
+	size_t done = 0;
+
+	buf = calloc(HDN_RECOVERY_PROMPT_MAX_METADATA + 1, 1);
+	if (!buf)
+		return -ENOMEM;
+
+	for (;;) {
+		ssize_t len;
+
+		len = read(STDIN_FILENO, buf + done,
+			   HDN_RECOVERY_PROMPT_MAX_METADATA - done);
+		if (len < 0) {
+			if (errno == EINTR)
+				continue;
+			free(buf);
+			return -errno;
+		}
+		if (!len)
+			break;
+		done += (size_t)len;
+		if (done == HDN_RECOVERY_PROMPT_MAX_METADATA) {
+			free(buf);
+			return -E2BIG;
+		}
+	}
+
+	if (!done) {
+		free(buf);
+		return -EINVAL;
+	}
+
+	buf[done] = '\0';
+	*metadata = buf;
+	return 0;
+}
+
+static int set_field(char **slot, char *value, bool action)
+{
+	if (*slot)
+		return -EINVAL;
+	if (action) {
+		if (!safe_name(value))
+			return -EINVAL;
+	} else if (!safe_text(value)) {
+		return -EINVAL;
+	}
+
+	*slot = value;
+	return 0;
+}
+
+static int parse_metadata(char *blob, struct hdn_recovery_metadata *metadata)
+{
+	char *save = NULL;
+	char *line;
+	bool magic = false;
+
+	memset(metadata, 0, sizeof(*metadata));
+
+	for (line = strtok_r(blob, "\n", &save); line;
+	     line = strtok_r(NULL, "\n", &save)) {
+		size_t len = strlen(line);
+
+		if (len && line[len - 1] == '\r')
+			line[--len] = '\0';
+		if (!len)
+			continue;
+		if (!strcmp(line, "HDN_RECOVERY_METADATA_V1")) {
+			magic = true;
+			continue;
+		}
+		if (!strncmp(line, "action=", 7)) {
+			if (set_field(&metadata->action, line + 7, true))
+				return -EINVAL;
+			continue;
+		}
+		if (!strncmp(line, "title=", 6)) {
+			if (set_field(&metadata->title, line + 6, false))
+				return -EINVAL;
+			continue;
+		}
+		if (!strncmp(line, "message=", 8)) {
+			if (set_field(&metadata->message, line + 8, false))
+				return -EINVAL;
+			continue;
+		}
+		if (!strncmp(line, "consequence=", 12)) {
+			if (set_field(&metadata->consequence, line + 12, false))
+				return -EINVAL;
+			continue;
+		}
+		if (!strncmp(line, "risk=", 5)) {
+			if (set_field(&metadata->risk, line + 5, false))
+				return -EINVAL;
+			continue;
+		}
+
+		return -EINVAL;
+	}
+
+	if (!magic || !metadata->action || !metadata->title ||
+	    !metadata->message || !metadata->consequence)
+		return -EINVAL;
+
+	return 0;
+}
+
+static int child_status_result(pid_t child)
+{
+	int status;
+
+	if (waitpid(child, &status, 0) < 0)
+		return 1;
+	if (!WIFEXITED(status))
+		return 1;
+	return WEXITSTATUS(status);
+}
+
+static int run_prompt_tool(const char *path, char *const argv[])
+{
+	pid_t child;
+
+	child = fork();
+	if (child < 0) {
+		fprintf(stderr, "hdn-recovery-prompt: fork failed: %s\n",
+			strerror(errno));
+		return 1;
+	}
+
+	if (!child) {
+		execv(path, argv);
+		_exit(errno == ENOENT ? 127 : 126);
+	}
+
+	return child_status_result(child) ? 1 : 0;
+}
+
+static bool desktop_session_available(void)
+{
+	const char *display = getenv("DISPLAY");
+	const char *wayland = getenv("WAYLAND_DISPLAY");
+
+	return (display && display[0]) || (wayland && wayland[0]);
+}
+
+static int show_graphical_prompt(const struct hdn_recovery_metadata *metadata)
+{
+	char body[2048];
+
+	if (!desktop_session_available()) {
+		fprintf(stderr,
+			"hdn-recovery-prompt: no graphical session available; denying request\n");
+		return 1;
+	}
+
+	if (metadata->risk) {
+		snprintf(body, sizeof(body), "%s\n\n%s\n\nRisk: %s",
+			 metadata->message, metadata->consequence,
+			 metadata->risk);
+	} else {
+		snprintf(body, sizeof(body), "%s\n\n%s",
+			 metadata->message, metadata->consequence);
+	}
+
+	if (!access("/usr/bin/zenity", X_OK)) {
+		char *const argv[] = {
+			"zenity", "--question", "--title", metadata->title,
+			"--width", "480", "--ok-label", "Continue",
+			"--cancel-label", "Cancel", "--text", body, NULL
+		};
+
+		return run_prompt_tool("/usr/bin/zenity", argv);
+	}
+
+	if (!access("/usr/bin/kdialog", X_OK)) {
+		char *const argv[] = {
+			"kdialog", "--title", metadata->title,
+			"--yes-label", "Continue", "--no-label", "Cancel",
+			"--yesno", body, NULL
+		};
+
+		return run_prompt_tool("/usr/bin/kdialog", argv);
+	}
+
+	if (!access("/usr/bin/xmessage", X_OK)) {
+		char *const argv[] = {
+			"xmessage", "-center", "-title", metadata->title,
+			"-buttons", "Continue:0,Cancel:1", body, NULL
+		};
+
+		return run_prompt_tool("/usr/bin/xmessage", argv);
+	}
+
+	fprintf(stderr,
+		"hdn-recovery-prompt: no supported graphical prompt helper found\n");
+	return 1;
+}
+
+int main(int argc, char **argv)
+{
+	struct hdn_recovery_metadata metadata;
+	const char *action = NULL;
+	bool test_approve = false;
+	bool test_deny = false;
+	char *blob = NULL;
+	int ret;
+	int i;
+
+	for (i = 1; i < argc; i++) {
+		if (!strcmp(argv[i], "--help") || !strcmp(argv[i], "-h")) {
+			usage(argv[0]);
+			return 0;
+		}
+		if (!strcmp(argv[i], "--test-approve")) {
+			test_approve = true;
+			continue;
+		}
+		if (!strcmp(argv[i], "--test-deny")) {
+			test_deny = true;
+			continue;
+		}
+		if (!action) {
+			action = argv[i];
+			continue;
+		}
+		usage(argv[0]);
+		return 2;
+	}
+
+	if (!action || !safe_name(action) || (test_approve && test_deny)) {
+		usage(argv[0]);
+		return 2;
+	}
+
+	ret = read_metadata(&blob);
+	if (ret) {
+		fprintf(stderr, "hdn-recovery-prompt: invalid recovery metadata\n");
+		return 1;
+	}
+
+	ret = parse_metadata(blob, &metadata);
+	if (ret || strcmp(metadata.action, action)) {
+		fprintf(stderr, "hdn-recovery-prompt: rejected recovery metadata\n");
+		free(blob);
+		return 1;
+	}
+
+	if (test_approve) {
+		free(blob);
+		return 0;
+	}
+	if (test_deny) {
+		free(blob);
+		return 1;
+	}
+
+	ret = show_graphical_prompt(&metadata);
+	free(blob);
+	return ret;
+}
diff -urN linux-7.0.12/tools/hardening/hdn-recovery-session.c linux-7.0.12-hdn/tools/hardening/hdn-recovery-session.c
--- linux-7.0.12/tools/hardening/hdn-recovery-session.c	1969-12-31 18:00:00.000000000 -0600
+++ linux-7.0.12-hdn/tools/hardening/hdn-recovery-session.c	2026-06-25 16:03:03.839950612 -0500
@@ -0,0 +1,652 @@
+// SPDX-License-Identifier: GPL-2.0-only
+
+#define _GNU_SOURCE
+
+#include <errno.h>
+#include <fcntl.h>
+#include <stdbool.h>
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+#include <sys/stat.h>
+#include <sys/wait.h>
+#include <unistd.h>
+
+#ifndef HDN_RECOVERY_SESSION_CONFIG
+#define HDN_RECOVERY_SESSION_CONFIG "/etc/hdn/recovery-session.conf"
+#endif
+
+#ifndef HDN_RECOVERY_DESCRIBE_PATH
+#define HDN_RECOVERY_DESCRIBE_PATH "/usr/libexec/hdn-recovery-describe"
+#endif
+
+#ifndef HDN_RECOVERY_ACTION_PATH
+#define HDN_RECOVERY_ACTION_PATH "/usr/libexec/hdn-recovery-action"
+#endif
+
+#ifndef HDN_RECOVERY_CONFIRM_PATH
+#define HDN_RECOVERY_CONFIRM_PATH "/usr/libexec/hdn-recovery-confirm"
+#endif
+
+#define HDN_RECOVERY_SESSION_MAX_ARGS 16
+#define HDN_RECOVERY_SESSION_MAX_METADATA 8192
+
+struct hdn_recovery_session_config {
+	char *describe_helper;
+	char *action_helper;
+	char *confirm_argv[HDN_RECOVERY_SESSION_MAX_ARGS + 1];
+	unsigned int confirm_argc;
+};
+
+static void usage(const char *prog)
+{
+	fprintf(stderr,
+		"Usage: %s [--config FILE] ACTION\n"
+		"\n"
+		"Runs a named recovery session: describe, confirm, then act.\n"
+		"Config lines:\n"
+		"  describe-helper PATH\n"
+		"  confirm-helper PATH [ARG...]\n"
+		"  action-helper PATH\n",
+		prog);
+}
+
+static char *trim(char *line)
+{
+	char *end;
+
+	while (*line == ' ' || *line == '\t' || *line == '\r' ||
+	       *line == '\n')
+		line++;
+
+	end = line + strlen(line);
+	while (end > line &&
+	       (end[-1] == ' ' || end[-1] == '\t' || end[-1] == '\r' ||
+		end[-1] == '\n'))
+		*--end = '\0';
+
+	return line;
+}
+
+static bool safe_name(const char *name)
+{
+	const char *p;
+
+	if (!name || !name[0] || !strcmp(name, ".") || !strcmp(name, ".."))
+		return false;
+
+	for (p = name; *p; p++) {
+		if ((*p >= 'A' && *p <= 'Z') ||
+		    (*p >= 'a' && *p <= 'z') ||
+		    (*p >= '0' && *p <= '9') ||
+		    *p == '.' || *p == '_' || *p == '-')
+			continue;
+		return false;
+	}
+
+	return true;
+}
+
+static bool path_has_dot_component(const char *path)
+{
+	const char *part = path;
+
+	while (*part) {
+		const char *slash;
+		size_t len;
+
+		while (*part == '/')
+			part++;
+		if (!*part)
+			break;
+
+		slash = strchr(part, '/');
+		len = slash ? (size_t)(slash - part) : strlen(part);
+		if ((len == 1 && part[0] == '.') ||
+		    (len == 2 && part[0] == '.' && part[1] == '.'))
+			return true;
+		part += len;
+	}
+
+	return false;
+}
+
+static int require_safe_absolute(const char *what, const char *path)
+{
+	if (!path || path[0] != '/') {
+		fprintf(stderr,
+			"hdn-recovery-session: %s must be absolute: %s\n",
+			what, path ? path : "(null)");
+		return -EINVAL;
+	}
+	if (!strcmp(path, "/")) {
+		fprintf(stderr,
+			"hdn-recovery-session: %s / is too broad\n", what);
+		return -EINVAL;
+	}
+	if (path_has_dot_component(path)) {
+		fprintf(stderr,
+			"hdn-recovery-session: %s must not contain . or .. path components: %s\n",
+			what, path);
+		return -EINVAL;
+	}
+
+	return 0;
+}
+
+static int require_safe_arg(const char *arg, unsigned int lineno)
+{
+	const unsigned char *p;
+
+	if (!arg || !arg[0]) {
+		fprintf(stderr,
+			"hdn-recovery-session: empty helper argument at line %u\n",
+			lineno);
+		return -EINVAL;
+	}
+
+	for (p = (const unsigned char *)arg; *p; p++) {
+		if (*p >= 0x21 && *p <= 0x7e)
+			continue;
+		fprintf(stderr,
+			"hdn-recovery-session: unsafe helper argument at line %u\n",
+			lineno);
+		return -EINVAL;
+	}
+
+	return 0;
+}
+
+static int replace_string(char **slot, const char *value)
+{
+	char *copy = strdup(value);
+
+	if (!copy)
+		return -ENOMEM;
+	free(*slot);
+	*slot = copy;
+	return 0;
+}
+
+static int set_helper_path(char **slot, const char *kind, char **tokens,
+			   unsigned int count, unsigned int lineno)
+{
+	if (count != 2) {
+		fprintf(stderr,
+			"hdn-recovery-session: %s line %u needs exactly one path\n",
+			kind, lineno);
+		return -EINVAL;
+	}
+	if (require_safe_absolute(kind, tokens[1]))
+		return -EINVAL;
+	return replace_string(slot, tokens[1]);
+}
+
+static int set_confirm_helper(struct hdn_recovery_session_config *config,
+			      char **tokens, unsigned int count,
+			      unsigned int lineno)
+{
+	unsigned int i;
+
+	if (count < 2) {
+		fprintf(stderr,
+			"hdn-recovery-session: confirm-helper line %u needs PATH [ARG...]\n",
+			lineno);
+		return -EINVAL;
+	}
+	if (count > HDN_RECOVERY_SESSION_MAX_ARGS) {
+		fprintf(stderr,
+			"hdn-recovery-session: too many confirm-helper arguments at line %u\n",
+			lineno);
+		return -E2BIG;
+	}
+	if (require_safe_absolute("confirm-helper", tokens[1]))
+		return -EINVAL;
+
+	for (i = 2; i < count; i++) {
+		if (require_safe_arg(tokens[i], lineno))
+			return -EINVAL;
+	}
+
+	for (i = 0; i < config->confirm_argc; i++)
+		free(config->confirm_argv[i]);
+	config->confirm_argc = 0;
+
+	for (i = 1; i < count; i++) {
+		config->confirm_argv[config->confirm_argc] =
+			strdup(tokens[i]);
+		if (!config->confirm_argv[config->confirm_argc])
+			return -ENOMEM;
+		config->confirm_argc++;
+	}
+	config->confirm_argv[config->confirm_argc] = NULL;
+	return 0;
+}
+
+static int parse_config_line(struct hdn_recovery_session_config *config,
+			     char *line, unsigned int lineno)
+{
+	char *tokens[HDN_RECOVERY_SESSION_MAX_ARGS + 1];
+	unsigned int count = 0;
+	char *save = NULL;
+	char *word;
+
+	line = trim(line);
+	if (!line[0] || line[0] == '#')
+		return 0;
+
+	for (word = strtok_r(line, " \t", &save); word;
+	     word = strtok_r(NULL, " \t", &save)) {
+		if (count >= sizeof(tokens) / sizeof(tokens[0])) {
+			fprintf(stderr,
+				"hdn-recovery-session: too many fields at line %u\n",
+				lineno);
+			return -E2BIG;
+		}
+		tokens[count++] = word;
+	}
+
+	if (!count)
+		return 0;
+	if (!strcmp(tokens[0], "describe-helper"))
+		return set_helper_path(&config->describe_helper,
+				       "describe-helper", tokens, count,
+				       lineno);
+	if (!strcmp(tokens[0], "action-helper"))
+		return set_helper_path(&config->action_helper,
+				       "action-helper", tokens, count,
+				       lineno);
+	if (!strcmp(tokens[0], "confirm-helper"))
+		return set_confirm_helper(config, tokens, count, lineno);
+
+	fprintf(stderr,
+		"hdn-recovery-session: unknown config key at line %u: %s\n",
+		lineno, tokens[0]);
+	return -EINVAL;
+}
+
+static int open_config(const char *path)
+{
+	struct stat st;
+	int flags = O_RDONLY | O_CLOEXEC;
+	int fd;
+
+#ifdef O_NOFOLLOW
+	flags |= O_NOFOLLOW;
+#endif
+
+	fd = open(path, flags);
+	if (fd < 0) {
+		fprintf(stderr, "hdn-recovery-session: cannot open %s: %s\n",
+			path, strerror(errno));
+		return -errno;
+	}
+
+	if (fstat(fd, &st)) {
+		int ret = -errno;
+
+		fprintf(stderr, "hdn-recovery-session: cannot stat %s: %s\n",
+			path, strerror(errno));
+		close(fd);
+		return ret;
+	}
+
+	if (!S_ISREG(st.st_mode) || st.st_uid != 0 || (st.st_mode & 022)) {
+		fprintf(stderr,
+			"hdn-recovery-session: refusing unsafe config %s\n",
+			path);
+		close(fd);
+		return -EACCES;
+	}
+
+	return fd;
+}
+
+static int load_config(const char *path,
+		       struct hdn_recovery_session_config *config)
+{
+	char *line = NULL;
+	size_t size = 0;
+	unsigned int lineno = 0;
+	ssize_t len;
+	FILE *file;
+	int ret = 0;
+	int fd;
+
+	memset(config, 0, sizeof(*config));
+
+	ret = replace_string(&config->describe_helper,
+			     HDN_RECOVERY_DESCRIBE_PATH);
+	if (ret)
+		return ret;
+	ret = replace_string(&config->action_helper, HDN_RECOVERY_ACTION_PATH);
+	if (ret)
+		return ret;
+	config->confirm_argv[0] = strdup(HDN_RECOVERY_CONFIRM_PATH);
+	if (!config->confirm_argv[0])
+		return -ENOMEM;
+	config->confirm_argc = 1;
+
+	fd = open_config(path);
+	if (fd < 0)
+		return fd;
+
+	file = fdopen(fd, "r");
+	if (!file) {
+		ret = -errno;
+		close(fd);
+		return ret;
+	}
+
+	while ((len = getline(&line, &size, file)) >= 0) {
+		(void)len;
+		lineno++;
+		ret = parse_config_line(config, line, lineno);
+		if (ret)
+			break;
+	}
+	if (ferror(file) && !ret)
+		ret = -EIO;
+
+	free(line);
+	fclose(file);
+	return ret;
+}
+
+static void free_config(struct hdn_recovery_session_config *config)
+{
+	unsigned int i;
+
+	free(config->describe_helper);
+	free(config->action_helper);
+	for (i = 0; i < config->confirm_argc; i++)
+		free(config->confirm_argv[i]);
+}
+
+static int child_status_result(pid_t child)
+{
+	int status;
+
+	if (waitpid(child, &status, 0) < 0)
+		return 1;
+	if (!WIFEXITED(status))
+		return 1;
+	return WEXITSTATUS(status);
+}
+
+static int read_metadata_from_describe(const char *helper, const char *action,
+				       char **metadata)
+{
+	char buf[HDN_RECOVERY_SESSION_MAX_METADATA + 1];
+	size_t done = 0;
+	int pipefd[2];
+	pid_t child;
+	int status;
+
+	if (pipe(pipefd)) {
+		fprintf(stderr, "hdn-recovery-session: pipe failed: %s\n",
+			strerror(errno));
+		return 1;
+	}
+
+	child = fork();
+	if (child < 0) {
+		fprintf(stderr, "hdn-recovery-session: fork failed: %s\n",
+			strerror(errno));
+		close(pipefd[0]);
+		close(pipefd[1]);
+		return 1;
+	}
+
+	if (!child) {
+		close(pipefd[0]);
+		if (dup2(pipefd[1], STDOUT_FILENO) < 0)
+			_exit(126);
+		close(pipefd[1]);
+		execl(helper, "hdn-recovery-describe", action, NULL);
+		fprintf(stderr, "hdn-recovery-session: exec %s failed: %s\n",
+			helper, strerror(errno));
+		_exit(errno == ENOENT ? 127 : 126);
+	}
+
+	close(pipefd[1]);
+	for (;;) {
+		ssize_t len;
+
+		len = read(pipefd[0], buf + done,
+			   HDN_RECOVERY_SESSION_MAX_METADATA - done);
+		if (len < 0) {
+			if (errno == EINTR)
+				continue;
+			fprintf(stderr,
+				"hdn-recovery-session: read recovery metadata failed: %s\n",
+				strerror(errno));
+			close(pipefd[0]);
+			(void)child_status_result(child);
+			return 1;
+		}
+		if (!len)
+			break;
+		done += (size_t)len;
+		if (done == HDN_RECOVERY_SESSION_MAX_METADATA) {
+			fprintf(stderr,
+				"hdn-recovery-session: recovery metadata too large\n");
+			close(pipefd[0]);
+			(void)child_status_result(child);
+			return 1;
+		}
+	}
+	close(pipefd[0]);
+
+	status = child_status_result(child);
+	if (status)
+		return status;
+	if (!done) {
+		fprintf(stderr, "hdn-recovery-session: empty recovery metadata\n");
+		return 1;
+	}
+
+	buf[done] = '\0';
+	*metadata = strdup(buf);
+	if (!*metadata)
+		return 1;
+	return 0;
+}
+
+static bool metadata_has_line(const char *metadata, const char *line)
+{
+	const char *match = metadata;
+	size_t line_len = strlen(line);
+
+	while ((match = strstr(match, line))) {
+		if ((match == metadata || match[-1] == '\n') &&
+		    match[line_len] == '\n')
+			return true;
+		match += line_len;
+	}
+
+	return false;
+}
+
+static int validate_metadata(const char *metadata, const char *action)
+{
+	char expected[256];
+
+	if (!metadata_has_line(metadata, "HDN_RECOVERY_METADATA_V1")) {
+		fprintf(stderr,
+			"hdn-recovery-session: recovery metadata missing magic\n");
+		return 1;
+	}
+	if (snprintf(expected, sizeof(expected), "action=%s", action) >=
+	    (int)sizeof(expected)) {
+		fprintf(stderr, "hdn-recovery-session: action name too long\n");
+		return 1;
+	}
+	if (!metadata_has_line(metadata, expected)) {
+		fprintf(stderr,
+			"hdn-recovery-session: recovery metadata action mismatch\n");
+		return 1;
+	}
+
+	return 0;
+}
+
+static int write_all(int fd, const char *buf, size_t size)
+{
+	size_t done = 0;
+
+	while (done < size) {
+		ssize_t ret = write(fd, buf + done, size - done);
+
+		if (ret < 0) {
+			if (errno == EINTR)
+				continue;
+			return -errno;
+		}
+		if (!ret)
+			return -EIO;
+		done += (size_t)ret;
+	}
+
+	return 0;
+}
+
+static int run_confirm_helper(const struct hdn_recovery_session_config *config,
+			      const char *action, const char *metadata)
+{
+	char *argv[HDN_RECOVERY_SESSION_MAX_ARGS + 2];
+	int pipefd[2];
+	unsigned int i;
+	pid_t child;
+	int write_ret;
+	int status;
+
+	if (pipe(pipefd)) {
+		fprintf(stderr, "hdn-recovery-session: pipe failed: %s\n",
+			strerror(errno));
+		return 1;
+	}
+
+	child = fork();
+	if (child < 0) {
+		fprintf(stderr, "hdn-recovery-session: fork failed: %s\n",
+			strerror(errno));
+		close(pipefd[0]);
+		close(pipefd[1]);
+		return 1;
+	}
+
+	if (!child) {
+		close(pipefd[1]);
+		if (dup2(pipefd[0], STDIN_FILENO) < 0)
+			_exit(126);
+		close(pipefd[0]);
+		for (i = 0; i < config->confirm_argc; i++)
+			argv[i] = config->confirm_argv[i];
+		argv[config->confirm_argc] = (char *)action;
+		argv[config->confirm_argc + 1] = NULL;
+		execv(config->confirm_argv[0], argv);
+		fprintf(stderr, "hdn-recovery-session: exec %s failed: %s\n",
+			config->confirm_argv[0], strerror(errno));
+		_exit(errno == ENOENT ? 127 : 126);
+	}
+
+	close(pipefd[0]);
+	write_ret = write_all(pipefd[1], metadata, strlen(metadata));
+	close(pipefd[1]);
+	status = child_status_result(child);
+	if (write_ret && !status) {
+		fprintf(stderr,
+			"hdn-recovery-session: confirm helper input failed: %s\n",
+			strerror(-write_ret));
+		return 1;
+	}
+	return status ? 1 : 0;
+}
+
+static int run_action_helper(const char *helper, const char *action)
+{
+	pid_t child;
+
+	child = fork();
+	if (child < 0) {
+		fprintf(stderr, "hdn-recovery-session: fork failed: %s\n",
+			strerror(errno));
+		return 1;
+	}
+
+	if (!child) {
+		execl(helper, "hdn-recovery-action", action, NULL);
+		fprintf(stderr, "hdn-recovery-session: exec %s failed: %s\n",
+			helper, strerror(errno));
+		_exit(errno == ENOENT ? 127 : 126);
+	}
+
+	return child_status_result(child);
+}
+
+int main(int argc, char **argv)
+{
+	struct hdn_recovery_session_config config;
+	const char *config_path = HDN_RECOVERY_SESSION_CONFIG;
+	const char *action = NULL;
+	char *metadata = NULL;
+	int ret;
+	int i;
+
+	for (i = 1; i < argc; i++) {
+		if (!strcmp(argv[i], "--config")) {
+			if (++i >= argc) {
+				usage(argv[0]);
+				return 2;
+			}
+			config_path = argv[i];
+		} else if (!strcmp(argv[i], "-h") ||
+			   !strcmp(argv[i], "--help")) {
+			usage(argv[0]);
+			return 0;
+		} else if (!action) {
+			action = argv[i];
+		} else {
+			usage(argv[0]);
+			return 2;
+		}
+	}
+
+	if (!action || !safe_name(action)) {
+		usage(argv[0]);
+		return 2;
+	}
+
+	ret = load_config(config_path, &config);
+	if (ret)
+		return 1;
+
+	ret = read_metadata_from_describe(config.describe_helper, action,
+					  &metadata);
+	if (ret)
+		goto out;
+
+	ret = validate_metadata(metadata, action);
+	if (ret)
+		goto out;
+
+	ret = run_confirm_helper(&config, action, metadata);
+	if (ret) {
+		fprintf(stderr,
+			"hdn-recovery-session: recovery confirmation denied: %s\n",
+			action);
+		goto out;
+	}
+
+	ret = run_action_helper(config.action_helper, action);
+	if (ret)
+		fprintf(stderr,
+			"hdn-recovery-session: recovery action failed for %s\n",
+			action);
+
+out:
+	free(metadata);
+	free_config(&config);
+	return ret ? 1 : 0;
+}
diff -urN linux-7.0.12/tools/hardening/hdn-rofs-apply.c linux-7.0.12-hdn/tools/hardening/hdn-rofs-apply.c
--- linux-7.0.12/tools/hardening/hdn-rofs-apply.c	1969-12-31 18:00:00.000000000 -0600
+++ linux-7.0.12-hdn/tools/hardening/hdn-rofs-apply.c	2026-06-26 15:22:38.141586930 -0500
@@ -0,0 +1,387 @@
+// SPDX-License-Identifier: GPL-2.0-only
+
+#define _GNU_SOURCE
+
+#include <ctype.h>
+#include <errno.h>
+#include <fcntl.h>
+#include <limits.h>
+#include <linux/mount.h>
+#include <stdbool.h>
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+#include <sys/stat.h>
+#include <sys/mount.h>
+#include <sys/syscall.h>
+#include <unistd.h>
+
+#ifndef AT_RECURSIVE
+#define AT_RECURSIVE 0x8000
+#endif
+
+enum hdn_rofs_requirement {
+	HDN_ROFS_REQUIRED,
+	HDN_ROFS_OPTIONAL,
+};
+
+static void usage(const char *prog)
+{
+	fprintf(stderr,
+		"Usage: %s [-r|--recursive] [-f PATHS.conf] [MOUNTPOINT...]\n"
+		"PATHS.conf entries: PATH, required PATH, or optional PATH\n",
+		prog);
+}
+
+static char *trim(char *line)
+{
+	char *end;
+
+	while (*line == ' ' || *line == '\t' || *line == '\r' ||
+	       *line == '\n')
+		line++;
+
+	end = line + strlen(line);
+	while (end > line &&
+	       (end[-1] == ' ' || end[-1] == '\t' || end[-1] == '\r' ||
+		end[-1] == '\n'))
+		*--end = '\0';
+
+	return line;
+}
+
+static int decode_mountinfo_path(const char *src, char *dst, size_t dst_size)
+{
+	size_t di = 0;
+
+	while (*src) {
+		unsigned char ch;
+
+		if (di + 1 >= dst_size)
+			return -ENAMETOOLONG;
+
+		if (src[0] == '\\' &&
+		    src[1] >= '0' && src[1] <= '7' &&
+		    src[2] >= '0' && src[2] <= '7' &&
+		    src[3] >= '0' && src[3] <= '7') {
+			ch = ((src[1] - '0') << 6) |
+			     ((src[2] - '0') << 3) |
+			     (src[3] - '0');
+			src += 4;
+		} else {
+			ch = *src++;
+		}
+
+		dst[di++] = ch;
+	}
+
+	dst[di] = '\0';
+	return 0;
+}
+
+static int fallback_path_is_mountpoint(const char *path)
+{
+	char parent[PATH_MAX];
+	struct stat st;
+	struct stat parent_st;
+	size_t len;
+
+	if (!strcmp(path, "/"))
+		return 1;
+
+	len = strlen(path);
+	if (len + 4 > sizeof(parent))
+		return -ENAMETOOLONG;
+
+	memcpy(parent, path, len);
+	if (len > 1 && parent[len - 1] == '/')
+		memcpy(parent + len, "..", 3);
+	else
+		memcpy(parent + len, "/..", 4);
+
+	if (stat(path, &st))
+		return -errno;
+	if (stat(parent, &parent_st))
+		return -errno;
+
+	return st.st_dev != parent_st.st_dev ||
+	       (st.st_dev == parent_st.st_dev && st.st_ino == parent_st.st_ino);
+}
+
+static int path_is_mountpoint(const char *path)
+{
+	char *line = NULL;
+	size_t size = 0;
+	FILE *file;
+	int ret = 0;
+
+	file = fopen("/proc/self/mountinfo", "r");
+	if (!file)
+		return fallback_path_is_mountpoint(path);
+
+	while (getline(&line, &size, file) >= 0) {
+		char decoded[PATH_MAX];
+		char *fields = line;
+		char *mountpoint = NULL;
+		int i;
+
+		for (i = 0; i < 5; i++) {
+			mountpoint = strsep(&fields, " ");
+			if (!mountpoint)
+				break;
+		}
+		if (!mountpoint)
+			continue;
+
+		if (decode_mountinfo_path(mountpoint, decoded,
+					  sizeof(decoded)))
+			continue;
+		if (!strcmp(decoded, path)) {
+			ret = 1;
+			break;
+		}
+	}
+
+	free(line);
+	fclose(file);
+	return ret;
+}
+
+static int parse_config_entry(char *entry, const char **path,
+			      enum hdn_rofs_requirement *requirement)
+{
+	char *first = entry;
+	char *rest;
+
+	*requirement = HDN_ROFS_REQUIRED;
+	*path = entry;
+
+	if (entry[0] == '/')
+		return 0;
+
+	rest = first;
+	while (*rest && !isspace((unsigned char)*rest))
+		rest++;
+	if (*rest) {
+		*rest++ = '\0';
+		rest = trim(rest);
+	}
+
+	if (!strcmp(first, "required")) {
+		*requirement = HDN_ROFS_REQUIRED;
+		*path = rest;
+	} else if (!strcmp(first, "optional")) {
+		*requirement = HDN_ROFS_OPTIONAL;
+		*path = rest;
+	} else {
+		fprintf(stderr,
+			"hdn-rofs-apply: unknown path-list directive: %s\n",
+			first);
+		return -EINVAL;
+	}
+
+	if (!*path || !(*path)[0]) {
+		fprintf(stderr,
+			"hdn-rofs-apply: missing path for %s entry\n", first);
+		return -EINVAL;
+	}
+
+	return 0;
+}
+
+static int apply_mount_readonly(const char *path, bool recursive)
+{
+	if (!recursive) {
+		if (!mount(NULL, path, NULL, MS_REMOUNT | MS_RDONLY, NULL))
+			return 0;
+		return -errno;
+	}
+
+#ifdef __NR_mount_setattr
+	struct mount_attr attr = {
+		.attr_set = MOUNT_ATTR_RDONLY,
+	};
+
+	if (!syscall(__NR_mount_setattr, AT_FDCWD, path, AT_RECURSIVE, &attr,
+		     sizeof(attr)))
+		return 0;
+
+	return -errno;
+#endif
+
+	return -EOPNOTSUPP;
+}
+
+static int apply_path(const char *path, bool recursive,
+		      enum hdn_rofs_requirement requirement)
+{
+	int ret;
+
+	if (!path[0] || path[0] != '/') {
+		fprintf(stderr, "hdn-rofs-apply: path must be absolute: %s\n",
+			path);
+		return -EINVAL;
+	}
+
+	if (requirement == HDN_ROFS_OPTIONAL) {
+		ret = path_is_mountpoint(path);
+		if (ret < 0) {
+			if (ret == -ENOENT) {
+				fprintf(stderr,
+					"hdn-rofs-apply: skipping absent optional path %s\n",
+					path);
+				return 0;
+			}
+			fprintf(stderr,
+				"hdn-rofs-apply: cannot inspect optional path %s: %s\n",
+				path, strerror(-ret));
+			return ret;
+		}
+		if (!ret) {
+			fprintf(stderr,
+				"hdn-rofs-apply: skipping optional non-mountpoint %s\n",
+				path);
+			return 0;
+		}
+	}
+
+	ret = apply_mount_readonly(path, recursive);
+	if (ret)
+		fprintf(stderr,
+			"hdn-rofs-apply: failed to make %s read-only: %s\n",
+			path, strerror(-ret));
+
+	return ret;
+}
+
+static int apply_file(const char *path, bool recursive)
+{
+	char *line = NULL;
+	size_t size = 0;
+	ssize_t len;
+	FILE *file;
+	struct stat st;
+	int flags = O_RDONLY | O_CLOEXEC;
+	int fd;
+	int ret = 0;
+
+#ifdef O_NOFOLLOW
+	flags |= O_NOFOLLOW;
+#endif
+
+	fd = open(path, flags);
+	if (fd < 0) {
+		fprintf(stderr, "hdn-rofs-apply: cannot open %s: %s\n", path,
+			strerror(errno));
+		return -errno;
+	}
+
+	if (fstat(fd, &st)) {
+		ret = -errno;
+		fprintf(stderr, "hdn-rofs-apply: cannot stat %s: %s\n", path,
+			strerror(errno));
+		close(fd);
+		return ret;
+	}
+
+	if (!S_ISREG(st.st_mode) || st.st_uid != 0 || (st.st_mode & 022)) {
+		fprintf(stderr,
+			"hdn-rofs-apply: refusing unsafe path list %s\n",
+			path);
+		close(fd);
+		return -EACCES;
+	}
+
+	file = fdopen(fd, "r");
+	if (!file) {
+		ret = -errno;
+		fprintf(stderr, "hdn-rofs-apply: fdopen %s failed: %s\n",
+			path, strerror(errno));
+		close(fd);
+		return ret;
+	}
+
+	while ((len = getline(&line, &size, file)) >= 0) {
+		char *entry = trim(line);
+		enum hdn_rofs_requirement requirement;
+		const char *entry_path;
+		int path_ret;
+
+		(void)len;
+		if (!entry[0] || entry[0] == '#')
+			continue;
+
+		path_ret = parse_config_entry(entry, &entry_path,
+					      &requirement);
+		if (!path_ret)
+			path_ret = apply_path(entry_path, recursive,
+					      requirement);
+		if (path_ret && !ret)
+			ret = path_ret;
+	}
+
+	if (ferror(file) && !ret)
+		ret = -EIO;
+
+	free(line);
+	fclose(file);
+	return ret;
+}
+
+int main(int argc, char **argv)
+{
+	bool recursive = false;
+	const char *config = NULL;
+	bool saw_path = false;
+	int ret = 0;
+	int i;
+
+	for (i = 1; i < argc; i++) {
+		if (!strcmp(argv[i], "-r") || !strcmp(argv[i], "--recursive")) {
+			recursive = true;
+			continue;
+		} else if (!strcmp(argv[i], "-f") ||
+			   !strcmp(argv[i], "--file")) {
+			if (++i >= argc) {
+				usage(argv[0]);
+				return 2;
+			}
+			config = argv[i];
+			continue;
+		} else if (!strcmp(argv[i], "-h") ||
+			   !strcmp(argv[i], "--help")) {
+			usage(argv[0]);
+			return 0;
+		} else if (!strcmp(argv[i], "--")) {
+			i++;
+			break;
+		} else if (argv[i][0] != '-') {
+			break;
+		}
+
+		usage(argv[0]);
+		return 2;
+	}
+
+	if (config) {
+		ret = apply_file(config, recursive);
+		if (ret)
+			return 1;
+	}
+
+	for (; i < argc; i++) {
+		int path_ret = apply_path(argv[i], recursive,
+					  HDN_ROFS_REQUIRED);
+
+		saw_path = true;
+		if (path_ret && !ret)
+			ret = path_ret;
+	}
+
+	if (!config && !saw_path) {
+		usage(argv[0]);
+		return 2;
+	}
+
+	return ret ? 1 : 0;
+}
diff -urN linux-7.0.12/tools/hardening/hdn-rofs-transaction.c linux-7.0.12-hdn/tools/hardening/hdn-rofs-transaction.c
--- linux-7.0.12/tools/hardening/hdn-rofs-transaction.c	1969-12-31 18:00:00.000000000 -0600
+++ linux-7.0.12-hdn/tools/hardening/hdn-rofs-transaction.c	2026-06-25 12:29:29.811541448 -0500
@@ -0,0 +1,104 @@
+// SPDX-License-Identifier: GPL-2.0-only
+
+#define _GNU_SOURCE
+
+#include <errno.h>
+#include <stdbool.h>
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+#include <sys/mount.h>
+#include <sys/wait.h>
+#include <unistd.h>
+
+static void usage(const char *prog)
+{
+	fprintf(stderr, "Usage: %s MOUNTPOINT -- COMMAND [ARG...]\n", prog);
+}
+
+static int remount_state(const char *path, bool readonly)
+{
+	unsigned long flags = MS_REMOUNT;
+
+	if (readonly)
+		flags |= MS_RDONLY;
+
+	if (!mount(NULL, path, NULL, flags, NULL))
+		return 0;
+
+	fprintf(stderr, "hdn-rofs-transaction: remount %s %s failed: %s\n",
+		path, readonly ? "read-only" : "writable", strerror(errno));
+	return -errno;
+}
+
+static int run_command(char **argv)
+{
+	int status;
+	pid_t child;
+
+	child = fork();
+	if (child < 0) {
+		fprintf(stderr, "hdn-rofs-transaction: fork failed: %s\n",
+			strerror(errno));
+		return 1;
+	}
+
+	if (!child) {
+		execv(argv[0], argv);
+		fprintf(stderr, "hdn-rofs-transaction: exec %s failed: %s\n",
+			argv[0], strerror(errno));
+		_exit(127);
+	}
+
+	if (waitpid(child, &status, 0) < 0) {
+		fprintf(stderr, "hdn-rofs-transaction: wait failed: %s\n",
+			strerror(errno));
+		return 1;
+	}
+
+	if (WIFEXITED(status))
+		return WEXITSTATUS(status);
+	if (WIFSIGNALED(status))
+		return 128 + WTERMSIG(status);
+
+	return 1;
+}
+
+int main(int argc, char **argv)
+{
+	const char *mountpoint;
+	int command_arg = 2;
+	int command_status;
+	int seal_ret;
+
+	if (argc < 4) {
+		usage(argv[0]);
+		return 2;
+	}
+
+	mountpoint = argv[1];
+	if (mountpoint[0] != '/') {
+		fprintf(stderr,
+			"hdn-rofs-transaction: mountpoint must be absolute: %s\n",
+			mountpoint);
+		return 2;
+	}
+
+	if (!strcmp(argv[command_arg], "--")) {
+		command_arg++;
+		if (command_arg >= argc) {
+			usage(argv[0]);
+			return 2;
+		}
+	}
+
+	if (remount_state(mountpoint, false))
+		return 1;
+
+	command_status = run_command(&argv[command_arg]);
+	seal_ret = remount_state(mountpoint, true);
+	if (seal_ret)
+		return 1;
+
+	return command_status;
+}
diff -urN linux-7.0.12/tools/hardening/hdn-system-transaction.c linux-7.0.12-hdn/tools/hardening/hdn-system-transaction.c
--- linux-7.0.12/tools/hardening/hdn-system-transaction.c	1969-12-31 18:00:00.000000000 -0600
+++ linux-7.0.12-hdn/tools/hardening/hdn-system-transaction.c	2026-06-25 14:38:11.163196929 -0500
@@ -0,0 +1,413 @@
+// SPDX-License-Identifier: GPL-2.0-only
+
+#define _GNU_SOURCE
+
+#include <errno.h>
+#include <fcntl.h>
+#include <limits.h>
+#include <stdbool.h>
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+#include <sys/stat.h>
+#include <unistd.h>
+
+#ifndef HDN_SYSTEM_TRANSACTION_CONFIG
+#define HDN_SYSTEM_TRANSACTION_CONFIG "/etc/hdn/system-transactions.conf"
+#endif
+
+#ifndef HDN_ADMIN_BROKER_PATH
+#define HDN_ADMIN_BROKER_PATH "/usr/libexec/hdn-admin-broker"
+#endif
+
+#define HDN_TRANSACTION_MAX_RULES 64
+#define HDN_TRANSACTION_MAX_ARGS 32
+
+struct hdn_transaction_rule {
+	char *name;
+	char *mountpoint;
+	char *worker_argv[HDN_TRANSACTION_MAX_ARGS + 1];
+	unsigned int worker_argc;
+};
+
+struct hdn_transaction_config {
+	struct hdn_transaction_rule rules[HDN_TRANSACTION_MAX_RULES];
+	unsigned int count;
+};
+
+static void usage(const char *prog)
+{
+	fprintf(stderr,
+		"Usage: %s [--config FILE] [--broker PATH] [--approval-token TOKEN] OPERATION\n"
+		"\n"
+		"Runs a named product transaction through hdn-admin-broker.\n"
+		"Config lines: transaction NAME MOUNTPOINT WORKER [ARG...]\n",
+		prog);
+}
+
+static char *trim(char *line)
+{
+	char *end;
+
+	while (*line == ' ' || *line == '\t' || *line == '\r' ||
+	       *line == '\n')
+		line++;
+
+	end = line + strlen(line);
+	while (end > line &&
+	       (end[-1] == ' ' || end[-1] == '\t' || end[-1] == '\r' ||
+		end[-1] == '\n'))
+		*--end = '\0';
+
+	return line;
+}
+
+static bool path_has_dot_component(const char *path)
+{
+	const char *part = path;
+
+	while (*part) {
+		const char *slash;
+		size_t len;
+
+		while (*part == '/')
+			part++;
+		if (!*part)
+			break;
+
+		slash = strchr(part, '/');
+		len = slash ? (size_t)(slash - part) : strlen(part);
+		if ((len == 1 && part[0] == '.') ||
+		    (len == 2 && part[0] == '.' && part[1] == '.'))
+			return true;
+		part += len;
+	}
+
+	return false;
+}
+
+static int require_safe_absolute(const char *what, const char *path)
+{
+	if (!path || path[0] != '/') {
+		fprintf(stderr,
+			"hdn-system-transaction: %s must be absolute: %s\n",
+			what, path ? path : "(null)");
+		return -EINVAL;
+	}
+	if (path_has_dot_component(path)) {
+		fprintf(stderr,
+			"hdn-system-transaction: %s must not contain . or .. path components: %s\n",
+			what, path);
+		return -EINVAL;
+	}
+
+	return 0;
+}
+
+static bool safe_operation_name(const char *name)
+{
+	const char *p;
+
+	if (!name || !name[0] || !strcmp(name, ".") || !strcmp(name, ".."))
+		return false;
+
+	for (p = name; *p; p++) {
+		if ((*p >= 'A' && *p <= 'Z') ||
+		    (*p >= 'a' && *p <= 'z') ||
+		    (*p >= '0' && *p <= '9') ||
+		    *p == '.' || *p == '_' || *p == '-')
+			continue;
+		return false;
+	}
+
+	return true;
+}
+
+static int add_rule(struct hdn_transaction_config *config, char **tokens,
+		    unsigned int count, unsigned int lineno)
+{
+	struct hdn_transaction_rule *rule;
+	unsigned int i;
+
+	if (count < 4) {
+		fprintf(stderr,
+			"hdn-system-transaction: transaction line %u needs NAME MOUNTPOINT WORKER\n",
+			lineno);
+		return -EINVAL;
+	}
+	if (config->count >= HDN_TRANSACTION_MAX_RULES) {
+		fprintf(stderr,
+			"hdn-system-transaction: too many transaction rules\n");
+		return -E2BIG;
+	}
+	if (!safe_operation_name(tokens[1])) {
+		fprintf(stderr,
+			"hdn-system-transaction: unsafe operation name at line %u: %s\n",
+			lineno, tokens[1]);
+		return -EINVAL;
+	}
+	if (require_safe_absolute("mountpoint", tokens[2]) ||
+	    require_safe_absolute("worker", tokens[3]))
+		return -EINVAL;
+	if (count - 3 > HDN_TRANSACTION_MAX_ARGS) {
+		fprintf(stderr,
+			"hdn-system-transaction: too many worker arguments at line %u\n",
+			lineno);
+		return -E2BIG;
+	}
+
+	rule = &config->rules[config->count];
+	rule->name = strdup(tokens[1]);
+	rule->mountpoint = strdup(tokens[2]);
+	if (!rule->name || !rule->mountpoint)
+		return -ENOMEM;
+
+	for (i = 3; i < count; i++) {
+		rule->worker_argv[rule->worker_argc] = strdup(tokens[i]);
+		if (!rule->worker_argv[rule->worker_argc])
+			return -ENOMEM;
+		rule->worker_argc++;
+	}
+	rule->worker_argv[rule->worker_argc] = NULL;
+	config->count++;
+	return 0;
+}
+
+static int parse_config_line(struct hdn_transaction_config *config, char *line,
+			     unsigned int lineno)
+{
+	char *tokens[HDN_TRANSACTION_MAX_ARGS + 4];
+	unsigned int count = 0;
+	char *save = NULL;
+	char *word;
+
+	line = trim(line);
+	if (!line[0] || line[0] == '#')
+		return 0;
+
+	for (word = strtok_r(line, " \t", &save); word;
+	     word = strtok_r(NULL, " \t", &save)) {
+		if (count >= sizeof(tokens) / sizeof(tokens[0])) {
+			fprintf(stderr,
+				"hdn-system-transaction: too many fields at line %u\n",
+				lineno);
+			return -E2BIG;
+		}
+		tokens[count++] = word;
+	}
+
+	if (!count)
+		return 0;
+	if (strcmp(tokens[0], "transaction")) {
+		fprintf(stderr,
+			"hdn-system-transaction: unknown config key at line %u: %s\n",
+			lineno, tokens[0]);
+		return -EINVAL;
+	}
+
+	return add_rule(config, tokens, count, lineno);
+}
+
+static int open_config(const char *path)
+{
+	struct stat st;
+	int flags = O_RDONLY | O_CLOEXEC;
+	int fd;
+
+#ifdef O_NOFOLLOW
+	flags |= O_NOFOLLOW;
+#endif
+
+	fd = open(path, flags);
+	if (fd < 0) {
+		fprintf(stderr, "hdn-system-transaction: cannot open %s: %s\n",
+			path, strerror(errno));
+		return -errno;
+	}
+
+	if (fstat(fd, &st)) {
+		int ret = -errno;
+
+		fprintf(stderr, "hdn-system-transaction: cannot stat %s: %s\n",
+			path, strerror(errno));
+		close(fd);
+		return ret;
+	}
+
+	if (!S_ISREG(st.st_mode) || st.st_uid != 0 || (st.st_mode & 022)) {
+		fprintf(stderr,
+			"hdn-system-transaction: refusing unsafe config %s\n",
+			path);
+		close(fd);
+		return -EACCES;
+	}
+
+	return fd;
+}
+
+static int load_config(const char *path, struct hdn_transaction_config *config)
+{
+	char *line = NULL;
+	size_t size = 0;
+	unsigned int lineno = 0;
+	ssize_t len;
+	FILE *file;
+	int ret = 0;
+	int fd;
+
+	memset(config, 0, sizeof(*config));
+
+	fd = open_config(path);
+	if (fd < 0)
+		return fd;
+
+	file = fdopen(fd, "r");
+	if (!file) {
+		ret = -errno;
+		close(fd);
+		return ret;
+	}
+
+	while ((len = getline(&line, &size, file)) >= 0) {
+		(void)len;
+		lineno++;
+		ret = parse_config_line(config, line, lineno);
+		if (ret)
+			break;
+	}
+	if (ferror(file) && !ret)
+		ret = -EIO;
+
+	free(line);
+	fclose(file);
+	return ret;
+}
+
+static void free_config(struct hdn_transaction_config *config)
+{
+	unsigned int i;
+	unsigned int j;
+
+	for (i = 0; i < config->count; i++) {
+		free(config->rules[i].name);
+		free(config->rules[i].mountpoint);
+		for (j = 0; j < config->rules[i].worker_argc; j++)
+			free(config->rules[i].worker_argv[j]);
+	}
+}
+
+static const struct hdn_transaction_rule *
+find_rule(const struct hdn_transaction_config *config, const char *operation)
+{
+	unsigned int i;
+
+	for (i = 0; i < config->count; i++) {
+		if (!strcmp(config->rules[i].name, operation))
+			return &config->rules[i];
+	}
+
+	return NULL;
+}
+
+static int run_rule(const char *broker, const char *approval_token,
+		    const struct hdn_transaction_rule *rule)
+{
+	char **argv;
+	unsigned int argc = 0;
+	unsigned int i;
+
+	argv = calloc((size_t)rule->worker_argc + 8, sizeof(*argv));
+	if (!argv) {
+		fprintf(stderr, "hdn-system-transaction: allocation failed\n");
+		return 1;
+	}
+
+	argv[argc++] = (char *)broker;
+	if (approval_token) {
+		argv[argc++] = "--approval-token";
+		argv[argc++] = (char *)approval_token;
+	}
+	argv[argc++] = "rofs-transaction";
+	argv[argc++] = rule->mountpoint;
+	argv[argc++] = "--";
+	for (i = 0; i < rule->worker_argc; i++)
+		argv[argc++] = rule->worker_argv[i];
+	argv[argc] = NULL;
+
+	execv(broker, argv);
+	fprintf(stderr, "hdn-system-transaction: exec %s failed: %s\n",
+		broker, strerror(errno));
+	free(argv);
+	return errno == ENOENT ? 127 : 126;
+}
+
+int main(int argc, char **argv)
+{
+	const char *config_path = HDN_SYSTEM_TRANSACTION_CONFIG;
+	const char *broker_path = HDN_ADMIN_BROKER_PATH;
+	const char *approval_token = NULL;
+	const char *operation = NULL;
+	const struct hdn_transaction_rule *rule;
+	struct hdn_transaction_config config;
+	int ret = 0;
+	int i;
+
+	for (i = 1; i < argc; i++) {
+		if (!strcmp(argv[i], "--help")) {
+			usage(argv[0]);
+			return 0;
+		}
+		if (!strcmp(argv[i], "--config")) {
+			if (++i >= argc)
+				goto bad_args;
+			config_path = argv[i];
+			continue;
+		}
+		if (!strcmp(argv[i], "--broker")) {
+			if (++i >= argc)
+				goto bad_args;
+			broker_path = argv[i];
+			continue;
+		}
+		if (!strcmp(argv[i], "--approval-token")) {
+			if (++i >= argc)
+				goto bad_args;
+			approval_token = argv[i];
+			continue;
+		}
+		if (argv[i][0] == '-')
+			goto bad_args;
+		if (operation)
+			goto bad_args;
+		operation = argv[i];
+	}
+
+	if (!operation || !safe_operation_name(operation))
+		goto bad_args;
+	if (require_safe_absolute("config", config_path) ||
+	    require_safe_absolute("broker", broker_path) ||
+	    (approval_token &&
+	     require_safe_absolute("approval token", approval_token)))
+		return 1;
+
+	ret = load_config(config_path, &config);
+	if (ret)
+		return 1;
+
+	rule = find_rule(&config, operation);
+	if (!rule) {
+		fprintf(stderr,
+			"hdn-system-transaction: operation is not product-approved: %s\n",
+			operation);
+		free_config(&config);
+		return 1;
+	}
+
+	ret = run_rule(broker_path, approval_token, rule);
+	free_config(&config);
+	return ret;
+
+bad_args:
+	usage(argv[0]);
+	return 2;
+}
diff -urN linux-7.0.12/tools/hardening/image-seals.conf linux-7.0.12-hdn/tools/hardening/image-seals.conf
--- linux-7.0.12/tools/hardening/image-seals.conf	1969-12-31 18:00:00.000000000 -0600
+++ linux-7.0.12-hdn/tools/hardening/image-seals.conf	2026-06-25 15:18:48.557280910 -0500
@@ -0,0 +1,13 @@
+# SPDX-License-Identifier: GPL-2.0-only
+#
+# Named product image sealing sequences consumed by hdn-image-seal.
+# Keep this file root-owned and not writable by group/other.
+#
+# Format:
+#   seal NAME policy-commit SIGNED_POLICY
+#   seal NAME rofs-apply READONLY_LIST
+#
+# Repeated lines with the same NAME run in file order.
+
+seal default policy-commit /usr/lib/hdn/policies/default.hdn
+seal default rofs-apply /etc/hdn/readonly-mounts.conf
diff -urN linux-7.0.12/tools/hardening/package-hooks.conf linux-7.0.12-hdn/tools/hardening/package-hooks.conf
--- linux-7.0.12/tools/hardening/package-hooks.conf	1969-12-31 18:00:00.000000000 -0600
+++ linux-7.0.12-hdn/tools/hardening/package-hooks.conf	2026-06-25 15:50:47.741586264 -0500
@@ -0,0 +1,11 @@
+# SPDX-License-Identifier: GPL-2.0-only
+#
+# Named package-manager and image-updater hooks consumed by hdn-package-hook.
+# Keep this file root-owned and not writable by group/other.
+#
+# Format:
+#   hook NAME system-transaction TRANSACTION
+#   hook NAME image-seal SEAL
+
+hook package-update system-transaction package-update
+hook image-seal-default image-seal default
diff -urN linux-7.0.12/tools/hardening/package-manager-hooks/apt/99-hdn-package-update linux-7.0.12-hdn/tools/hardening/package-manager-hooks/apt/99-hdn-package-update
--- linux-7.0.12/tools/hardening/package-manager-hooks/apt/99-hdn-package-update	1969-12-31 18:00:00.000000000 -0600
+++ linux-7.0.12-hdn/tools/hardening/package-manager-hooks/apt/99-hdn-package-update	2026-06-25 16:17:23.445968454 -0500
@@ -0,0 +1,8 @@
+// SPDX-License-Identifier: GPL-2.0-only
+//
+// APT/dpkg integration for HDN protected system updates.
+// Install as /etc/apt/apt.conf.d/99-hdn-package-update.
+
+DPkg::Post-Invoke {
+	"/usr/libexec/hdn-package-hook package-update";
+};
diff -urN linux-7.0.12/tools/hardening/package-manager-hooks/dnf/99-hdn-package-update.action linux-7.0.12-hdn/tools/hardening/package-manager-hooks/dnf/99-hdn-package-update.action
--- linux-7.0.12/tools/hardening/package-manager-hooks/dnf/99-hdn-package-update.action	1969-12-31 18:00:00.000000000 -0600
+++ linux-7.0.12-hdn/tools/hardening/package-manager-hooks/dnf/99-hdn-package-update.action	2026-06-26 15:35:54.873539136 -0500
@@ -0,0 +1,9 @@
+# SPDX-License-Identifier: GPL-2.0-only
+#
+# DNF 4 post-transaction-actions integration for HDN protected system updates.
+# Install as /etc/dnf/plugins/post-transaction-actions.d/99-hdn-package-update.action.
+#
+# The command is intentionally a stable product action. Raw mountpoints,
+# workers, broker tokens, and helper paths remain in root-owned HDN config.
+
