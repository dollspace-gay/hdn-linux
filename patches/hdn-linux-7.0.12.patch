+static int signal_crash_sentinel(void)
+{
+	long page_size;
+	void *mapping;
+	volatile char value;
+
+	page_size = sysconf(_SC_PAGESIZE);
+	if (page_size <= 0)
+		return 2;
+
+	mapping = mmap(NULL, page_size, PROT_NONE,
+		       MAP_PRIVATE | MAP_ANONYMOUS, -1, 0);
+	if (mapping == MAP_FAILED)
+		return 2;
+
+	value = *(volatile char *)mapping;
+	(void)value;
+	return 2;
+}
