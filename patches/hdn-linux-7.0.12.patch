+	if (rootfd < 0)
+		return 2;
+
+	child = spawn_chroot_outside_target(&release_fd);
+	if (child < 0) {
+		close(rootfd);
+		return 2;
+	}
+
+	if (chroot(HDN_CHROOT_TEST_DIR)) {
+		close(rootfd);
+		release_chroot_outside_target(child, release_fd);
+		return 2;
+	}
