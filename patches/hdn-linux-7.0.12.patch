+		.iov_len = len,
+	};
+	struct iovec remote = {
+		.iov_base = (void *)addr,
+		.iov_len = len,
+	};
+
+	return syscall(__NR_process_vm_writev, pid, &local, 1, &remote, 1, 0);
+}
