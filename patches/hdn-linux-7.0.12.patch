+	int wd;
+	int fd;
+
+	fd = inotify_init1(IN_CLOEXEC);
+	if (fd < 0)
+		return 2;
+
+	errno = 0;
+	wd = inotify_add_watch(fd, path, IN_ALL_EVENTS);
+	saved_errno = errno;
