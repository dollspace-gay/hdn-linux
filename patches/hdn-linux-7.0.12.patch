+static ssize_t hdn_process_vm_read(pid_t pid, unsigned long addr,
+				   void *buf, size_t len)
+{
+	struct iovec local = {
+		.iov_base = buf,
+		.iov_len = len,
+	};
+	struct iovec remote = {
+		.iov_base = (void *)addr,
+		.iov_len = len,
+	};
+
+	return syscall(__NR_process_vm_readv, pid, &local, 1, &remote, 1, 0);
+}
