+			"hdn-desktop-daemon: action is not product-approved: %s\n",
+			action);
+		return 1;
+	}
+
+	return run_desktop_action(config->desktop_action_helper, action) ? 1 : 0;
+}
+
+static int run_stdio(const struct hdn_desktop_daemon_config *config)
+{
+	char *line = NULL;
+	size_t size = 0;
+	bool failed = false;
+	ssize_t len;
+
+	puts("HDN_DESKTOP_DAEMON_READY");
+	fflush(stdout);
+
+	while ((len = getline(&line, &size, stdin)) >= 0) {
+		char *action = trim(line);
+		int ret;
+
+		(void)len;
+		if (!action[0])
+			continue;
+
+		if (!safe_name(action)) {
+			printf("HDN_DESKTOP_DAEMON_RESULT action=(invalid) status=invalid exit=1\n");
+			fflush(stdout);
+			failed = true;
+			continue;
+		}
+
+		ret = dispatch_action(config, action);
+		printf("HDN_DESKTOP_DAEMON_RESULT action=%s status=%s exit=%d\n",
+		       action, ret ? "failed" : "ok", ret ? 1 : 0);
+		fflush(stdout);
+		if (ret)
+			failed = true;
+	}
+
+	free(line);
+	return ferror(stdin) || failed ? 1 : 0;
+}
+
+int main(int argc, char **argv)
+{
+	struct hdn_desktop_daemon_config config;
+	const char *config_path = HDN_DESKTOP_DAEMON_CONFIG;
+	const char *action = NULL;
+	bool stdio_mode = false;
+	int ret;
+	int i;
+
+	for (i = 1; i < argc; i++) {
+		if (!strcmp(argv[i], "--config")) {
+			if (++i >= argc) {
+				usage(argv[0]);
+				return 2;
+			}
+			config_path = argv[i];
+		} else if (!strcmp(argv[i], "--stdio")) {
+			stdio_mode = true;
+		} else if (!strcmp(argv[i], "-h") ||
+			   !strcmp(argv[i], "--help")) {
+			usage(argv[0]);
+			return 0;
+		} else if (!action) {
+			action = argv[i];
+		} else {
+			usage(argv[0]);
+			return 2;
+		}
+	}
+
+	if (stdio_mode && action) {
+		usage(argv[0]);
+		return 2;
+	}
+	if (!stdio_mode && !action) {
+		usage(argv[0]);
+		return 2;
+	}
+
+	ret = load_config(config_path, &config);
+	if (ret)
+		return 1;
+
+	if (stdio_mode)
+		ret = run_stdio(&config);
+	else
+		ret = dispatch_action(&config, action);
+
+	free_config(&config);
+	return ret ? 1 : 0;
+}
