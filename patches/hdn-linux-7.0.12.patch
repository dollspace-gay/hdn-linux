+static int read_pidfd_fdinfo(int fd, char *buf, size_t size)
+{
+	char path[64];
+	ssize_t len;
+	int infofd;
+	int saved_errno;
+
+	if (!size)
+		return -EINVAL;
+
+	snprintf(path, sizeof(path), "/proc/self/fdinfo/%d", fd);
+	infofd = open(path, O_RDONLY | O_CLOEXEC);
+	if (infofd < 0)
+		return -errno;
+
+	len = read(infofd, buf, size - 1);
+	saved_errno = errno;
+	close(infofd);
+	if (len < 0)
+		return -saved_errno;
+
+	buf[len] = '\0';
+	return 0;
+}
