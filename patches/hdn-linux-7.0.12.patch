+static pid_t spawn_execute_only_target(unsigned long *addr)
+{
+	int sync_pipe[2];
+	pid_t child;
+
+	if (pipe(sync_pipe))
+		return -1;
+
+	child = fork();
+	if (child < 0) {
+		close(sync_pipe[0]);
+		close(sync_pipe[1]);
+		return -1;
+	}
+
+	if (!child) {
+		close(sync_pipe[0]);
+		if (dup2(sync_pipe[1], 3) < 0)
+			_exit(2);
+		if (sync_pipe[1] != 3)
+			close(sync_pipe[1]);
+		execl("/hdn_smoke", "hdn_smoke", "--exec-only-target", NULL);
+		_exit(2);
+	}
+
+	close(sync_pipe[1]);
+	if (read(sync_pipe[0], addr, sizeof(*addr)) != sizeof(*addr)) {
+		close(sync_pipe[0]);
+		kill(child, SIGKILL);
+		waitpid(child, NULL, 0);
+		return -1;
+	}
+	close(sync_pipe[0]);
+
+	return child;
+}
