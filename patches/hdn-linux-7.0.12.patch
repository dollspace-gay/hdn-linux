+		return 2;
+
+	errno = 0;
+	ret = mprotect(addr, page_size, PROT_READ | PROT_EXEC);
+	if (ret)
+		saved_errno = errno;
+	munmap(addr, page_size);
+
+	if (!ret)
+		return 1;
+	return errno_is_denial(saved_errno) ? 0 : 2;
+#else
+	return KSFT_SKIP;
+#endif
