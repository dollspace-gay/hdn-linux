+static pid_t spawn_proc_memmap_target(void)
+{
+	int sync_pipe[2];
+	char ready = 'R';
+	pid_t child;
+
+	if (pipe(sync_pipe))
+		return -1;
+
+	child = fork();
+	if (child < 0) {
+		close(sync_pipe[0]);
+		close(sync_pipe[1]);
+		return -1;
+	}
+
+	if (!child) {
+		close(sync_pipe[0]);
+		if (write(sync_pipe[1], &ready, sizeof(ready)) != sizeof(ready))
+			_exit(2);
+		close(sync_pipe[1]);
+		for (;;)
+			pause();
+	}
+
+	close(sync_pipe[1]);
+	if (read(sync_pipe[0], &ready, sizeof(ready)) != sizeof(ready)) {
+		close(sync_pipe[0]);
+		kill(child, SIGKILL);
+		waitpid(child, NULL, 0);
+		return -1;
+	}
+	close(sync_pipe[0]);
+
+	return child;
+}
