+	target_profile_id = hdn_task_profile_id_nosleep(target);
+	if (hdn_current_profile_id() == target_profile_id)
+		return 0;
+	if (hdn_profile_allows(HDN_AUTH_SIGNAL, HDN_TRANS_SIGNAL))
+		return 0;
