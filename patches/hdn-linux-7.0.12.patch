+static int proc_ipaddr_unix_stream_carry(void)
+{
+	struct sockaddr_un addr = {
+		.sun_family = AF_UNIX,
+	};
+	socklen_t addrlen;
+	int frontend_server = -1;
+	int frontend_client = -1;
+	int frontend_accepted = -1;
+	int unix_server = -1;
+	int unix_client = -1;
+	int unix_accepted = -1;
