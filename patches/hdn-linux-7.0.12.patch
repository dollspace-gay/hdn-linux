+static bool hdn_chroot_restricted_capability(int cap)
+{
+	switch (cap) {
+	case CAP_LINUX_IMMUTABLE:
+	case CAP_NET_ADMIN:
+	case CAP_SYS_MODULE:
+	case CAP_SYS_RAWIO:
+	case CAP_SYS_PACCT:
+	case CAP_SYS_ADMIN:
+	case CAP_SYS_BOOT:
+	case CAP_SYS_TIME:
+	case CAP_NET_RAW:
+	case CAP_SYS_TTY_CONFIG:
+	case CAP_IPC_OWNER:
+	case CAP_SETFCAP:
+	case CAP_SYSLOG:
+	case CAP_MAC_ADMIN:
+		return true;
+	default:
+		return false;
+	}
+}
