+	else if (!strcmp(action_name, "DENY_WATCH"))
+		rule->flags = HDN_OBJECT_DENY_WATCH;
+	else if (!strcmp(action_name, "DENY_XATTR"))
+		rule->flags = HDN_OBJECT_DENY_XATTR;
+	else if (!strcmp(action_name, "DENY_SETXATTR"))
