+static bool recovery_description_has_line(const char *text, const char *line)
+{
+	const char *match = text;
+	size_t len = strlen(line);
+
+	while ((match = strstr(match, line))) {
+		if ((match == text || match[-1] == '\n') &&
+		    match[len] == '\n')
+			return true;
+		match += len;
+	}
+
+	return false;
+}
