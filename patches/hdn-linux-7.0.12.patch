+# SPDX-License-Identifier: GPL-2.0-only
+#
+# DNF5/libdnf5 actions-plugin integration for HDN protected system updates.
+# Install under the distro's libdnf5 actions.d config directory, for example:
+# /etc/dnf/libdnf5-plugins/actions.d/99-hdn-package-update.actions.
