+
+static u64 hdn_string_object_id(const char *text)
+{
+	u64 hash = 14695981039346656037ULL;
+
+	if (!text)
+		return 0;
+
+	while (*text) {
+		hash ^= (u8)*text++;
+		hash *= 1099511628211ULL;
+	}
+
+	return hash;
+}
+
+static u64 hdn_bytes_object_id(const void *data, size_t len)
+{
+	const u8 *bytes = data;
+	u64 hash = 14695981039346656037ULL;
+
+	while (len--) {
+		hash ^= *bytes++;
+		hash *= 1099511628211ULL;
+	}
+
+	return hash;
+}
