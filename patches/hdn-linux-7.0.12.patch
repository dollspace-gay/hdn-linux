+static int tty_controlling_fd(void)
+{
+	int fd;
+
+	if (setsid() < 0 && errno != EPERM)
+		return -1;
+
+	fd = open("/dev/ttyS0", O_RDWR | O_CLOEXEC);
+	if (fd < 0)
+		fd = open("/dev/console", O_RDWR | O_CLOEXEC);
+	if (fd < 0)
+		return -1;
+	if (!isatty(fd)) {
+		close(fd);
+		errno = ENOTTY;
+		return -1;
+	}
+	ioctl(fd, TIOCSCTTY, 0);
+
+	return fd;
+}
